# ============================================================
# SiteMaintenance — Environment Configuration
# Copy this file to .env and fill in all values.
# NEVER commit .env to source control.
# ============================================================

# Application
NODE_ENV=development
PORT=3000

# Base URL of this app — used to generate links in notification emails.
# No trailing slash. Example: http://192.168.1.10:3000
APP_BASE_URL=http://localhost:3000

# Session secret — use a long random string (e.g. openssl rand -base64 48)
SESSION_SECRET=change-me-to-a-long-random-string

# Set to true only when running behind HTTPS. Leave false for plain HTTP.
COOKIE_SECURE=false

# Encryption key for sensitive settings stored in the database (LDAP password, OIDC secret, SMTP password).
# Use a long random string. If not set, SESSION_SECRET is used as the fallback.
# WARNING: changing this key will invalidate all previously encrypted settings — re-enter them in the admin UI.
SETTINGS_ENCRYPTION_KEY=change-me-to-another-long-random-string

# ============================================================
# SQL Server Database
# When NODE_ENV=production the app uses PROD_DB_* variables.
# All other environments (development, etc.) use DEV_DB_*.
# If a prefixed var is absent, the unprefixed DB_* is used as fallback.
# ============================================================

# ── Development database ─────────────────────────────────────
DEV_DB_SERVER=localhost
DEV_DB_DATABASE=SiteMaintenance_Dev
DEV_DB_USER=sa
DEV_DB_PASSWORD=your-dev-db-password
DEV_DB_PORT=1433
DEV_DB_ENCRYPT=false
DEV_DB_TRUST_SERVER_CERT=true

# ── Production database ──────────────────────────────────────
PROD_DB_SERVER=prod-sql-server
PROD_DB_DATABASE=SiteMaintenance
PROD_DB_USER=appuser
PROD_DB_PASSWORD=your-prod-db-password
PROD_DB_PORT=1433
PROD_DB_ENCRYPT=false
PROD_DB_TRUST_SERVER_CERT=false

# ============================================================
# OIDC / Entra ID (optional — also configurable in admin UI)
# ============================================================
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_TENANT_ID=
OIDC_REDIRECT_URI=https://yourapp.example.com/auth/oidc/callback

# ============================================================
# LDAP / Active Directory (optional — also configurable in admin UI)
# ============================================================
LDAP_URL=ldap://dc.example.com:389
LDAP_BIND_DN=CN=svc-app,OU=ServiceAccounts,DC=example,DC=com
LDAP_BIND_CREDENTIALS=
LDAP_SEARCH_BASE=OU=Users,DC=example,DC=com
LDAP_SEARCH_FILTER=(sAMAccountName={{username}})

# ============================================================
# Email / SMTP (optional — also configurable in admin UI)
# ============================================================
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME=SiteMaintenance

# ============================================================
# Push Notifications (PWA / Mobile App)
# Generate VAPID keys once with: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
# VAPID_EMAIL must be a real address (used as contact for push services).
# ============================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# ============================================================
# Logging
# ============================================================
# Directory for log files (relative to src/ or absolute path)
LOG_DIR=./logs
# Log level: error, warn, info, http, debug
LOG_LEVEL=info
