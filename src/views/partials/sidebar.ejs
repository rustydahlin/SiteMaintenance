<% if (user) { %>
<nav id="sidebar" class="col-md-2 col-lg-2 d-md-block bg-body-secondary sidebar collapse">
  <div class="position-sticky pt-4">
    <ul class="nav flex-column">
      <li class="nav-item">
        <a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/">
          <i class="bi bi-speedometer2 me-2"></i>Dashboard
        </a>
      </li>

      <li class="nav-item mt-2">
        <span class="nav-link text-muted text-uppercase small fw-bold ps-3">Field</span>
      </li>
      <li class="nav-item">
        <a class="nav-link <%= currentPath.startsWith('/sites') ? 'active' : '' %>" href="/sites">
          <i class="bi bi-building me-2"></i>Sites
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link <%= currentPath.startsWith('/inventory') ? 'active' : '' %>" href="/inventory">
          <i class="bi bi-box-seam me-2"></i>Inventory
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link <%= currentPath.startsWith('/repairs') ? 'active' : '' %>" href="/repairs">
          <i class="bi bi-wrench-adjustable me-2"></i>Repairs / RMA
        </a>
      </li>

      <% if (user.roles && (user.roles.includes('Admin') || user.roles.includes('Technician'))) { %>
      <li class="nav-item mt-2">
        <span class="nav-link text-muted text-uppercase small fw-bold ps-3">Admin</span>
      </li>
      <% } %>

      <% if (user.roles && user.roles.includes('Admin')) { %>
      <li class="nav-item">
        <a class="nav-link <%= currentPath.startsWith('/admin') ? 'active' : '' %>" href="/admin">
          <i class="bi bi-sliders me-2"></i>Administration
        </a>
      </li>
      <% } %>
    </ul>

    <div class="text-center px-3 py-3 border-top">
      <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
        <i class="bi bi-moon-stars-fill small text-muted"></i>
        <div class="form-check form-switch mb-0">
          <input class="form-check-input" type="checkbox" id="darkModeToggle" role="switch" />
          <label class="form-check-label small text-muted" for="darkModeToggle">Dark mode</label>
        </div>
      </div>
      <img src="/images/publicsafetyteam.png" alt="Logo" style="width:60px; height:auto; margin-bottom:8px;" />
      <p class="text-muted" style="font-size:11px; margin:0;">Call Darron. (701) 328-6974</p>
    </div>
  </div>
</nav>
<% } %>
