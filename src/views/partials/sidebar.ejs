<% if (user) { %>
<nav id="sidebar">
  <div class="position-sticky">

    <!-- Toggle button -->
    <button id="sidebarToggle" title="Toggle sidebar">
      <i class="bi bi-chevron-double-left" id="sidebarToggleIcon"></i>
    </button>

    <% const isNMUpdater = user.roles && user.roles.includes('NetworkMapUpdater') && !user.roles.includes('Admin'); %>
    <ul class="nav flex-column">
      <% if (!isNMUpdater) { %>
      <li class="nav-item">
        <a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/" title="Dashboard">
          <i class="bi bi-speedometer2"></i>
          <span class="nav-label">Dashboard</span>
        </a>
      </li>
      <% } %>

      <li class="nav-item mt-2">
        <span class="sidebar-section-label">Field</span>
        <span class="sidebar-section-divider"></span>
      </li>
      <li class="nav-item">
        <a class="nav-link <%= currentPath.startsWith('/sites') ? 'active' : '' %>" href="/sites" title="Sites">
          <i class="bi bi-building"></i>
          <span class="nav-label">Sites</span>
        </a>
      </li>

      <% if (!isNMUpdater) { %>
      <li class="nav-item">
        <a class="nav-link <%= currentPath.startsWith('/inventory') ? 'active' : '' %>" href="/inventory" title="Inventory">
          <i class="bi bi-box-seam"></i>
          <span class="nav-label">Inventory</span>
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link <%= currentPath.startsWith('/repairs') ? 'active' : '' %>" href="/repairs" title="Repairs / RMA">
          <i class="bi bi-wrench-adjustable"></i>
          <span class="nav-label">Repairs / RMA</span>
        </a>
      </li>
      <% if (maintenanceEnabled && user.roles && (user.roles.includes('Admin') || user.roles.includes('Maintenance') || user.roles.includes('Maintenance-Close'))) { %>
      <li class="nav-item">
        <a class="nav-link <%= currentPath.startsWith('/maintenance') ? 'active' : '' %>" href="/maintenance" title="Maintenance">
          <i class="bi bi-tools"></i>
          <span class="nav-label">Maintenance</span>
        </a>
      </li>
      <% } %>
      <li class="nav-item">
        <a class="nav-link <%= currentPath.startsWith('/logs') ? 'active' : '' %>" href="/logs" title="Logs">
          <i class="bi bi-journal-text"></i>
          <span class="nav-label">Logs</span>
        </a>
      </li>
      <% } %>

      <% if (!isNMUpdater && vendorsEnabled) { %>
      <li class="nav-item mt-2">
        <span class="sidebar-section-label">Vendors</span>
        <span class="sidebar-section-divider"></span>
      </li>
      <li class="nav-item">
        <a class="nav-link <%= currentPath.startsWith('/vendors') ? 'active' : '' %>" href="/vendors" title="Vendors / Contractors">
          <i class="bi bi-building-check"></i>
          <span class="nav-label">Vendors</span>
        </a>
      </li>
      <% } %>

      <% if (user.roles && (user.roles.includes('Admin') || user.roles.includes('Technician') || isNMUpdater || (systemKeysEnabled && user.roles.includes('SystemKeys')))) { %>
      <li class="nav-item mt-2">
        <span class="sidebar-section-label">Admin</span>
        <span class="sidebar-section-divider"></span>
      </li>
      <% } %>

      <% if (!isNMUpdater && systemKeysEnabled && user.roles && (user.roles.includes('Admin') || user.roles.includes('SystemKeys'))) { %>
      <li class="nav-item">
        <a class="nav-link <%= currentPath.startsWith('/system-keys') ? 'active' : '' %>" href="/system-keys" title="System Keys">
          <i class="bi bi-key"></i>
          <span class="nav-label">System Keys</span>
        </a>
      </li>
      <% } %>

      <% if (user.roles && (user.roles.includes('Admin') || isNMUpdater)) { %>
      <li class="nav-item">
        <a class="nav-link <%= currentPath.startsWith('/admin') ? 'active' : '' %>" href="/admin" title="Administration">
          <i class="bi bi-sliders"></i>
          <span class="nav-label">Administration</span>
        </a>
      </li>
      <% } %>
    </ul>

    <div class="sidebar-footer">
      <div class="sidebar-darkmode">
        <i class="bi bi-moon-stars-fill text-muted"></i>
        <span class="nav-label">
          <div class="form-check form-switch mb-0 ms-1">
            <input class="form-check-input" type="checkbox" id="darkModeToggle" role="switch" />
            <label class="form-check-label small text-muted" for="darkModeToggle">Dark mode</label>
          </div>
        </span>
      </div>
      <div class="sidebar-logo nav-label">
        <% if (sidebarLogoUrl) { %>
        <img src="<%= sidebarLogoUrl %>" alt="Logo" style="width:60px;height:auto;margin-bottom:4px;" />
        <% } %>
        <% if (sidebarFooterHtml) { %>
        <p class="text-muted" style="font-size:11px;margin:0;"><%- sidebarFooterHtml %></p>
        <% } %>
      </div>
    </div>

  </div>
</nav>
<% } %>
