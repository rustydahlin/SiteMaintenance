<% const _flashMsgs = flash ? [
  ...(flash.success||[]).map(m => ({ type:'success', icon:'check-circle-fill',       msg: m })),
  ...(flash.error  ||[]).map(m => ({ type:'danger',  icon:'exclamation-triangle-fill', msg: m })),
  ...(flash.warning||[]).map(m => ({ type:'warning', icon:'exclamation-circle-fill',  msg: m })),
  ...(flash.info   ||[]).map(m => ({ type:'info',    icon:'info-circle-fill',          msg: m })),
] : [] %>
<% if (_flashMsgs.length) { %>
<div class="flash-container">
  <% _flashMsgs.forEach(f => { %>
  <div class="alert alert-<%= f.type %> alert-dismissible fade show shadow" role="alert">
    <i class="bi bi-<%= f.icon %> me-2"></i><%= f.msg %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
  <% }) %>
</div>
<% } %>
