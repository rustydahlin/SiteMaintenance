<div class="mb-3">
  <a href="/mobile/vendors" class="btn btn-sm btn-outline-secondary">
    <i class="bi bi-arrow-left"></i> Vendors
  </a>
</div>

<!-- Badges -->
<div class="d-flex gap-2 mb-3">
  <% if (!vendor.IsActive) { %>
    <span class="badge bg-secondary">Inactive</span>
  <% } %>
  <% if (vendor.DoesPMWork) { %>
    <span class="badge bg-success">PM Work</span>
  <% } %>
</div>

<!-- Vendor info -->
<div class="card mobile-card mb-3">
  <div class="card-body">
    <% if (vendor.Phone) { %>
      <div class="detail-row">
        <span class="detail-label">Phone</span>
        <span class="detail-value"><a href="tel:<%= vendor.Phone %>"><%= vendor.Phone %></a></span>
      </div>
    <% } %>
    <% if (vendor.Email) { %>
      <div class="detail-row">
        <span class="detail-label">Email</span>
        <span class="detail-value"><a href="mailto:<%= vendor.Email %>"><%= vendor.Email %></a></span>
      </div>
    <% } %>
    <% if (vendor.Address || vendor.City || vendor.State) { %>
      <div class="detail-row">
        <span class="detail-label">Address</span>
        <span class="detail-value"><%= [vendor.Address, vendor.City, vendor.State, vendor.Zip].filter(Boolean).join(', ') %></span>
      </div>
    <% } %>
    <% if (vendor.Website) { %>
      <div class="detail-row">
        <span class="detail-label">Website</span>
        <span class="detail-value">
          <a href="<%= vendor.Website %>" target="_blank" rel="noopener">
            <%= vendor.Website.replace(/^https?:\/\//, '') %>
            <i class="bi bi-box-arrow-up-right ms-1" style="font-size:0.7rem"></i>
          </a>
        </span>
      </div>
    <% } %>
    <% if (vendor.Notes) { %>
      <div class="detail-row align-items-start">
        <span class="detail-label" style="padding-top:1px">Notes</span>
        <span class="detail-value" style="white-space:pre-wrap"><%= vendor.Notes %></span>
      </div>
    <% } %>
  </div>
</div>

<!-- Contacts -->
<h6 class="text-secondary small text-uppercase fw-semibold mb-2">
  Contacts (<%= vendor.contacts.length %>)
</h6>

<% if (vendor.contacts.length === 0) { %>
  <div class="card mobile-card">
    <div class="card-body text-secondary small text-center py-3">No contacts on file.</div>
  </div>
<% } else { %>
  <div class="card mobile-card">
    <div class="card-body px-3 py-2">
      <% for (const c of vendor.contacts) { %>
        <div class="list-item-row" style="cursor:default">
          <div class="list-item-icon bg-info bg-opacity-10 text-info">
            <i class="bi bi-person"></i>
          </div>
          <div class="list-item-text">
            <div class="item-title">
              <%= c.FirstName %> <%= c.LastName || '' %>
              <% if (!c.IsActive) { %><span class="badge bg-secondary ms-1" style="font-size:0.6rem">Inactive</span><% } %>
            </div>
            <% if (c.Title) { %>
              <div class="item-sub"><%= c.Title %></div>
            <% } %>
            <% if (c.Phone) { %>
              <div class="item-sub">
                <a href="tel:<%= c.Phone %>" class="text-decoration-none">
                  <i class="bi bi-telephone me-1"></i><%= c.Phone %>
                </a>
              </div>
            <% } %>
            <% if (c.Email) { %>
              <div class="item-sub">
                <a href="mailto:<%= c.Email %>" class="text-decoration-none">
                  <i class="bi bi-envelope me-1"></i><%= c.Email %>
                </a>
              </div>
            <% } %>
            <% if (c.Notes) { %>
              <div class="item-sub text-secondary mt-1" style="white-space:pre-wrap"><%= c.Notes %></div>
            <% } %>
          </div>
          <% if (c.ReceivePMEmails) { %>
            <i class="bi bi-envelope-check-fill text-success ms-2 flex-shrink-0" title="Receives PM emails" style="font-size:0.9rem"></i>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
<% } %>

<div class="text-center mt-3">
  <a href="/vendors/<%= vendor.VendorID %>" class="btn btn-sm btn-outline-secondary">
    <i class="bi bi-arrow-up-right-square me-1"></i>Full Vendor Details
  </a>
</div>

<style>
  .detail-row {
    display: flex;
    gap: 10px;
    padding: 6px 0;
    border-bottom: 1px solid var(--bs-border-color);
    font-size: 0.85rem;
  }
  .detail-row:last-child { border-bottom: none; }
  .detail-label {
    flex-shrink: 0;
    width: 70px;
    color: var(--bs-secondary-color);
    font-size: 0.78rem;
  }
  .detail-value { flex: 1; word-break: break-word; }
</style>
