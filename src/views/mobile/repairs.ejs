<!-- Scope toggle -->
<div class="d-flex gap-2 mb-2">
  <a href="/mobile/repairs?status=<%= status %>&scope=mine"
     class="btn btn-sm <%= scope === 'mine' ? 'btn-primary' : 'btn-outline-secondary' %>">Mine</a>
  <a href="/mobile/repairs?status=<%= status %>&scope=all"
     class="btn btn-sm <%= scope === 'all' ? 'btn-primary' : 'btn-outline-secondary' %>">All</a>
</div>

<!-- Status filter tabs -->
<div class="d-flex gap-2 mb-3">
  <a href="/mobile/repairs?status=open&scope=<%= scope %>"
     class="btn btn-sm <%= status === 'open' ? 'btn-primary' : 'btn-outline-secondary' %>">Open</a>
  <a href="/mobile/repairs?status=in-progress&scope=<%= scope %>"
     class="btn btn-sm <%= status === 'in-progress' ? 'btn-primary' : 'btn-outline-secondary' %>">In Progress</a>
  <a href="/mobile/repairs?status=all&scope=<%= scope %>"
     class="btn btn-sm <%= status === 'all' ? 'btn-primary' : 'btn-outline-secondary' %>">All</a>
</div>

<% if (repairs.length === 0) { %>
  <div class="text-center text-secondary py-5">
    <i class="bi bi-wrench" style="font-size:2rem"></i>
    <p class="mt-2 small">No repairs found.</p>
  </div>
<% } else { %>
  <div class="card mobile-card">
    <div class="card-body px-3 py-2">
      <% for (const r of repairs) { %>
        <a href="/mobile/repairs/<%= r.RepairID %>" class="list-item-row">
          <div class="list-item-icon bg-warning bg-opacity-10 text-warning">
            <i class="bi bi-wrench"></i>
          </div>
          <div class="list-item-text">
            <div class="item-title"><%= r.CommonName || r.ModelNumber || r.SerialNumber || 'Unknown Item' %></div>
            <div class="item-sub">
              <span class="text-secondary fw-semibold">#<%= r.RepairID %></span>
              <%
                let repairBadgeClass, repairBadgeLabel;
                if (r.ReceivedDate)       { repairBadgeClass = 'bg-success';           repairBadgeLabel = 'Closed'; }
                else if (!r.SentDate)     { repairBadgeClass = 'bg-secondary';          repairBadgeLabel = 'Not Sent'; }
                else if (r.ExpectedReturnDate && new Date(r.ExpectedReturnDate) < new Date()) {
                                            repairBadgeClass = 'bg-danger';             repairBadgeLabel = 'Overdue'; }
                else                      { repairBadgeClass = 'bg-warning text-dark';  repairBadgeLabel = 'Open'; }
              %>
              · <span class="badge <%= repairBadgeClass %>" style="font-size:0.65rem"><%= repairBadgeLabel %></span>
              <% if (r.RMANumber) { %> · RMA: <%= r.RMANumber %><% } %>
              <% if (r.AssignedUserName) { %> · <%= r.AssignedUserName %><% } %>
            </div>
            <div class="item-sub">
              Created: <%= new Date(r.CreatedAt).toLocaleDateString() %>
              <% if (r.ExpectedReturnDate) { %>
                · Expected: <%= new Date(r.ExpectedReturnDate).toLocaleDateString() %>
                <% if (new Date(r.ExpectedReturnDate) < new Date() && !r.ReceivedDate) { %>
                  <span class="text-danger ms-1"><i class="bi bi-exclamation-circle"></i> Overdue</span>
                <% } %>
              <% } %>
            </div>
          </div>
          <i class="bi bi-chevron-right list-item-arrow"></i>
        </a>
      <% } %>
    </div>
  </div>

  <div class="text-center mt-2 text-secondary small">
    Showing <%= repairs.length %> repair<%= repairs.length !== 1 ? 's' : '' %>
  </div>
<% } %>

<div class="text-center mt-3">
  <a href="/repairs" class="btn btn-sm btn-outline-secondary">
    <i class="bi bi-arrow-up-right-square me-1"></i>Manage Repairs
  </a>
</div>
