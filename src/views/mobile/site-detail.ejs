<div class="mb-3">
  <a href="/mobile/sites" class="btn btn-sm btn-outline-secondary">
    <i class="bi bi-arrow-left"></i> Sites
  </a>
</div>

<!-- Site info -->
<div class="card mobile-card">
  <div class="card-body">

    <!-- Badges row -->
    <div class="mb-2">
      <% if (site.SiteTypeName) { %>
        <span class="badge bg-primary bg-opacity-10 text-primary"><%= site.SiteTypeName %></span>
      <% } %>
      <% if (site.SiteStatusName) { %>
        <span class="badge bg-secondary bg-opacity-10 text-secondary ms-1"><%= site.SiteStatusName %></span>
      <% } %>
      <% if (site.MonitoringLocationTypeName) { %>
        <span class="badge bg-info bg-opacity-10 text-info ms-1"><%= site.MonitoringLocationTypeName %></span>
      <% } %>
    </div>

    <% if (site.ParentSiteName) { %>
      <div class="detail-row">
        <span class="detail-label">Parent Site</span>
        <span class="detail-value"><a href="/mobile/sites/<%= site.ParentSiteID %>"><%= site.ParentSiteName %></a></span>
      </div>
    <% } %>
    <% if (site.SiteNumber) { %>
      <div class="detail-row">
        <span class="detail-label">Site #</span>
        <span class="detail-value"><%= site.SiteNumber %></span>
      </div>
    <% } %>
    <% if (site.ContractNumber) { %>
      <div class="detail-row">
        <span class="detail-label">Contract #</span>
        <span class="detail-value"><%= site.ContractNumber %></span>
      </div>
    <% } %>
    <% if (site.Address || site.City || site.State) { %>
      <div class="detail-row">
        <span class="detail-label">Address</span>
        <span class="detail-value"><%= [site.Address, site.City, site.State, site.ZipCode].filter(Boolean).join(', ') %></span>
      </div>
    <% } %>
    <% if (site.Latitude && site.Longitude) { %>
      <div class="detail-row">
        <span class="detail-label">Coordinates</span>
        <span class="detail-value">
          <a href="https://maps.apple.com/?ll=<%= site.Latitude %>,<%= site.Longitude %>&q=<%= encodeURIComponent(site.SiteName) %>" target="_blank">
            <%= parseFloat(site.Latitude).toFixed(5) %>, <%= parseFloat(site.Longitude).toFixed(5) %>
            <i class="bi bi-box-arrow-up-right ms-1" style="font-size:0.7rem"></i>
          </a>
        </span>
      </div>
    <% } %>
    <% if (site.WarrantyExpires) { %>
      <div class="detail-row">
        <span class="detail-label">Warranty</span>
        <span class="detail-value"><%= new Date(site.WarrantyExpires).toLocaleDateString() %></span>
      </div>
    <% } %>
    <% if (site.Description) { %>
      <div class="detail-row align-items-start">
        <span class="detail-label" style="padding-top:1px">Notes</span>
        <span class="detail-value" style="white-space:pre-wrap"><%= site.Description %></span>
      </div>
    <% } %>
  </div>
</div>

<style>
  .detail-row {
    display: flex;
    gap: 10px;
    padding: 6px 0;
    border-bottom: 1px solid var(--bs-border-color);
    font-size: 0.85rem;
  }
  .detail-row:last-child { border-bottom: none; }
  .detail-label {
    flex-shrink: 0;
    width: 90px;
    color: var(--bs-secondary-color);
    font-size: 0.78rem;
  }
  .detail-value { flex: 1; word-break: break-word; }
</style>

<!-- Sub-sites -->
<% if (subsites && subsites.length > 0) { %>
  <h6 class="text-secondary small text-uppercase fw-semibold mb-2 mt-3">Sub-sites</h6>
  <div class="card mobile-card">
    <div class="card-body px-3 py-2">
      <% for (const sub of subsites) { %>
        <a href="/mobile/sites/<%= sub.SiteID %>" class="list-item-row">
          <div class="list-item-icon bg-primary bg-opacity-10 text-primary">
            <i class="bi bi-building"></i>
          </div>
          <div class="list-item-text">
            <div class="item-title"><%= sub.SiteName %></div>
            <div class="item-sub">
              <% if (sub.SiteTypeName) { %><%= sub.SiteTypeName %><% } %>
              <% if (sub.StatusName) { %> · <span class="badge bg-secondary bg-opacity-25 text-secondary" style="font-size:0.65rem"><%= sub.StatusName %></span><% } %>
            </div>
          </div>
          <i class="bi bi-chevron-right list-item-arrow"></i>
        </a>
      <% } %>
    </div>
  </div>
<% } %>

<!-- Network Resources -->
<div class="d-flex justify-content-between align-items-center mt-3 mb-2">
  <h6 class="text-secondary small text-uppercase fw-semibold mb-0">Network Resources</h6>
  <% const canEditNetwork = user && (user.roles.includes('Admin') || user.roles.includes('NetworkMapUpdater')); %>
  <% if (canEditNetwork) { %>
    <a href="/mobile/sites/<%= site.SiteID %>/network-resources/new" class="btn btn-sm btn-outline-primary py-0 px-2">
      <i class="bi bi-plus"></i> Add
    </a>
  <% } %>
</div>
<% if (networkResources && networkResources.length > 0) { %>
  <div class="card mobile-card">
    <div class="card-body px-3 py-2">
      <% for (const r of networkResources) { %>
        <div class="list-item-row" style="cursor:default">
          <div class="list-item-icon bg-warning bg-opacity-10 text-warning">
            <i class="bi bi-hdd-network"></i>
          </div>
          <div class="list-item-text">
            <div class="item-title"><%= r.Hostname %></div>
            <div class="item-sub">
              <% if (r.IPAddress) { %><code style="font-size:0.75rem"><%= r.IPAddress %></code><% } %>
              <% if (r.DeviceTypeName) { %> · <%= r.DeviceTypeName %><% } %>
              <% if (r.CircuitTypeName) { %> · <%= r.CircuitTypeName %><% } %>
              <% if (r.CircuitID) { %> · <span class="text-secondary">CID: <%= r.CircuitID %></span><% } %>
            </div>
            <% if (r.Notes) { %>
              <div class="item-sub text-secondary"><%= r.Notes %></div>
            <% } %>
          </div>
          <div class="d-flex flex-column align-items-end gap-1 ms-2 flex-shrink-0">
            <% if (r.AlertStatus) { %>
              <i class="bi bi-bell-fill text-danger" title="Affects alert status" style="font-size:0.75rem"></i>
            <% } %>
            <% if (canEditNetwork) { %>
              <a href="/mobile/sites/<%= site.SiteID %>/network-resources/<%= r.ResourceID %>/edit"
                 class="btn btn-outline-secondary py-0 px-1" style="font-size:0.7rem">
                <i class="bi bi-pencil"></i>
              </a>
            <% } %>
          </div>
        </div>
      <% } %>
    </div>
  </div>
<% } %>

<!-- Inventory at this site -->
<div class="d-flex justify-content-between align-items-center mt-3 mb-2">
  <h6 class="text-secondary small text-uppercase fw-semibold mb-0">Equipment at this site</h6>
  <% const canEditInventory = user && user.roles.includes('Admin'); %>
  <% if (canEditInventory) { %>
    <a href="/mobile/sites/<%= site.SiteID %>/inventory/install" class="btn btn-sm btn-outline-primary py-0 px-2">
      <i class="bi bi-plus"></i> Install
    </a>
  <% } %>
</div>

<% if (!inventory || inventory.length === 0) { %>
  <div class="card mobile-card">
    <div class="card-body text-secondary small text-center py-3">No equipment assigned.</div>
  </div>
<% } else { %>
  <div class="card mobile-card">
    <div class="card-body px-3 py-2">
      <% for (const item of inventory) { %>
        <div class="list-item-row" style="cursor:default">
          <div class="list-item-icon bg-success bg-opacity-10 text-success">
            <i class="bi bi-box-seam"></i>
          </div>
          <div class="list-item-text">
            <div class="item-title">
              <%= item.CommonName || item.ModelNumber || item.SerialNumber || 'Unknown' %>
              <% if (item.TrackingType === 'bulk' && item.Quantity > 1) { %>
                <span class="badge bg-secondary bg-opacity-25 text-secondary ms-1" style="font-size:0.65rem">×<%= item.Quantity %></span>
              <% } %>
            </div>
            <div class="item-sub">
              <% if (item.SerialNumber) { %>S/N: <%= item.SerialNumber %><% } %>
              <% if (item.Manufacturer) { %><%= item.SerialNumber ? ' · ' : '' %><%= item.Manufacturer %><% } %>
            </div>
          </div>
          <% if (canEditInventory) { %>
          <div class="d-flex gap-1 ms-2 flex-shrink-0">
            <a href="/mobile/sites/<%= site.SiteID %>/inventory/<%= item.SiteInventoryID %>/swap"
               class="btn btn-outline-warning py-0 px-1" style="font-size:0.7rem" title="Swap">
              <i class="bi bi-arrow-left-right"></i>
            </a>
          <form method="POST" action="/mobile/sites/<%= site.SiteID %>/inventory/<%= item.SiteInventoryID %>/remove"
                class="ms-2 flex-shrink-0"
                onsubmit="return confirm('Remove <%= (item.CommonName || item.SerialNumber || 'this item').replace(/'/g, '') %> from site?')">
            <button type="submit" class="btn btn-outline-danger py-0 px-1" style="font-size:0.7rem" title="Remove">
              <i class="bi bi-trash"></i>
            </button>
          </form>
          </div>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
<% } %>

<!-- PM Schedules -->
<div class="d-flex justify-content-between align-items-center mt-3 mb-2">
  <h6 class="text-secondary small text-uppercase fw-semibold mb-0">PM Schedules</h6>
</div>

<% if (!pmSchedules || pmSchedules.length === 0) { %>
  <div class="card mobile-card">
    <div class="card-body text-secondary small text-center py-3">No PM schedules for this site.</div>
  </div>
<% } else { %>
  <div class="card mobile-card">
    <div class="card-body px-3 py-0">
      <% for (const pm of pmSchedules) { %>
        <%
          const nextDue   = pm.NextDueDate ? new Date(pm.NextDueDate) : null;
          const isOverdue = pm.DaysUntilDue < 0;
          const isDueSoon = !isOverdue && pm.DaysUntilDue <= 7;
        %>
        <div class="py-2" style="border-bottom:1px solid var(--bs-border-color)">
          <div class="d-flex align-items-start justify-content-between gap-2">
            <div style="flex:1;min-width:0">
              <div class="fw-semibold" style="font-size:0.875rem"><%= pm.Title %></div>
              <div class="small text-secondary mt-1">
                Every <%= pm.FrequencyDays %> days
                <% if (pm.AssignedUserName) { %> · <i class="bi bi-person me-1"></i><%= pm.AssignedUserName %><% } %>
                <% if (pm.AssignedVendorName) { %> · <i class="bi bi-building me-1"></i><%= pm.AssignedVendorName %><% } %>
              </div>
              <div class="small mt-1">
                <% if (pm.LastPerformedAt) { %>
                  <span class="text-secondary">Last: <%= new Date(pm.LastPerformedAt).toLocaleDateString() %></span> ·
                <% } %>
                <% if (nextDue) { %>
                  <span class="<%= isOverdue ? 'text-danger fw-semibold' : isDueSoon ? 'text-warning' : 'text-secondary' %>">
                    <% if (isOverdue) { %><i class="bi bi-exclamation-circle me-1"></i>Overdue <%= Math.abs(pm.DaysUntilDue) %>d
                    <% } else if (isDueSoon) { %>Due in <%= pm.DaysUntilDue %>d
                    <% } else { %>Next: <%= nextDue.toLocaleDateString() %>
                    <% } %>
                  </span>
                <% } %>
              </div>
            </div>
            <!-- Quick complete -->
            <button type="button"
                    class="btn btn-outline-success py-0 px-2 flex-shrink-0"
                    style="font-size:0.7rem"
                    title="Mark Complete"
                    data-pm-id="<%= pm.ScheduleID %>"
                    data-pm-name="<%= pm.Title.replace(/'/g,'') %>"
                    onclick="openCompleteModal(this)">
              <i class="bi bi-check-lg"></i>
            </button>
          </div>
        </div>
      <% } %>
    </div>
  </div>
<% } %>

<!-- Complete PM modal -->
<div class="modal fade" id="completePMModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h6 class="modal-title fw-semibold" id="completePMTitle">Mark Complete</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="completePMForm" method="POST">
        <div class="modal-body py-2">
          <div class="mb-2">
            <label class="form-label small fw-semibold">Date Performed</label>
            <input type="date" name="performedDate" class="form-control form-control-sm"
                   value="<%= new Date().toISOString().split('T')[0] %>" />
          </div>
        </div>
        <div class="modal-footer py-2">
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-success btn-sm"><i class="bi bi-check-lg me-1"></i>Mark Complete</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function openCompleteModal(btn) {
  var id   = btn.dataset.pmId;
  var name = btn.dataset.pmName;
  document.getElementById('completePMTitle').textContent = 'Complete: ' + name;
  document.getElementById('completePMForm').action = '/mobile/sites/<%= site.SiteID %>/pm/' + id + '/complete';
  var modal = new bootstrap.Modal(document.getElementById('completePMModal'));
  modal.show();
}
</script>

<div class="text-center mt-3">
  <a href="/sites/<%= site.SiteID %>" class="btn btn-sm btn-outline-secondary">
    <i class="bi bi-arrow-up-right-square me-1"></i>Full Site Details
  </a>
</div>
