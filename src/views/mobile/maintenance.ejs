<!-- Filter tabs -->
<div class="d-flex gap-2 mb-3">
  <a href="/mobile/maintenance?filter=overdue" class="btn btn-sm <%= filter === 'overdue' ? 'btn-danger' : 'btn-outline-secondary' %>">Overdue</a>
  <a href="/mobile/maintenance?filter=open" class="btn btn-sm <%= filter === 'open' ? 'btn-primary' : 'btn-outline-secondary' %>">Open</a>
  <a href="/mobile/maintenance?filter=all" class="btn btn-sm <%= filter === 'all' ? 'btn-primary' : 'btn-outline-secondary' %>">All</a>
</div>

<% if (items.length === 0) { %>
  <div class="text-center text-secondary py-5">
    <i class="bi bi-clipboard-check" style="font-size:2rem"></i>
    <p class="mt-2 small">No maintenance items found.</p>
  </div>
<% } else { %>
  <div class="card mobile-card">
    <div class="card-body px-3 py-2">
      <% const today = new Date(); %>
      <% for (const item of items) { %>
        <%
          const dueDate = item.DueDate ? new Date(item.DueDate) : null;
          const isOverdue = dueDate && !item.ClosedAt && dueDate < today;
          const isClosed = !!item.ClosedAt;
        %>
        <div class="list-item-row" style="cursor:default">
          <div class="list-item-icon <%= isOverdue ? 'bg-danger bg-opacity-10 text-danger' : isClosed ? 'bg-success bg-opacity-10 text-success' : 'bg-info bg-opacity-10 text-info' %>">
            <i class="bi bi-<%= isClosed ? 'check-circle' : 'clipboard-check' %>"></i>
          </div>
          <div class="list-item-text">
            <div class="item-title"><%= item.WorkToComplete || item.MaintenanceTypeName || 'Maintenance Task' %></div>
            <div class="item-sub">
              <%= item.SiteName || '' %>
              <% if (item.AssignedToUserName) { %> · <%= item.AssignedToUserName %><% } %>
            </div>
            <% if (dueDate) { %>
              <div class="item-sub <%= isOverdue ? 'text-danger fw-semibold' : '' %>">
                <% if (isOverdue) { %><i class="bi bi-exclamation-circle me-1"></i>Overdue: <% } else { %>Due: <% } %>
                <%= dueDate.toLocaleDateString() %>
              </div>
            <% } %>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <div class="text-center mt-2 text-secondary small">
    Showing <%= items.length %> item<%= items.length !== 1 ? 's' : '' %>
  </div>
<% } %>

<div class="text-center mt-3">
  <a href="/maintenance" class="btn btn-sm btn-outline-secondary">
    <i class="bi bi-arrow-up-right-square me-1"></i>Manage Maintenance
  </a>
</div>
