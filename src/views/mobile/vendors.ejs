<!-- Search -->
<div class="search-bar">
  <form method="GET" action="/mobile/vendors">
    <input type="search" name="q" class="form-control form-control-sm"
           placeholder="Search vendors..." value="<%= q %>" autocomplete="off" />
  </form>
</div>

<% if (vendors.length === 0) { %>
  <div class="text-center text-secondary py-5">
    <i class="bi bi-building-check" style="font-size:2rem"></i>
    <p class="mt-2 small"><% if (q.trim()) { %>No vendors match "<%= q %>".<% } else { %>No vendors found.<% } %></p>
  </div>
<% } else { %>
  <div class="card mobile-card">
    <div class="card-body px-3 py-2">
      <% for (const v of vendors) { %>
        <a href="/mobile/vendors/<%= v.VendorID %>" class="list-item-row">
          <div class="list-item-icon bg-primary bg-opacity-10 text-primary">
            <i class="bi bi-building-check"></i>
          </div>
          <div class="list-item-text">
            <div class="item-title">
              <%= v.VendorName %>
              <% if (!v.IsActive) { %><span class="badge bg-secondary ms-1" style="font-size:0.62rem">Inactive</span><% } %>
              <% if (v.DoesPMWork) { %><span class="badge bg-success ms-1" style="font-size:0.62rem">PM</span><% } %>
            </div>
            <div class="item-sub">
              <% if (v.Phone) { %><i class="bi bi-telephone me-1"></i><%= v.Phone %><% } %>
              <% if (v.City || v.State) { %><%= v.Phone ? ' · ' : '' %><%= [v.City, v.State].filter(Boolean).join(', ') %><% } %>
            </div>
          </div>
          <i class="bi bi-chevron-right list-item-arrow"></i>
        </a>
      <% } %>
    </div>
  </div>

  <div class="text-center mt-2 text-secondary small">
    <%= vendors.length %> vendor<%= vendors.length !== 1 ? 's' : '' %>
  </div>
<% } %>
