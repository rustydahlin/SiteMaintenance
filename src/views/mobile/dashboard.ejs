<!-- My Assignments (always shown first, prominent) -->
<% const hasMyWork = myRepairs.length > 0 || myMaintenance.length > 0; %>
<% if (hasMyWork) { %>
  <h6 class="text-secondary small text-uppercase fw-semibold mb-2">My Assignments</h6>

  <% if (myMaintenance.length > 0) { %>
    <div class="card mobile-card mb-3" style="border-color:<%= myOverdue.length > 0 ? 'var(--bs-danger-border-subtle)' : 'var(--bs-info-border-subtle)' %>">
      <div class="card-header py-2 px-3 d-flex justify-content-between align-items-center"
           style="background:<%= myOverdue.length > 0 ? 'var(--bs-danger-bg-subtle)' : 'var(--bs-info-bg-subtle)' %>;font-size:0.78rem;font-weight:600">
        <span>
          <i class="bi bi-clipboard-check me-1 <%= myOverdue.length > 0 ? 'text-danger' : 'text-info' %>"></i>My Maintenance
          <% if (myOverdue.length > 0) { %><span class="ms-1 text-danger">(<%= myOverdue.length %> overdue)</span><% } %>
        </span>
        <span class="badge <%= myOverdue.length > 0 ? 'bg-danger' : 'bg-info text-dark' %>"><%= myMaintenance.length %></span>
      </div>
      <div class="card-body px-3 py-2">
        <% for (const m of myMaintenance) { %>
          <a href="/mobile/maintenance/<%= m.MaintenanceID %>" class="list-item-row">
            <div class="list-item-text">
              <div class="item-title"><%= m.SiteName %></div>
              <div class="item-sub">
                <% if (m.MaintenanceTypeName) { %><%= m.MaintenanceTypeName %><% } %>
                <% if (m.DueDate) { %>
                  <% const isOverdue = new Date(m.DueDate) < new Date(); %>
                  <span class="<%= isOverdue ? 'text-danger' : 'text-secondary' %> ms-1">
                    <% if (isOverdue) { %><i class="bi bi-exclamation-circle me-1"></i>Overdue<% } else { %>Due: <%= new Date(m.DueDate).toLocaleDateString() %><% } %>
                  </span>
                <% } %>
              </div>
            </div>
            <i class="bi bi-chevron-right list-item-arrow"></i>
          </a>
        <% } %>
      </div>
    </div>
  <% } %>

  <% const myPMsOverdue = myPMs.filter(p => p.DaysUntilDue < 0); %>
  <div class="card mobile-card mb-3" style="border-color:<%= myPMsOverdue.length > 0 ? 'var(--bs-danger-border-subtle)' : 'var(--bs-success-border-subtle)' %>">
    <div class="card-header py-2 px-3 d-flex justify-content-between align-items-center"
         style="background:<%= myPMsOverdue.length > 0 ? 'var(--bs-danger-bg-subtle)' : 'var(--bs-success-bg-subtle)' %>;font-size:0.78rem;font-weight:600">
      <span>
        <i class="bi bi-clipboard2-pulse me-1 <%= myPMsOverdue.length > 0 ? 'text-danger' : 'text-success' %>"></i>My PM Schedules
        <% if (myPMsOverdue.length > 0) { %><span class="ms-1 text-danger">(<%= myPMsOverdue.length %> overdue)</span><% } %>
      </span>
      <% if (myPMs.length > 0) { %><span class="badge <%= myPMsOverdue.length > 0 ? 'bg-danger' : 'bg-success' %>"><%= myPMs.length %></span><% } %>
    </div>
    <div class="card-body px-3 py-2">
      <% if (myPMs.length === 0) { %>
        <div class="text-secondary small text-center py-2">No PMs scheduled in the next 60 days.</div>
      <% } else { %>
        <% for (const pm of myPMs) { %>
          <% const pmOverdue = pm.DaysUntilDue < 0; const pmSoon = !pmOverdue && pm.DaysUntilDue <= 7; %>
          <a href="/mobile/sites/<%= pm.SiteID %>" class="list-item-row">
            <div class="list-item-text">
              <div class="item-title"><%= pm.Title %></div>
              <div class="item-sub"><i class="bi bi-building me-1"></i><%= pm.SiteName %></div>
              <div class="item-sub <%= pmOverdue ? 'text-danger fw-semibold' : pmSoon ? 'text-warning' : '' %>">
                <% if (pmOverdue) { %><i class="bi bi-exclamation-circle me-1"></i><%= Math.abs(pm.DaysUntilDue) %>d overdue
                <% } else if (pmSoon) { %>Due in <%= pm.DaysUntilDue %>d
                <% } else { %>Next: <%= new Date(pm.NextDueDate).toLocaleDateString() %>
                <% } %>
              </div>
            </div>
            <i class="bi bi-chevron-right list-item-arrow"></i>
          </a>
        <% } %>
      <% } %>
    </div>
  </div>

  <% if (myRepairs.length > 0) { %>
    <div class="card mobile-card mb-3" style="border-color:var(--bs-warning-border-subtle)">
      <div class="card-header py-2 px-3 d-flex justify-content-between align-items-center"
           style="background:var(--bs-warning-bg-subtle);font-size:0.78rem;font-weight:600">
        <span><i class="bi bi-wrench me-1 text-warning"></i>My Open Repairs</span>
        <span class="badge bg-warning text-dark"><%= myRepairs.length %></span>
      </div>
      <div class="card-body px-3 py-2">
        <% for (const r of myRepairs) { %>
          <a href="/mobile/repairs/<%= r.RepairID %>" class="list-item-row">
            <div class="list-item-text">
              <div class="item-title"><%= r.CommonName || r.ModelNumber || r.SerialNumber || 'Unknown' %></div>
              <div class="item-sub">
                <%
                  let dBadgeClass, dBadgeLabel;
                  if (!r.SentDate)   { dBadgeClass = 'bg-secondary';         dBadgeLabel = 'Not Sent'; }
                  else if (r.ExpectedReturnDate && new Date(r.ExpectedReturnDate) < new Date()) {
                                       dBadgeClass = 'bg-danger';            dBadgeLabel = 'Overdue'; }
                  else               { dBadgeClass = 'bg-warning text-dark'; dBadgeLabel = 'Open'; }
                %>
                <span class="badge <%= dBadgeClass %>" style="font-size:0.62rem"><%= dBadgeLabel %></span>
                <% if (r.RMANumber) { %><span class="text-secondary ms-1">RMA: <%= r.RMANumber %></span><% } %>
              </div>
            </div>
            <i class="bi bi-chevron-right list-item-arrow"></i>
          </a>
        <% } %>
      </div>
    </div>
  <% } %>

  <hr class="my-3">
<% } %>

<!-- Global stat cards -->
<div class="row g-3 mb-4">
  <div class="col-4">
    <a href="/mobile/maintenance" class="card stat-card text-decoration-none">
      <div class="card-body py-3 px-2">
        <div class="stat-number <%= overdueCount > 0 ? 'text-danger' : 'text-success' %>"><%= overdueCount %></div>
        <div class="stat-label">PM Overdue</div>
      </div>
    </a>
  </div>
  <div class="col-4">
    <a href="/mobile/repairs" class="card stat-card text-decoration-none">
      <div class="card-body py-3 px-2">
        <div class="stat-number text-warning"><%= openRepairs %></div>
        <div class="stat-label">Open Repairs</div>
      </div>
    </a>
  </div>
  <div class="col-4">
    <a href="/mobile/sites" class="card stat-card text-decoration-none">
      <div class="card-body py-3 px-2">
        <div class="stat-number text-primary"><%= siteCount %></div>
        <div class="stat-label">Sites</div>
      </div>
    </a>
  </div>
</div>

<!-- Quick links -->
<div class="card mobile-card">
  <div class="card-body px-3 py-2">
    <a href="/mobile/maintenance" class="list-item-row">
      <div class="list-item-icon bg-info bg-opacity-10 text-info">
        <i class="bi bi-clipboard-check"></i>
      </div>
      <div class="list-item-text">
        <div class="item-title">Maintenance</div>
        <div class="item-sub"><%= dueCount %> due, <%= overdueCount %> overdue</div>
      </div>
      <i class="bi bi-chevron-right list-item-arrow"></i>
    </a>
    <a href="/mobile/repairs" class="list-item-row">
      <div class="list-item-icon bg-warning bg-opacity-10 text-warning">
        <i class="bi bi-wrench"></i>
      </div>
      <div class="list-item-text">
        <div class="item-title">Repairs & RMAs</div>
        <div class="item-sub"><%= openRepairs %> open</div>
      </div>
      <i class="bi bi-chevron-right list-item-arrow"></i>
    </a>
    <a href="/mobile/sites" class="list-item-row">
      <div class="list-item-icon bg-primary bg-opacity-10 text-primary">
        <i class="bi bi-building"></i>
      </div>
      <div class="list-item-text">
        <div class="item-title">Sites</div>
        <div class="item-sub"><%= siteCount %> active</div>
      </div>
      <i class="bi bi-chevron-right list-item-arrow"></i>
    </a>
    <a href="/mobile/inventory" class="list-item-row">
      <div class="list-item-icon bg-success bg-opacity-10 text-success">
        <i class="bi bi-box-seam"></i>
      </div>
      <div class="list-item-text">
        <div class="item-title">Inventory</div>
        <div class="item-sub">Search equipment</div>
      </div>
      <i class="bi bi-chevron-right list-item-arrow"></i>
    </a>
  </div>
</div>


<div class="text-center mt-3">
  <a href="/" class="btn btn-sm btn-outline-secondary">
    <i class="bi bi-grid me-1"></i>Full Desktop Site
  </a>
</div>
