<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title" content="<%= typeof appName !== 'undefined' ? appName : 'SiteMaintenance' %>" />
  <meta name="theme-color" content="#0d6efd" />
  <title><%= typeof title !== 'undefined' ? title + ' — ' + (typeof appName !== 'undefined' ? appName : 'SiteMaintenance') : (typeof appName !== 'undefined' ? appName : 'SiteMaintenance') %></title>

  <link rel="manifest" href="/manifest.json" />
  <link rel="apple-touch-icon" href="/images/publicsafetyteam.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Bootstrap 5 -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

  <style>
    body {
      padding-bottom: 72px; /* space for bottom nav */
      padding-top: env(safe-area-inset-top);
      padding-left: env(safe-area-inset-left);
      padding-right: env(safe-area-inset-right);
    }

    .mobile-header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--bs-body-bg);
      border-bottom: 1px solid var(--bs-border-color);
      padding: 12px 16px;
      padding-top: calc(12px + env(safe-area-inset-top));
    }

    .mobile-header h1 {
      font-size: 1.1rem;
      font-weight: 600;
      margin: 0;
    }

    .bottom-nav {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 200;
      background: var(--bs-body-bg);
      border-top: 1px solid var(--bs-border-color);
      display: flex;
      padding-bottom: env(safe-area-inset-bottom);
    }

    .bottom-nav a {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 8px 4px;
      text-decoration: none;
      color: var(--bs-secondary-color);
      font-size: 0.65rem;
      gap: 2px;
      min-height: 56px;
    }

    .bottom-nav a.active,
    .bottom-nav a:hover {
      color: #0d6efd;
    }

    .bottom-nav i {
      font-size: 1.3rem;
    }

    .mobile-content {
      padding: 16px;
    }

    .mobile-card {
      border-radius: 12px;
      margin-bottom: 12px;
    }

    .mobile-card .card-body {
      padding: 14px 16px;
    }

    .stat-card {
      text-align: center;
      border-radius: 12px;
    }

    .stat-card .stat-number {
      font-size: 2rem;
      font-weight: 700;
      line-height: 1;
    }

    .stat-card .stat-label {
      font-size: 0.75rem;
      color: var(--bs-secondary-color);
      margin-top: 4px;
    }

    .list-item-row {
      display: flex;
      align-items: center;
      padding: 12px 0;
      border-bottom: 1px solid var(--bs-border-color);
      text-decoration: none;
      color: inherit;
    }

    .list-item-row:last-child { border-bottom: none; }

    .list-item-row:active { background: var(--bs-tertiary-bg); }

    .list-item-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 1.1rem;
      margin-right: 12px;
    }

    .list-item-text { flex: 1; min-width: 0; }

    .list-item-text .item-title {
      font-weight: 500;
      font-size: 0.9rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .list-item-text .item-sub {
      font-size: 0.75rem;
      color: var(--bs-secondary-color);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .list-item-arrow {
      color: var(--bs-secondary-color);
      font-size: 0.85rem;
      flex-shrink: 0;
      margin-left: 8px;
    }

    .search-bar {
      position: sticky;
      top: 56px;
      z-index: 99;
      background: var(--bs-body-bg);
      padding: 8px 16px;
      border-bottom: 1px solid var(--bs-border-color);
    }

    .search-bar input {
      border-radius: 10px;
      background: var(--bs-tertiary-bg);
      border-color: transparent;
    }

    .search-bar input:focus {
      background: var(--bs-tertiary-bg);
      border-color: #0d6efd;
    }

    #notifBtn {
      font-size: 0.8rem;
    }
  </style>

  <script>
    // Apply saved theme before render
    if (localStorage.getItem('theme') === 'dark') {
      document.documentElement.setAttribute('data-bs-theme', 'dark');
    }
  </script>
</head>
<body>

<!-- Header -->
<div class="mobile-header d-flex justify-content-between align-items-center">
  <h1 class="bi bi-tools"> <%= typeof title !== 'undefined' ? title : (typeof appName !== 'undefined' ? appName : 'SiteMaintenance') %></h1>
  <div class="d-flex gap-2 align-items-center">
    <button id="notifBtn" class="btn btn-sm btn-outline-secondary" title="Enable Notifications" style="display:none">
      <i class="bi bi-bell" id="notifIcon"></i>
    </button>
    <button id="darkToggle" class="btn btn-sm btn-outline-secondary" title="Toggle dark mode">
      <i class="bi bi-moon" id="darkIcon"></i>
    </button>
  </div>
</div>

<!-- Flash messages -->
<% if (typeof flash !== 'undefined' && flash.error && flash.error.length) { %>
  <div class="mx-3 mt-2 alert alert-danger alert-dismissible small py-2 mb-0" role="alert">
    <%= flash.error[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>
<% if (typeof flash !== 'undefined' && flash.success && flash.success.length) { %>
  <div class="mx-3 mt-2 alert alert-success alert-dismissible small py-2 mb-0" role="alert">
    <%= flash.success[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<!-- Page content -->
<div class="mobile-content">
  <%- body %>
</div>

<!-- Bottom Navigation -->
<nav class="bottom-nav">
  <a href="/mobile" class="<%= typeof currentPath !== 'undefined' && currentPath === '/' ? 'active' : '' %>">
    <i class="bi bi-house"></i>
    <span>Home</span>
  </a>
  <a href="/mobile/sites" class="<%= typeof currentPath !== 'undefined' && currentPath.startsWith('/sites') ? 'active' : '' %>">
    <i class="bi bi-building"></i>
    <span>Sites</span>
  </a>
  <a href="/mobile/repairs" class="<%= typeof currentPath !== 'undefined' && currentPath.startsWith('/repairs') ? 'active' : '' %>">
    <i class="bi bi-wrench"></i>
    <span>Repairs</span>
  </a>
  <a href="/mobile/maintenance" class="<%= typeof currentPath !== 'undefined' && currentPath.startsWith('/maintenance') ? 'active' : '' %>">
    <i class="bi bi-clipboard-check"></i>
    <span>Maint.</span>
  </a>
  <a href="/mobile/inventory" class="<%= typeof currentPath !== 'undefined' && currentPath.startsWith('/inventory') ? 'active' : '' %>">
    <i class="bi bi-box-seam"></i>
    <span>Inventory</span>
  </a>
</nav>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
(function () {
  // Register service worker
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js', { scope: '/' }).catch(function(e) {
      console.warn('SW registration failed:', e);
    });
  }

  // Dark mode toggle
  var darkToggle = document.getElementById('darkToggle');
  var darkIcon   = document.getElementById('darkIcon');
  function applyDark(dark) {
    document.documentElement.setAttribute('data-bs-theme', dark ? 'dark' : 'light');
    localStorage.setItem('theme', dark ? 'dark' : 'light');
    if (darkIcon) {
      darkIcon.className = dark ? 'bi bi-sun' : 'bi bi-moon';
    }
  }
  // Set correct icon on load
  if (darkIcon && localStorage.getItem('theme') === 'dark') darkIcon.className = 'bi bi-sun';
  if (darkToggle) {
    darkToggle.addEventListener('click', function () {
      applyDark(localStorage.getItem('theme') !== 'dark');
    });
  }

  // Show notification bell if push is supported and not yet granted
  var notifBtn = document.getElementById('notifBtn');
  if (notifBtn && 'Notification' in window && 'PushManager' in window) {
    if (Notification.permission !== 'granted') {
      notifBtn.style.display = '';
    }
    notifBtn.addEventListener('click', function () {
      enablePushNotifications();
    });
  }

  function urlBase64ToUint8Array(base64String) {
    var padding = '='.repeat((4 - base64String.length % 4) % 4);
    var base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
    var rawData = atob(base64);
    var outputArray = new Uint8Array(rawData.length);
    for (var i = 0; i < rawData.length; ++i) outputArray[i] = rawData.charCodeAt(i);
    return outputArray;
  }

  function enablePushNotifications() {
    Notification.requestPermission().then(function (permission) {
      if (permission !== 'granted') return;
      if (!('serviceWorker' in navigator)) return;

      navigator.serviceWorker.ready.then(function (reg) {
        fetch('/api/push/vapid-public-key')
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (!data.publicKey) return;
            return reg.pushManager.subscribe({
              userVisibleOnly: true,
              applicationServerKey: urlBase64ToUint8Array(data.publicKey),
            });
          })
          .then(function (subscription) {
            if (!subscription) return;
            return fetch('/api/push/subscribe', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(subscription.toJSON()),
            });
          })
          .then(function () {
            if (notifBtn) notifBtn.style.display = 'none';
          })
          .catch(function (e) { console.warn('Push subscribe failed:', e); });
      });
    });
  }
})();
</script>

</body>
</html>
