<h1 class="h3 mb-4"><i class="bi bi-person-circle me-2"></i>My Profile</h1>

<div class="row g-4">
  <div class="col-md-6">
    <div class="card shadow-sm">
      <div class="card-header">Account Information</div>
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-4">Display Name</dt>
          <dd class="col-sm-8"><%= profile.DisplayName %></dd>
          <dt class="col-sm-4">Username</dt>
          <dd class="col-sm-8"><%= profile.Username %></dd>
          <dt class="col-sm-4">Email</dt>
          <dd class="col-sm-8"><%= profile.Email || '<span class="text-muted">Not set</span>' %></dd>
          <dt class="col-sm-4">Auth Method</dt>
          <dd class="col-sm-8">
            <span class="badge <%=
              profile.AuthProvider === 'oidc' ? 'bg-info text-dark' :
              profile.AuthProvider === 'ldap' ? 'bg-warning text-dark' :
              'bg-secondary' %>"><%= profile.AuthProvider %></span>
          </dd>
          <dt class="col-sm-4">Roles</dt>
          <dd class="col-sm-8">
            <% (profile.roles || []).forEach(r => { %>
              <span class="badge <%= r === 'Admin' ? 'bg-danger' : 'bg-primary' %> me-1"><%= r %></span>
            <% }) %>
          </dd>
          <dt class="col-sm-4">Last Login</dt>
          <dd class="col-sm-8 text-muted small"><%= profile.LastLoginAt ? new Date(profile.LastLoginAt).toLocaleString() : 'N/A' %></dd>
        </dl>
      </div>
    </div>
  </div>

  <!-- Notification Preferences -->
  <% if (canNotify) { %>
  <div class="col-12">
    <div class="card shadow-sm">
      <div class="card-header fw-semibold"><i class="bi bi-bell me-2"></i>Email Notification Preferences</div>
      <div class="card-body">
        <p class="text-muted small mb-3">
          Select which email notifications you want to receive.
          You must have an email address set on your account for these to be delivered.
          <strong>Note:</strong> if you are directly assigned to a PM schedule or system key, you will always receive
          that reminder regardless of these settings — these checkboxes control whether you receive
          notifications for items <em>not</em> assigned to you.
        </p>
        <form action="/profile/notifications" method="POST">
          <%
            const prefs = notifPrefs || {};
            const notifTypes = [
              { key: 'pm.reminder',       label: 'PM Reminders',              desc: 'PMs that are due or overdue across all sites (assigned PMs notify you regardless)' },
              { key: 'repair.followup',   label: 'Repair Follow-Up Due',      desc: 'Any repair where the follow-up date has passed' },
              { key: 'repair.overdue',    label: 'Repair Overdue',            desc: 'Any repair not returned by its expected date' },
              { key: 'warranty.expiring', label: 'Warranty Expiring',         desc: 'Sites or inventory items with warranties expiring soon' },
              { key: 'site.statusChange', label: 'Site Status Changes',       desc: 'When any site\'s status is updated' },
              { key: 'log.new',           label: 'New Log Entries',           desc: 'When a new log entry is created on any site' },
{ key: 'systemKey.expiring',label: 'System Key Expiring',       desc: 'System keys expiring soon (key holders are always notified regardless)' },
            ];
          %>
          <div class="row g-2">
            <% for (const n of notifTypes) { %>
            <div class="col-md-6">
              <div class="form-check d-flex align-items-start gap-2">
                <input class="form-check-input mt-1" type="checkbox" name="<%= n.key %>" value="1"
                       id="notif_<%= n.key.replace('.','_') %>"
                       <%= prefs[n.key] ? 'checked' : '' %>>
                <label class="form-check-label" for="notif_<%= n.key.replace('.','_') %>">
                  <span class="fw-semibold"><%= n.label %></span>
                  <br><span class="text-muted small"><%= n.desc %></span>
                </label>
              </div>
            </div>
            <% } %>
          </div>
          <div class="mt-3">
            <button type="submit" class="btn btn-primary btn-sm">
              <i class="bi bi-check-lg me-1"></i>Save Preferences
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
  <% } %>

  <% if (profile.AuthProvider === 'local') { %>
  <div class="col-md-6">
    <div class="card shadow-sm">
      <div class="card-header">Change Password</div>
      <div class="card-body">
        <form action="/profile/password" method="POST">
          <div class="mb-3">
            <label class="form-label">Current Password <span class="text-danger">*</span></label>
            <input type="password" name="currentPassword" class="form-control" autocomplete="current-password" required />
          </div>
          <div class="mb-3">
            <label class="form-label">New Password <span class="text-danger">*</span></label>
            <input type="password" name="newPassword" class="form-control" autocomplete="new-password" required minlength="8" />
            <div class="form-text">Minimum 8 characters.</div>
          </div>
          <div class="mb-3">
            <label class="form-label">Confirm New Password <span class="text-danger">*</span></label>
            <input type="password" name="confirmPassword" class="form-control" autocomplete="new-password" required minlength="8" />
          </div>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-lock me-2"></i>Change Password
          </button>
        </form>
      </div>
    </div>
  </div>
  <% } %>
</div>
