<div class="text-center py-5">
  <i class="bi bi-exclamation-octagon display-1 text-danger"></i>
  <h1 class="mt-3">500 — Server Error</h1>
  <p class="text-muted"><%= message || 'An unexpected error occurred. Please try again later.' %></p>
  <% if (stack) { %>
    <pre class="text-start bg-body-secondary border rounded p-3 mt-3 small"><%= stack %></pre>
  <% } %>
  <a href="/" class="btn btn-primary mt-2"><i class="bi bi-house me-2"></i>Go to Dashboard</a>
</div>
