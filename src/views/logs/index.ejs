<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0"><i class="bi bi-journal-text me-2"></i>Logs</h1>
  <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#newLogModal">
    <i class="bi bi-plus-lg me-1"></i>New Log Entry
  </button>
</div>

<!-- Filters -->
<form method="GET" action="/logs" class="row g-2 mb-3 align-items-end">
  <input type="hidden" name="sort" value="<%= sort %>">
  <input type="hidden" name="dir"  value="<%= dir %>">
  <div class="col-md-3">
    <label class="form-label form-label-sm">Site</label>
    <select name="siteID" class="form-select form-select-sm">
      <option value="">All Sites</option>
      <% sites.forEach(s => { %>
        <option value="<%= s.SiteID %>" <%= filters.siteID === s.SiteID ? 'selected' : '' %>><%= s.SiteName %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-2">
    <label class="form-label form-label-sm">Type</label>
    <select name="logTypeID" class="form-select form-select-sm">
      <option value="">All Types</option>
      <% logTypes.forEach(t => { %>
        <option value="<%= t.LogTypeID %>" <%= filters.logTypeID === t.LogTypeID ? 'selected' : '' %>><%= t.TypeName %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-2">
    <label class="form-label form-label-sm">From</label>
    <input type="date" name="dateFrom" class="form-control form-control-sm" value="<%= filters.dateFrom || '' %>">
  </div>
  <div class="col-md-2">
    <label class="form-label form-label-sm">To</label>
    <input type="date" name="dateTo" class="form-control form-control-sm" value="<%= filters.dateTo || '' %>">
  </div>
  <div class="col-md-2">
    <label class="form-label form-label-sm">Search</label>
    <input type="text" name="search" class="form-control form-control-sm" placeholder="Site, subject, performed by…" value="<%= filters.search || '' %>">
  </div>
  <div class="col-auto d-flex gap-2">
    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-funnel me-1"></i>Filter</button>
    <a href="/logs" class="btn btn-outline-secondary btn-sm">Clear</a>
  </div>
</form>

<%
function sortLink(col) {
  const newDir = (sort === col && dir === 'asc') ? 'desc' : 'asc';
  const base = pagination.queryString.replace(/\bsort=\w+/, '').replace(/\bdir=\w+/, '').replace(/&&+/, '&').replace(/^&|&$/, '');
  return '/logs?' + (base ? base + '&' : '') + 'sort=' + col + '&dir=' + newDir;
}
function sortIcon(col) {
  if (sort !== col) return '<i class="bi bi-arrow-down-up text-muted ms-1" style="font-size:0.75rem"></i>';
  return sort === col && dir === 'asc'
    ? '<i class="bi bi-sort-up ms-1" style="font-size:0.75rem"></i>'
    : '<i class="bi bi-sort-down ms-1" style="font-size:0.75rem"></i>';
}
%>

<div class="card shadow-sm">
  <div class="card-header d-flex justify-content-between align-items-center py-2">
    <span class="small text-muted"><%= pagination.total.toLocaleString() %> log entr<%= pagination.total === 1 ? 'y' : 'ies' %></span>
  </div>
  <div class="table-responsive">
    <table class="table table-sm table-hover mb-0">
      <thead class="table-dark">
        <tr>
          <th><a href="<%= sortLink('date') %>" class="text-white text-decoration-none">Date <%- sortIcon('date') %></a></th>
          <th><a href="<%= sortLink('site') %>" class="text-white text-decoration-none">Site <%- sortIcon('site') %></a></th>
          <th><a href="<%= sortLink('type') %>" class="text-white text-decoration-none">Type <%- sortIcon('type') %></a></th>
          <th><a href="<%= sortLink('subject') %>" class="text-white text-decoration-none">Subject <%- sortIcon('subject') %></a></th>
          <th><a href="<%= sortLink('performedBy') %>" class="text-white text-decoration-none">Performed By <%- sortIcon('performedBy') %></a></th>
        </tr>
      </thead>
      <tbody>
        <% if (!rows.length) { %>
        <tr><td colspan="5" class="text-center text-muted py-4">No log entries found.</td></tr>
        <% } %>
        <% rows.forEach(row => {
          const entryDate = row.EntryDate ? new Date(row.EntryDate).toLocaleDateString('en-US', { timeZone: 'UTC' }) : '—';
          const performer = row.PerformedByUserName || row.PerformedBy || '—';
        %>
        <tr>
          <td class="text-nowrap small"><%= entryDate %></td>
          <td class="small">
            <% if (row.SiteID) { %>
              <a href="/sites/<%= row.SiteID %>"><%= row.SiteName || row.SiteID %></a>
            <% } else { %>—<% } %>
          </td>
          <td class="small">
            <% if (row.LogTypeName) { %>
              <span class="badge bg-secondary"><%= row.LogTypeName %></span>
            <% } else { %>—<% } %>
            <% if (row.IsAutoGenerated) { %>
              <span class="badge bg-info text-dark ms-1" title="Auto-generated">Auto</span>
            <% } %>
          </td>
          <td class="small">
            <a href="/sites/<%= row.SiteID %>/logs/<%= row.LogEntryID %>">
              <%= row.Subject || '(no subject)' %>
            </a>
          </td>
          <td class="small text-muted"><%= performer %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Pagination -->
<% if (pagination.totalPages > 1) { %>
<nav class="mt-3">
  <ul class="pagination pagination-sm justify-content-center mb-0">
    <li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">
      <a class="page-link" href="/logs?<%= pagination.queryString %>&page=<%= pagination.page - 1 %>">‹</a>
    </li>
    <% for (let p = Math.max(1, pagination.page - 2); p <= Math.min(pagination.totalPages, pagination.page + 2); p++) { %>
    <li class="page-item <%= p === pagination.page ? 'active' : '' %>">
      <a class="page-link" href="/logs?<%= pagination.queryString %>&page=<%= p %>"><%= p %></a>
    </li>
    <% } %>
    <li class="page-item <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>">
      <a class="page-link" href="/logs?<%= pagination.queryString %>&page=<%= pagination.page + 1 %>">›</a>
    </li>
  </ul>
</nav>
<% } %>

<!-- New Log Entry Modal -->
<div class="modal fade" id="newLogModal" tabindex="-1" aria-labelledby="newLogModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <form method="POST" action="/logs" novalidate>
        <div class="modal-header">
          <h5 class="modal-title" id="newLogModalLabel"><i class="bi bi-journal-plus me-2"></i>New Log Entry</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="row g-3">

            <!-- Site -->
            <div class="col-md-6">
              <label class="form-label">Site <span class="text-danger">*</span></label>
              <select name="siteID" class="form-select" required>
                <option value="">— Select Site —</option>
                <% sites.forEach(s => { %>
                  <option value="<%= s.SiteID %>"><%= s.SiteName %></option>
                <% }) %>
              </select>
            </div>

            <!-- Log Type -->
            <div class="col-md-6">
              <label class="form-label">Log Type <span class="text-danger">*</span></label>
              <select name="logTypeID" class="form-select" required>
                <option value="">— Select Type —</option>
                <% logTypes.forEach(t => { %>
                  <option value="<%= t.LogTypeID %>"><%= t.TypeName %></option>
                <% }) %>
              </select>
            </div>

            <!-- Entry Date -->
            <div class="col-md-6">
              <label class="form-label">Entry Date <span class="text-danger">*</span></label>
              <input type="datetime-local" name="entryDate" class="form-control" required
                     value="<%= (() => { const d = new Date(); return new Date(d.getTime() - d.getTimezoneOffset() * 60000).toISOString().slice(0,16); })() %>" />
            </div>

            <!-- Performed By -->
            <div class="col-md-6">
              <label class="form-label">Performed By</label>
              <input type="text" name="performedBy" class="form-control"
                     placeholder="Technician or contractor name" maxlength="200" />
            </div>

            <!-- Subject -->
            <div class="col-12">
              <label class="form-label">Subject</label>
              <input type="text" name="subject" class="form-control"
                     placeholder="Brief summary of this log entry" maxlength="500" />
            </div>

            <!-- Description -->
            <div class="col-12">
              <label class="form-label">Description</label>
              <textarea name="description" class="form-control" rows="5"
                        placeholder="Detailed description of work performed, observations, etc."
                        maxlength="8000"></textarea>
            </div>

          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-floppy me-1"></i>Create Log Entry</button>
        </div>
      </form>
    </div>
  </div>
</div>
