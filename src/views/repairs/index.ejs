<%
  function statusBadge(repair) {
    if (repair.ReceivedDate) return '<span class="badge bg-success">Closed</span>';
    if (!repair.SentDate)    return '<span class="badge bg-secondary">Not Sent</span>';
    const now = new Date(); now.setUTCHours(0, 0, 0, 0);
    const exp = repair.ExpectedReturnDate ? new Date(repair.ExpectedReturnDate) : null;
    if (exp && exp < now) return '<span class="badge bg-danger">Overdue</span>';
    return '<span class="badge bg-warning text-dark">Open</span>';
  }

  function daysOpen(sentDate) {
    if (!sentDate) return '—';
    const days = Math.ceil((new Date() - new Date(sentDate)) / (1000 * 60 * 60 * 24));
    return days + 'd';
  }

  const curSort = typeof sort !== 'undefined' ? sort : 'sentDate';
  const curDir  = typeof dir  !== 'undefined' ? dir  : 'desc';
  function sortLink(col) {
    const defaultDir = col === 'sentDate' ? 'desc' : 'asc';
    const newDir = (curSort === col && curDir === defaultDir) ? (defaultDir === 'asc' ? 'desc' : 'asc') : defaultDir;
    const f = typeof filters !== 'undefined' ? filters : {};
    const parts = [`status=${encodeURIComponent(f.status || 'open')}`];
    if (f.search)         parts.push(`search=${encodeURIComponent(f.search)}`);
    if (f.manufacturer)   parts.push(`manufacturer=${encodeURIComponent(f.manufacturer)}`);
    if (f.assignedUserID) parts.push(`assignedUserID=${encodeURIComponent(f.assignedUserID)}`);
    parts.push(`sort=${col}`, `dir=${newDir}`);
    return `/repairs?${parts.join('&')}`;
  }
  function sortIcon(col) {
    if (curSort !== col) return '<i class="bi bi-arrow-down-up text-muted ms-1 small opacity-50"></i>';
    return curDir === 'asc'
      ? '<i class="bi bi-sort-up ms-1 small"></i>'
      : '<i class="bi bi-sort-down ms-1 small"></i>';
  }
%>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0"><i class="bi bi-wrench-adjustable me-2"></i>Repairs & RMAs</h1>
  <% if (user && user.roles && user.roles.includes('Admin')) { %>
    <a href="/repairs/new" class="btn btn-primary btn-sm">
      <i class="bi bi-plus-lg me-1"></i>New Repair
    </a>
  <% } %>
</div>

<!-- Filters -->
<form method="get" action="/repairs" class="mb-3">
  <div class="row g-2 align-items-end">
    <div class="col-sm-auto">
      <label class="form-label small mb-1">Search</label>
      <input type="text" name="search" class="form-control form-control-sm" placeholder="Item, serial, RMA#, manufacturer…" value="<%= filters.search %>">
    </div>
    <div class="col-sm-auto">
      <label class="form-label small mb-1">Status</label>
      <select name="status" class="form-select form-select-sm">
        <option value="open"    <%= filters.status === 'open'    ? 'selected' : '' %>>Open</option>
        <option value="notsent" <%= filters.status === 'notsent' ? 'selected' : '' %>>Not Sent</option>
        <option value="closed"  <%= filters.status === 'closed'  ? 'selected' : '' %>>Closed</option>
        <option value="all"     <%= filters.status === 'all'     ? 'selected' : '' %>>All</option>
      </select>
    </div>
    <div class="col-sm-auto">
      <label class="form-label small mb-1">Manufacturer</label>
      <select name="manufacturer" class="form-select form-select-sm">
        <option value="">All Manufacturers</option>
        <% manufacturers.forEach(m => { %>
          <option value="<%= m %>" <%= filters.manufacturer === m ? 'selected' : '' %>><%= m %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-sm-auto">
      <label class="form-label small mb-1">Assigned To</label>
      <select name="assignedUserID" class="form-select form-select-sm">
        <option value="">All Users</option>
        <% users.forEach(u => { %>
          <option value="<%= u.UserID %>" <%= filters.assignedUserID === u.UserID ? 'selected' : '' %>><%= u.DisplayName %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-sm-auto d-flex gap-2">
      <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-funnel me-1"></i>Filter</button>
      <a href="/repairs" class="btn btn-outline-secondary btn-sm">Clear</a>
    </div>
  </div>
</form>

<% if (repairs.length === 0) { %>
  <div class="alert alert-info">
    No <%= filters.status !== 'all' ? filters.status : '' %> repairs found.
  </div>
<% } else { %>
<div class="table-responsive">
  <table class="table table-hover table-sm align-middle mb-0">
    <thead>
      <tr>
        <th class="text-muted">#</th>
        <th><a href="<%- sortLink('item') %>" class="text-decoration-none text-body">Item<%- sortIcon('item') %></a></th>
        <th><a href="<%- sortLink('manufacturer') %>" class="text-decoration-none text-body">Manufacturer<%- sortIcon('manufacturer') %></a></th>
        <th><a href="<%- sortLink('createdAt') %>" class="text-decoration-none text-body">Created<%- sortIcon('createdAt') %></a></th>
        <th><a href="<%- sortLink('sentDate') %>" class="text-decoration-none text-body">Sent Date<%- sortIcon('sentDate') %></a></th>
        <th>RMA #</th>
        <th><a href="<%- sortLink('expectedReturn') %>" class="text-decoration-none text-body">Expected Return<%- sortIcon('expectedReturn') %></a></th>
        <th><a href="<%- sortLink('assignedUser') %>" class="text-decoration-none text-body">Assigned To<%- sortIcon('assignedUser') %></a></th>
        <th>Status</th>
        <th>Days Open</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% repairs.forEach(repair => { %>
      <tr>
        <td class="small text-muted text-nowrap"><%= repair.RepairID %></td>
        <td>
          <a href="/repairs/<%= repair.RepairID %>" class="text-decoration-none fw-semibold">
            <%= repair.CommonName || repair.SerialNumber || repair.ModelNumber || ('Item #' + repair.ItemID) %>
          </a>
          <% if (!repair.SerialNumber && repair.ModelNumber) { %>
            <span class="badge bg-info text-dark small ms-1">FRU</span>
          <% } %>
          <% if (repair.SerialNumber) { %>
            <div class="small text-muted"><%= repair.SerialNumber %><% if (repair.ModelNumber) { %> / <%= repair.ModelNumber %><% } %></div>
          <% } else if (repair.ModelNumber && repair.CommonName) { %>
            <div class="small text-muted"><%= repair.ModelNumber %></div>
          <% } %>
        </td>
        <td class="small text-muted"><%= repair.Manufacturer || '—' %></td>
        <td class="small text-muted text-nowrap">
          <%= repair.CreatedAt ? new Date(repair.CreatedAt).toLocaleDateString() : '—' %>
        </td>
        <td class="small text-muted text-nowrap">
          <%= repair.SentDate ? new Date(repair.SentDate).toLocaleDateString('en-US', { timeZone: 'UTC' }) : '—' %>
        </td>
        <td class="small"><%= repair.RMANumber || '—' %></td>
        <td class="small text-muted text-nowrap">
          <%= repair.ExpectedReturnDate ? new Date(repair.ExpectedReturnDate).toLocaleDateString('en-US', { timeZone: 'UTC' }) : '—' %>
        </td>
        <td class="small text-muted"><%= repair.AssignedUserName || '—' %></td>
        <td><%- statusBadge(repair) %></td>
        <td class="small text-muted">
          <% if (!repair.ReceivedDate) { %>
            <%= daysOpen(repair.SentDate) %>
          <% } else { %>
            <span class="text-success">Closed</span>
          <% } %>
        </td>
        <td>
          <a href="/repairs/<%= repair.RepairID %>" class="btn btn-sm btn-outline-secondary">View</a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Pagination -->
<div class="d-flex justify-content-between align-items-center mt-3">
  <small class="text-muted">
    Showing <%= repairs.length %> of <%= pagination.total %> record<%= pagination.total !== 1 ? 's' : '' %>
  </small>
  <%- include('../partials/pagination') %>
</div>
<% } %>
