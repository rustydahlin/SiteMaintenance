<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">
    <i class="bi bi-wrench-adjustable me-2"></i>
    <% if (isEdit) { const lbl = repair.SerialNumber || repair.CommonName || repair.ModelNumber || `Item #${repair.ItemID}`; %>
      Edit Repair — <%= lbl %>
    <% } else { %>New Repair / RMA<% } %>
  </h1>
  <a href="<%= isEdit ? `/repairs/${repair.RepairID}` : '/repairs' %>"
     class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Cancel
  </a>
</div>

<% if (typeof formErrors !== 'undefined' && formErrors && formErrors.length) { %>
<div class="alert alert-danger mb-3">
  <% formErrors.forEach(e => { %><div><i class="bi bi-exclamation-circle me-1"></i><%= e %></div><% }) %>
</div>
<% } %>

<div class="card shadow-sm">
  <div class="card-body">
    <form method="POST" action="<%= action %>" novalidate>

      <div class="row g-3">

        <!-- Item / Serial Number -->
        <div class="col-md-6">
          <label for="itemID" class="form-label">
            Inventory Item <span class="text-danger">*</span>
          </label>
          <% if (prefilledItem) { %>
            <input type="hidden" name="itemID" value="<%= prefilledItem.ItemID %>" />
            <% if (typeof bulkStockLabel !== 'undefined' && bulkStockLabel) { %>
              <input type="hidden" name="bulkStockLabel" value="<%= bulkStockLabel %>" />
            <% } %>
            <div class="form-control bg-body-secondary">
              <i class="bi bi-box-seam me-1 text-muted"></i>
              <strong><%= prefilledItem.SerialNumber || prefilledItem.CommonName || prefilledItem.ModelNumber || `Item #${prefilledItem.ItemID}` %></strong>
              <% if (prefilledItem.SerialNumber && prefilledItem.CommonName) { %>
                <span class="text-muted ms-1">— <%= prefilledItem.CommonName %></span>
              <% } else if (prefilledItem.ModelNumber && (prefilledItem.SerialNumber || prefilledItem.CommonName)) { %>
                <span class="text-muted ms-1">— <%= prefilledItem.ModelNumber %></span>
              <% } %>
              <% if (typeof bulkStockLabel !== 'undefined' && bulkStockLabel) { %>
                <span class="text-muted ms-2">· from: <%= bulkStockLabel %></span>
              <% } %>
            </div>
          <% } else { %>
            <input type="hidden" id="itemID" name="itemID" value="" required />
            <input type="hidden" id="siteInventoryID" name="siteInventoryID" value="" />
            <input type="hidden" id="bulkStockID" name="bulkStockID" value="" />
            <input type="hidden" id="bulkStockLabel" name="bulkStockLabel" value="" />
            <div class="input-group">
              <input type="text" id="itemDisplay" class="form-control" readonly
                     placeholder="Click the search button to browse inventory…"
                     style="cursor:pointer; background:var(--bs-body-bg)"
                     data-bs-toggle="modal" data-bs-target="#itemPickerModal" />
              <button type="button" class="btn btn-outline-secondary"
                      data-bs-toggle="modal" data-bs-target="#itemPickerModal"
                      title="Browse inventory">
                <i class="bi bi-search"></i>
              </button>
              <button type="button" class="btn btn-outline-danger" id="clearItem"
                      style="display:none" title="Clear selection">
                <i class="bi bi-x-lg"></i>
              </button>
            </div>
          <% } %>

          <!-- Deployment warning (shown by JS when selected item is deployed) -->
          <div id="deployedWarning" class="alert alert-warning mt-2 mb-0" style="display:none;">
            <div class="fw-semibold mb-2">
              <i class="bi bi-exclamation-triangle-fill me-1"></i>
              This item is currently installed at <strong id="deployedSiteName"></strong>.
            </div>
            <p class="small mb-2">
              Continuing will remove it from that site. You can optionally swap in a replacement item below.
            </p>
            <label class="form-label small fw-semibold mb-1">Swap in replacement (optional)</label>
            <input type="hidden" id="replacementItemID" name="replacementItemID" value="" />
            <div class="input-group input-group-sm">
              <input type="text" id="replacementChosen" class="form-control bg-body-secondary" readonly
                     placeholder="Click to browse In-Stock items…"
                     style="cursor:pointer"
                     data-bs-toggle="modal" data-bs-target="#replacementPickerModal" />
              <button type="button" class="btn btn-outline-secondary btn-sm"
                      data-bs-toggle="modal" data-bs-target="#replacementPickerModal"
                      title="Browse In-Stock items">
                <i class="bi bi-search"></i>
              </button>
              <button type="button" class="btn btn-outline-danger btn-sm" id="clearReplacement"
                      style="display:none" title="Clear replacement">
                <i class="bi bi-x-lg"></i>
              </button>
            </div>
          </div>
        </div>

        <!-- Serial Number (serialized items only) -->
        <% if (prefilledItem && prefilledItem.TrackingType === 'serialized') { %>
        <div class="col-md-6">
          <label class="form-label">Serial Number</label>
          <div class="form-control bg-body-secondary"><%= prefilledItem.SerialNumber || '—' %></div>
        </div>
        <% } %>

        <!-- Sent Date -->
        <div class="col-md-3">
          <label for="sentDate" class="form-label">Sent Date</label>
          <input type="date" id="sentDate" name="sentDate"
                 class="form-control"
                 value="<%= repair && repair.SentDate
                   ? new Date(repair.SentDate).toISOString().split('T')[0]
                   : '' %>" />
          <div class="form-text">Fill in on the day the item is physically shipped.</div>
        </div>

        <!-- RMA Number -->
        <div class="col-md-3">
          <label for="rmaNumber" class="form-label">RMA Number</label>
          <input type="text" id="rmaNumber" name="rmaNumber"
                 class="form-control"
                 value="<%= repair && repair.RMANumber ? repair.RMANumber : '' %>"
                 maxlength="100" />
        </div>

        <!-- Manufacturer Contact -->
        <div class="col-md-6">
          <label for="manufacturerContact" class="form-label">Manufacturer Contact</label>
          <input type="text" id="manufacturerContact" name="manufacturerContact"
                 class="form-control"
                 placeholder="Contact name, email, or phone"
                 value="<%= repair && repair.ManufacturerContact ? repair.ManufacturerContact : '' %>"
                 maxlength="500" />
        </div>

        <!-- Sent By -->
        <div class="col-md-3">
          <label for="sentByUserID" class="form-label">Sent By</label>
          <select id="sentByUserID" name="sentByUserID" class="form-select">
            <option value="">— Select User —</option>
            <% users.forEach(u => { %>
              <option value="<%= u.UserID %>"
                <%= (repair && repair.SentByUserID == u.UserID) ? 'selected' : '' %>>
                <%= u.DisplayName %>
              </option>
            <% }) %>
          </select>
        </div>

        <!-- Assigned To -->
        <div class="col-md-3">
          <label for="assignedUserID" class="form-label">Assigned To</label>
          <select id="assignedUserID" name="assignedUserID" class="form-select">
            <option value="">— Select User —</option>
            <% users.forEach(u => { %>
              <option value="<%= u.UserID %>"
                <%= (repair && repair.AssignedUserID == u.UserID) ? 'selected' :
                   (!isEdit && currentUserID == u.UserID) ? 'selected' : '' %>>
                <%= u.DisplayName %>
              </option>
            <% }) %>
          </select>
          <div class="form-text">Receives overdue email reminders.</div>
        </div>

        <!-- Expected Return Date -->
        <div class="col-md-3">
          <label for="expectedReturnDate" class="form-label">Expected Return Date</label>
          <input type="date" id="expectedReturnDate" name="expectedReturnDate"
                 class="form-control"
                 value="<%= repair && repair.ExpectedReturnDate
                   ? new Date(repair.ExpectedReturnDate).toISOString().split('T')[0]
                   : '' %>" />
        </div>

        <!-- Reason -->
        <div class="col-12">
          <label for="reason" class="form-label">
            Reason for Repair <span class="text-danger">*</span>
          </label>
          <textarea id="reason" name="reason"
                    class="form-control" rows="4" required
                    placeholder="Describe the issue or reason for sending for repair/RMA…"
                    maxlength="4000"><%= repair && repair.Reason ? repair.Reason : '' %></textarea>
        </div>

      </div><!-- /.row -->

      <hr class="my-4" />

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-floppy me-1"></i>
          <%= isEdit ? 'Save Changes' : 'Create Repair Record' %>
        </button>
        <a href="<%= isEdit ? `/repairs/${repair.RepairID}` : '/repairs' %>"
           class="btn btn-outline-secondary">Cancel</a>
      </div>

    </form>
  </div>
</div>

<!-- ── Inventory Picker Modal ─────────────────────────────────────────────── -->
<% if (!prefilledItem) { %>
<div class="modal fade" id="itemPickerModal" tabindex="-1" aria-labelledby="itemPickerModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h5 class="modal-title" id="itemPickerModalLabel">
          <i class="bi bi-box-seam me-2"></i>Select Inventory Item
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0">
        <!-- Search bar -->
        <div class="p-3 border-bottom">
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" id="pickerSearch" class="form-control"
                   placeholder="Search by serial number, common name, model, manufacturer…"
                   autocomplete="off" />
            <button type="button" class="btn btn-outline-secondary" id="pickerClearSearch"
                    style="display:none" title="Clear search">
              <i class="bi bi-x-lg"></i>
            </button>
          </div>
        </div>
        <!-- Results table -->
        <div id="pickerLoading" class="text-center text-muted py-5" style="display:none">
          <div class="spinner-border spinner-border-sm me-2"></div>Loading…
        </div>
        <div id="pickerEmpty" class="text-center text-muted py-5" style="display:none">
          <i class="bi bi-inbox fs-3 d-block mb-2"></i>No items found.
        </div>
        <div class="table-responsive" id="pickerTableWrap">
          <table class="table table-hover table-sm align-middle mb-0" style="cursor:pointer">
            <thead class="table-dark sticky-top">
              <tr>
                <th style="width:110px">Status</th>
                <th>Serial #</th>
                <th>Common Name</th>
                <th>Model #</th>
                <th>Manufacturer</th>
                <th>Location / Site</th>
              </tr>
            </thead>
            <tbody id="pickerTableBody"></tbody>
          </table>
        </div>
        <div id="pickerCount" class="px-3 py-2 border-top small text-muted" style="display:none"></div>

        <!-- Bulk items section -->
        <div id="pickerBulkSection" style="display:none">
          <div class="px-3 pt-3 pb-1 border-top">
            <span class="fw-semibold small">
              <i class="bi bi-stack me-1 text-secondary"></i>Bulk Items with Available Stock
            </span>
            <span class="text-muted small ms-2">These items are tracked by quantity, not serial number.</span>
          </div>
          <div class="table-responsive">
            <table class="table table-hover table-sm align-middle mb-0" style="cursor:pointer">
              <thead class="table-secondary">
                <tr>
                  <th>Common Name</th>
                  <th>Model #</th>
                  <th>Manufacturer</th>
                  <th>Stock Location</th>
                  <th class="text-center">Available</th>
                </tr>
              </thead>
              <tbody id="pickerBulkBody"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ── Replacement Picker Modal ───────────────────────────────────────────── -->
<div class="modal fade" id="replacementPickerModal" tabindex="-1" aria-labelledby="replPickerLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h5 class="modal-title" id="replPickerLabel">
          <i class="bi bi-box-seam me-2"></i>Select Replacement — In-Stock Items
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0">
        <div class="p-3 border-bottom">
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" id="replPickerSearch" class="form-control"
                   placeholder="Search by serial number, common name, model, manufacturer…"
                   autocomplete="off" />
            <button type="button" class="btn btn-outline-secondary" id="replClearSearch"
                    style="display:none" title="Clear search">
              <i class="bi bi-x-lg"></i>
            </button>
          </div>
        </div>
        <div id="replLoading" class="text-center text-muted py-5" style="display:none">
          <div class="spinner-border spinner-border-sm me-2"></div>Loading…
        </div>
        <div id="replEmpty" class="text-center text-muted py-5" style="display:none">
          <i class="bi bi-inbox fs-3 d-block mb-2"></i>No in-stock items found.
        </div>
        <div class="table-responsive" id="replTableWrap">
          <table class="table table-hover table-sm align-middle mb-0" style="cursor:pointer">
            <thead class="table-dark sticky-top">
              <tr>
                <th>Serial #</th>
                <th>Common Name</th>
                <th>Model #</th>
                <th>Manufacturer</th>
                <th>Stock Location</th>
              </tr>
            </thead>
            <tbody id="replTableBody"></tbody>
          </table>
        </div>
        <div id="replCount" class="px-3 py-2 border-top small text-muted" style="display:none"></div>

        <!-- Bulk items matching Common Name -->
        <div id="replBulkSection" style="display:none">
          <div class="px-3 pt-3 pb-1 border-top">
            <span class="fw-semibold small">
              <i class="bi bi-stack me-1 text-secondary"></i>Bulk Items — Matching Common Name
            </span>
            <span class="text-muted small ms-2">Tracked by quantity, not serial number.</span>
          </div>
          <div class="table-responsive">
            <table class="table table-hover table-sm align-middle mb-0" style="cursor:pointer">
              <thead class="table-secondary">
                <tr>
                  <th>Common Name</th>
                  <th>Model #</th>
                  <th>Manufacturer</th>
                  <th>Stock Location</th>
                  <th class="text-center">Available</th>
                </tr>
              </thead>
              <tbody id="replBulkBody"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  const hiddenInput   = document.getElementById('itemID');
  const siHidden      = document.getElementById('siteInventoryID');
  const displayInput  = document.getElementById('itemDisplay');
  const clearBtn      = document.getElementById('clearItem');
  const deployWarning = document.getElementById('deployedWarning');
  const deployedName  = document.getElementById('deployedSiteName');


  // Modal picker elements
  const pickerSearch      = document.getElementById('pickerSearch');
  const pickerClearSearch = document.getElementById('pickerClearSearch');
  const pickerLoading     = document.getElementById('pickerLoading');
  const pickerEmpty       = document.getElementById('pickerEmpty');
  const pickerTableWrap   = document.getElementById('pickerTableWrap');
  const pickerTableBody   = document.getElementById('pickerTableBody');
  const pickerCount       = document.getElementById('pickerCount');
  const bulkStockHidden      = document.getElementById('bulkStockID');
  const bulkStockLabelHidden = document.getElementById('bulkStockLabel');
  const pickerBulkSection = document.getElementById('pickerBulkSection');
  const pickerBulkBody    = document.getElementById('pickerBulkBody');
  const pickerModal       = document.getElementById('itemPickerModal');

  let searchDebounce;

  function statusBadge(name) {
    const cls = name === 'In-Stock' ? 'bg-success'
              : name === 'Deployed' ? 'bg-primary'
              : name === 'In-Repair' ? 'bg-warning text-dark'
              : 'bg-secondary';
    return `<span class="badge ${cls}">${name || '—'}</span>`;
  }

  function itemLabel(item) {
    const primary = item.SerialNumber || item.CommonName || item.ModelNumber || `Item #${item.ItemID}`;
    const parts = [];
    if (item.SerialNumber && item.CommonName) parts.push(item.CommonName);
    if (item.ModelNumber && (item.SerialNumber || item.CommonName)) parts.push(item.ModelNumber);
    if (item.Manufacturer) parts.push(item.Manufacturer);
    return primary + (parts.length ? ' — ' + parts.join(' / ') : '');
  }

  function renderPickerResults(items) {
    pickerLoading.style.display = 'none';
    if (!items.length) {
      pickerTableWrap.style.display = 'none';
      pickerCount.style.display     = 'none';
      pickerEmpty.style.display     = 'block';
      return;
    }
    pickerEmpty.style.display = 'none';
    pickerTableWrap.style.display = '';
    pickerCount.style.display = 'block';
    pickerCount.textContent = `${items.length} item${items.length !== 1 ? 's' : ''} found`;
    pickerTableBody.innerHTML = items.map(item => {
      const location = item.CurrentSiteName
        ? `<i class="bi bi-geo-alt-fill text-primary me-1"></i>${escHtml(item.CurrentSiteName)}`
        : (item.StockLocationName
            ? `<i class="bi bi-box-seam text-success me-1"></i>${escHtml(item.StockLocationName)}`
            : '<span class="text-muted">—</span>');
      return `<tr class="picker-row" data-item='${JSON.stringify(item).replace(/'/g, '&#39;').replace(/"/g, '&quot;')}'>
        <td>${statusBadge(item.StatusName)}</td>
        <td class="fw-semibold">${escHtml(item.SerialNumber || '—')}</td>
        <td>${escHtml(item.CommonName || '—')}</td>
        <td class="text-muted small">${escHtml(item.ModelNumber || '—')}</td>
        <td class="text-muted small">${escHtml(item.Manufacturer || '—')}</td>
        <td class="small">${location}</td>
      </tr>`;
    }).join('');

    pickerTableBody.querySelectorAll('.picker-row').forEach(row => {
      row.addEventListener('click', function () {
        const item = JSON.parse(this.dataset.item.replace(/&quot;/g, '"'));
        selectItem(item);
        bootstrap.Modal.getInstance(pickerModal).hide();
      });
    });
  }

  function escHtml(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function renderBulkResults(items) {
    if (!items.length) {
      pickerBulkSection.style.display = 'none';
      return;
    }
    pickerBulkSection.style.display = '';

    let html = '';
    for (const item of items) {
      const distribs     = item.distributions || [];
      const allocatedQty = distribs.reduce((s, d) => s + d.Quantity, 0);
      const unallocated  = Math.max(0, item.QuantityAvailable - allocatedQty);
      const itemJson     = JSON.stringify(item).replace(/'/g, '&#39;').replace(/"/g, '&quot;');

      // Group header row (not clickable)
      html += `<tr class="table-secondary">
        <td colspan="4" class="fw-semibold ps-3 py-1">
          <i class="bi bi-stack me-1"></i>${escHtml(item.CommonName || '—')}
          <span class="text-muted fw-normal small ms-2">${escHtml(item.ModelNumber || '')}${item.ModelNumber && item.Manufacturer ? ' / ' : ''}${escHtml(item.Manufacturer || '')}</span>
        </td>
        <td class="text-center py-1 text-muted small">${item.QuantityAvailable} / ${item.QuantityTotal} avail.</td>
      </tr>`;

      // One sub-row per distribution
      for (const d of distribs) {
        const icon = d.StockType === 'location' ? 'bi-box-seam text-success' : 'bi-person text-info';
        const subItem = JSON.stringify({ ...item, _stockID: d.StockID, _stockLabel: d.Label })
          .replace(/'/g, '&#39;').replace(/"/g, '&quot;');
        html += `<tr class="picker-bulk-row" style="cursor:pointer" data-item='${subItem}'>
          <td class="ps-4 small"><i class="bi ${icon} me-1"></i>${escHtml(d.Label)}</td>
          <td class="text-muted small" colspan="3"></td>
          <td class="text-center"><span class="badge bg-success">${d.Quantity}</span></td>
        </tr>`;
      }

      // Unallocated sub-row (if any)
      if (unallocated > 0) {
        const subItem = JSON.stringify({ ...item, _stockID: null, _stockLabel: 'Unallocated' })
          .replace(/'/g, '&#39;').replace(/"/g, '&quot;');
        html += `<tr class="picker-bulk-row" style="cursor:pointer" data-item='${subItem}'>
          <td class="ps-4 small text-muted fst-italic"><i class="bi bi-inbox me-1"></i>Unallocated</td>
          <td class="text-muted small" colspan="3"></td>
          <td class="text-center"><span class="badge bg-secondary">${unallocated}</span></td>
        </tr>`;
      }
    }

    pickerBulkBody.innerHTML = html;
    pickerBulkBody.querySelectorAll('.picker-bulk-row').forEach(row => {
      row.addEventListener('click', function () {
        const item = JSON.parse(this.dataset.item.replace(/&quot;/g, '"'));
        selectBulkItem(item);
        bootstrap.Modal.getInstance(pickerModal).hide();
      });
    });
  }

  function selectBulkItem(item) {
    hiddenInput.value           = item.ItemID;
    siHidden.value              = '';
    bulkStockHidden.value       = item._stockID || '';
    bulkStockLabelHidden.value  = item._stockLabel || '';
    const nameParts = [item.CommonName, item.ModelNumber].filter(Boolean).join(' — ');
    const from      = item._stockLabel ? ` · from: ${item._stockLabel}` : '';
    displayInput.value          = `${nameParts}${from}`;
    clearBtn.style.display      = 'inline-flex';
    deployWarning.style.display = 'none';
    clearReplacement();
  }

  async function loadPickerItems(q) {
    pickerLoading.style.display   = 'block';
    pickerTableWrap.style.display = 'none';
    pickerEmpty.style.display     = 'none';
    pickerCount.style.display     = 'none';
    pickerBulkSection.style.display = 'none';
    try {
      const qs = encodeURIComponent(q || '');
      const [serialized, bulk] = await Promise.all([
        fetch(`/repairs/inventory-search?q=${qs}`).then(r => r.json()),
        fetch(`/repairs/bulk-inventory-search?q=${qs}`).then(r => r.json()),
      ]);
      pickerLoading.style.display = 'none';
      renderPickerResults(serialized);
      renderBulkResults(bulk);
    } catch (_) {
      pickerLoading.style.display = 'none';
      pickerEmpty.style.display   = 'block';
    }
  }

  // Load all items when modal opens
  pickerModal.addEventListener('show.bs.modal', () => {
    pickerSearch.value = '';
    pickerClearSearch.style.display = 'none';
    loadPickerItems('');
    setTimeout(() => pickerSearch.focus(), 300);
  });

  pickerSearch.addEventListener('input', function () {
    const q = this.value.trim();
    pickerClearSearch.style.display = q ? 'inline-flex' : 'none';
    clearTimeout(searchDebounce);
    searchDebounce = setTimeout(() => loadPickerItems(q), 250);
  });

  pickerClearSearch.addEventListener('click', () => {
    pickerSearch.value = '';
    pickerClearSearch.style.display = 'none';
    loadPickerItems('');
    pickerSearch.focus();
  });

  let selectedCommonName = '';

  function selectItem(item) {
    hiddenInput.value      = item.ItemID;
    siHidden.value         = item.CurrentSiteInventoryID || '';
    bulkStockHidden.value  = '';
    displayInput.value     = itemLabel(item);
    clearBtn.style.display = 'inline-flex';
    selectedCommonName     = item.CommonName || '';

    if (item.CurrentSiteID) {
      deployedName.textContent    = item.CurrentSiteName;
      deployWarning.style.display = 'block';
    } else {
      deployWarning.style.display = 'none';
      clearReplacement();
    }
  }

  clearBtn.addEventListener('click', function () {
    hiddenInput.value           = '';
    siHidden.value              = '';
    bulkStockHidden.value       = '';
    bulkStockLabelHidden.value  = '';
    displayInput.value          = '';
    clearBtn.style.display      = 'none';
    deployWarning.style.display = 'none';
    clearReplacement();
  });

  // ── Replacement modal picker ─────────────────────────────────────────────────
  const replHidden   = document.getElementById('replacementItemID');
  const replChosen   = document.getElementById('replacementChosen');
  const replClearBtn   = document.getElementById('clearReplacement');
  const replModal      = document.getElementById('replacementPickerModal');
  const replSearch     = document.getElementById('replPickerSearch');
  const replClearS     = document.getElementById('replClearSearch');
  const replLoading    = document.getElementById('replLoading');
  const replEmpty      = document.getElementById('replEmpty');
  const replTableWrap  = document.getElementById('replTableWrap');
  const replTableBody  = document.getElementById('replTableBody');
  const replCount      = document.getElementById('replCount');
  const replBulkSection= document.getElementById('replBulkSection');
  const replBulkBody   = document.getElementById('replBulkBody');

  let replDebounce;

  async function loadReplItems(q) {
    replLoading.style.display     = 'block';
    replTableWrap.style.display   = 'none';
    replEmpty.style.display       = 'none';
    replCount.style.display       = 'none';
    replBulkSection.style.display = 'none';
    try {
      const [items, bulkItems] = await Promise.all([
        fetch(`/repairs/inventory-search?q=${encodeURIComponent(q || '')}&inStock=1`).then(r => r.json()),
        q ? fetch(`/repairs/bulk-inventory-search?q=${encodeURIComponent(q)}`).then(r => r.json()) : Promise.resolve([]),
      ]);
      replLoading.style.display = 'none';

      if (!items.length && !bulkItems.length) {
        replEmpty.style.display = 'block';
      } else if (!items.length) {
        // bulk items exist — don't show the empty state
      } else {
        replCount.textContent       = `${items.length} item${items.length !== 1 ? 's' : ''} found`;
        replCount.style.display     = 'block';
        replTableWrap.style.display = '';
        replTableBody.innerHTML     = items.map(item => `
          <tr class="repl-row" style="cursor:pointer"
              data-item='${JSON.stringify(item).replace(/'/g,'&#39;').replace(/"/g,'&quot;')}'>
            <td class="fw-semibold">${escHtml(item.SerialNumber || '—')}</td>
            <td>${escHtml(item.CommonName || '—')}</td>
            <td class="text-muted small">${escHtml(item.ModelNumber || '—')}</td>
            <td class="text-muted small">${escHtml(item.Manufacturer || '—')}</td>
            <td class="small">${item.StockLocationName ? `<i class="bi bi-box-seam text-success me-1"></i>${escHtml(item.StockLocationName)}` : '<span class="text-muted">—</span>'}</td>
          </tr>`).join('');
        replTableBody.querySelectorAll('.repl-row').forEach(row => {
          row.addEventListener('click', function () {
            selectReplacement(JSON.parse(this.dataset.item.replace(/&quot;/g, '"')));
            bootstrap.Modal.getInstance(replModal).hide();
          });
        });
      }

      // Bulk section
      if (bulkItems.length) {
        replBulkSection.style.display = '';
        let html = '';
        for (const item of bulkItems) {
          const distribs     = item.distributions || [];
          const allocatedQty = distribs.reduce((s, d) => s + d.Quantity, 0);
          const unallocated  = Math.max(0, item.QuantityAvailable - allocatedQty);
          html += `<tr class="table-secondary">
            <td colspan="4" class="fw-semibold ps-3 py-1">
              <i class="bi bi-stack me-1"></i>${escHtml(item.CommonName || '—')}
              <span class="text-muted fw-normal small ms-2">${escHtml(item.ModelNumber || '')}${item.ModelNumber && item.Manufacturer ? ' / ' : ''}${escHtml(item.Manufacturer || '')}</span>
            </td>
            <td class="text-center py-1 text-muted small">${item.QuantityAvailable} / ${item.QuantityTotal} avail.</td>
          </tr>`;
          for (const d of distribs) {
            const icon    = d.StockType === 'location' ? 'bi-box-seam text-success' : 'bi-person text-info';
            const subItem = JSON.stringify({ ...item, _stockID: d.StockID, _stockLabel: d.Label }).replace(/'/g,'&#39;').replace(/"/g,'&quot;');
            html += `<tr class="repl-bulk-row" style="cursor:pointer" data-item='${subItem}'>
              <td class="ps-4 small"><i class="bi ${icon} me-1"></i>${escHtml(d.Label)}</td>
              <td class="text-muted small" colspan="3"></td>
              <td class="text-center"><span class="badge bg-success">${d.Quantity}</span></td>
            </tr>`;
          }
          if (unallocated > 0) {
            const subItem = JSON.stringify({ ...item, _stockID: null, _stockLabel: 'Unallocated' }).replace(/'/g,'&#39;').replace(/"/g,'&quot;');
            html += `<tr class="repl-bulk-row" style="cursor:pointer" data-item='${subItem}'>
              <td class="ps-4 small text-muted fst-italic"><i class="bi bi-inbox me-1"></i>Unallocated</td>
              <td class="text-muted small" colspan="3"></td>
              <td class="text-center"><span class="badge bg-secondary">${unallocated}</span></td>
            </tr>`;
          }
        }
        replBulkBody.innerHTML = html;
        replBulkBody.querySelectorAll('.repl-bulk-row').forEach(row => {
          row.addEventListener('click', function () {
            selectBulkReplacement(JSON.parse(this.dataset.item.replace(/&quot;/g, '"')));
            bootstrap.Modal.getInstance(replModal).hide();
          });
        });
      }
    } catch (_) {
      replLoading.style.display = 'none';
      replEmpty.style.display   = 'block';
    }
  }

  replModal.addEventListener('show.bs.modal', () => {
    replSearch.value = selectedCommonName;
    replClearS.style.display = selectedCommonName ? 'inline-flex' : 'none';
    loadReplItems(selectedCommonName);
    setTimeout(() => replSearch.focus(), 300);
  });

  replSearch.addEventListener('input', function () {
    const q = this.value.trim();
    replClearS.style.display = q ? 'inline-flex' : 'none';
    clearTimeout(replDebounce);
    replDebounce = setTimeout(() => loadReplItems(q), 250);
  });

  replClearS.addEventListener('click', () => {
    replSearch.value = '';
    replClearS.style.display = 'none';
    loadReplItems('');
    replSearch.focus();
  });

  function selectReplacement(item) {
    replHidden.value           = item.ItemID;
    replChosen.value           = itemLabel(item);
    replClearBtn.style.display = 'inline-flex';
  }

  function selectBulkReplacement(item) {
    replHidden.value           = item.ItemID;
    const nameParts = [item.CommonName, item.ModelNumber].filter(Boolean).join(' — ');
    const from      = item._stockLabel ? ` · from: ${item._stockLabel}` : '';
    replChosen.value           = `${nameParts}${from}`;
    replClearBtn.style.display = 'inline-flex';
  }

  function clearReplacement() {
    replHidden.value           = '';
    replChosen.value           = '';
    replClearBtn.style.display = 'none';
  }

  replClearBtn.addEventListener('click', clearReplacement);
})();
</script>
<% } %>
