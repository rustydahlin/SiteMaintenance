<div class="card shadow-sm">
  <div class="card-body p-4">
    <ul class="nav nav-tabs mb-3" id="loginTabs">
      <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#localTab">
          <i class="bi bi-person-lock me-1"></i>Local
        </button>
      </li>
      <% if (ldapEnabled) { %>
      <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#ldapTab">
          <i class="bi bi-diagram-3 me-1"></i>Active Directory
        </button>
      </li>
      <% } %>
    </ul>

    <div class="tab-content">
      <!-- Local Login -->
      <div class="tab-pane fade show active" id="localTab">
        <form action="/auth/login" method="POST">
          <div class="mb-3">
            <label class="form-label">Username</label>
            <input type="text" name="username" class="form-control" autocomplete="username" required autofocus />
          </div>
          <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" autocomplete="current-password" required />
          </div>
          <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
          </button>
        </form>
      </div>

      <!-- LDAP Login -->
      <div class="tab-pane fade" id="ldapTab">
        <form action="/auth/ldap" method="POST">
          <div class="mb-3">
            <label class="form-label">Domain Username</label>
            <input type="text" name="ldapUsername" class="form-control" autocomplete="username" />
          </div>
          <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" name="ldapPassword" class="form-control" autocomplete="current-password" />
          </div>
          <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-box-arrow-in-right me-2"></i>Sign In with AD
          </button>
        </form>
      </div>
    </div>

    <% if (oidcEnabled) { %>
    <div class="mt-3">
      <hr />
      <a href="/auth/oidc" class="btn btn-outline-secondary w-100">
        <i class="bi bi-microsoft me-2"></i>Sign in with Microsoft / Entra ID
      </a>
    </div>
    <% } %>
  </div>
</div>
