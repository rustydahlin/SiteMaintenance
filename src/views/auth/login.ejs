<div class="card shadow-sm">
  <div class="card-body p-4">
    <form action="/auth/login" method="POST">
      <div class="mb-3">
        <label class="form-label">Username</label>
        <input type="text" name="username" class="form-control" autocomplete="username" required autofocus />
      </div>
      <div class="mb-3">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" autocomplete="current-password" required />
      </div>
      <% if (loginNote) { %>
      <p class="small text-muted mb-3"><%= loginNote %></p>
      <% } %>
      <button type="submit" class="btn btn-primary w-100">
        <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
      </button>
      <% if (oidcEnabled) { %>
      <hr class="my-3">
      <a href="/auth/oidc" class="btn btn-outline-secondary w-100">
        <i class="bi bi-microsoft me-2"></i><%= oidcButtonLabel || 'Sign in with Microsoft / Entra ID' %>
      </a>
      <% } %>
    </form>
  </div>
</div>
