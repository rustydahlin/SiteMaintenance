<%
  const curSort = typeof sort !== 'undefined' ? sort : 'dueDate';
  const curDir  = typeof dir  !== 'undefined' ? dir  : 'asc';
  const f = typeof filters !== 'undefined' ? filters : {};
  function sortLink(col) {
    const newDir = (curSort === col && curDir === 'asc') ? 'desc' : 'asc';
    const parts = [];
    if (f.siteID)  parts.push(`siteID=${encodeURIComponent(f.siteID)}`);
    if (f.status)  parts.push(`status=${encodeURIComponent(f.status)}`);
    if (f.search)  parts.push(`search=${encodeURIComponent(f.search)}`);
    parts.push(`sort=${col}`, `dir=${newDir}`);
    return `/maintenance?${parts.join('&')}`;
  }
  function sortIcon(col) {
    if (curSort !== col) return '<i class="bi bi-arrow-down-up text-muted ms-1 small opacity-50"></i>';
    return curDir === 'asc'
      ? '<i class="bi bi-sort-up ms-1 small"></i>'
      : '<i class="bi bi-sort-down ms-1 small"></i>';
  }

  function statusBadge(item) {
    if (item.ClosedAt) {
      return '<span class="badge bg-secondary">Closed</span>';
    }
    if (item.DueDate) {
      const due  = new Date(item.DueDate);
      const now  = new Date();
      now.setHours(0, 0, 0, 0);
      if (due < now) return '<span class="badge bg-danger">Past-Due</span>';
    }
    return '<span class="badge bg-warning text-dark">Open</span>';
  }

  function dueBadge(item) {
    if (!item.DueDate) return '<span class="text-muted">—</span>';
    const due     = new Date(item.DueDate);
    const now     = new Date();
    now.setHours(0, 0, 0, 0);
    const diffMs  = due - now;
    const diffDay = Math.round(diffMs / 86400000);
    const label   = due.toLocaleDateString();
    if (item.ClosedAt)  return `<span class="text-muted">${label}</span>`;
    if (diffDay < 0)    return `<span class="text-danger fw-semibold">${label}</span>`;
    if (diffDay <= 7)   return `<span class="text-warning fw-semibold">${label}</span>`;
    return label;
  }
%>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0"><i class="bi bi-tools me-2"></i>Maintenance</h1>
  <% if (canManage) { %>
  <a href="/maintenance/new" class="btn btn-primary btn-sm">
    <i class="bi bi-plus-lg me-1"></i>New Item
  </a>
  <% } %>
</div>

<!-- Filters -->
<div class="card mb-3 shadow-sm">
  <div class="card-body py-2">
    <form method="GET" action="/maintenance" class="row g-2 align-items-end">
      <input type="hidden" name="sort" value="<%= curSort %>" />
      <input type="hidden" name="dir"  value="<%= curDir %>" />
      <div class="col-sm-3 col-lg-3">
        <label class="form-label small mb-1">Search</label>
        <input type="text" name="search" class="form-control form-control-sm"
               placeholder="Site, type, reference, user…"
               value="<%= filters.search || '' %>" />
      </div>
      <div class="col-sm-3 col-lg-3">
        <label class="form-label small mb-1">Site</label>
        <select name="siteID" class="form-select form-select-sm">
          <option value="">All Sites</option>
          <% sites.forEach(s => { %>
            <option value="<%= s.SiteID %>" <%= filters.siteID == s.SiteID ? 'selected' : '' %>>
              <%= s.SiteName %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-sm-2 col-lg-2">
        <label class="form-label small mb-1">Status</label>
        <select name="status" class="form-select form-select-sm">
          <option value="open"   <%= filters.status === 'open'   ? 'selected' : '' %>>Open</option>
          <option value="all"    <%= filters.status === 'all'    ? 'selected' : '' %>>All</option>
          <option value="closed" <%= filters.status === 'closed' ? 'selected' : '' %>>Closed</option>
        </select>
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-outline-primary">
          <i class="bi bi-search me-1"></i>Filter
        </button>
        <a href="/maintenance" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
      </div>
    </form>
  </div>
</div>

<% if (items.length === 0) { %>
  <div class="alert alert-info">No maintenance items found matching your filters.</div>
<% } else { %>
<div class="table-responsive">
  <table class="table table-hover table-sm align-middle mb-0">
    <thead>
      <tr>
        <th><a href="<%- sortLink('site') %>" class="text-decoration-none text-body">Site<%- sortIcon('site') %></a></th>
        <th><a href="<%- sortLink('type') %>" class="text-decoration-none text-body">Type<%- sortIcon('type') %></a></th>
        <th><a href="<%- sortLink('assignedTo') %>" class="text-decoration-none text-body">Assigned To<%- sortIcon('assignedTo') %></a></th>
        <th><a href="<%- sortLink('dueDate') %>" class="text-decoration-none text-body">Due Date<%- sortIcon('dueDate') %></a></th>
        <th><a href="<%- sortLink('createdAt') %>" class="text-decoration-none text-body">Created<%- sortIcon('createdAt') %></a></th>
        <th>Ref #</th>
        <th><a href="<%- sortLink('status') %>" class="text-decoration-none text-body">Status<%- sortIcon('status') %></a></th>
      </tr>
    </thead>
    <tbody>
      <% items.forEach(item => { %>
      <tr>
        <td>
          <a href="/maintenance/<%= item.MaintenanceID %>" class="fw-semibold text-decoration-none">
            <%= item.SiteName %>
          </a>
        </td>
        <td class="small"><%= item.MaintenanceTypeName || '—' %></td>
        <td class="small"><%= item.AssignedToUserName  || '—' %></td>
        <td class="small"><%- dueBadge(item) %></td>
        <td class="small text-muted"><%= item.CreatedAt ? new Date(item.CreatedAt).toLocaleDateString() : '—' %></td>
        <td class="small text-muted"><%= item.ExternalReference || '—' %></td>
        <td><%- statusBadge(item) %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Pagination -->
<div class="d-flex justify-content-between align-items-center mt-3">
  <small class="text-muted">
    Showing <%= items.length %> of <%= pagination.total %> item<%= pagination.total !== 1 ? 's' : '' %>
  </small>
  <%- include('../partials/pagination') %>
</div>
<% } %>
