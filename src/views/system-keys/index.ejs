<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0"><i class="bi bi-key me-2"></i>System Keys</h1>
  <div class="d-flex gap-2">
    <a href="/system-keys/import"   class="btn btn-outline-secondary btn-sm"><i class="bi bi-upload me-1"></i>Import</a>
    <a href="/system-keys/export"   class="btn btn-outline-secondary btn-sm"><i class="bi bi-download me-1"></i>Export</a>
    <a href="/system-keys/new"      class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>New Key</a>
  </div>
</div>

<!-- Filter form -->
<div class="card mb-3 shadow-sm">
  <div class="card-body py-2">
    <form method="GET" action="/system-keys" class="row g-2 align-items-end">
      <input type="hidden" name="sort" value="<%= sort %>">
      <input type="hidden" name="dir"  value="<%= dir %>">

      <div class="col-sm-4 col-lg-3">
        <label class="form-label small mb-1">Search</label>
        <input type="text" name="search" class="form-control form-control-sm"
               placeholder="Name, serial, key code…"
               value="<%= filters.search %>">
      </div>

      <div class="col-sm-3 col-lg-2">
        <label class="form-label small mb-1">Key Type</label>
        <select name="keyType" class="form-select form-select-sm">
          <option value="">All Types</option>
          <option value="Unlimited" <%= filters.keyType === 'Unlimited' ? 'selected' : '' %>>Unlimited</option>
          <option value="Limited"   <%= filters.keyType === 'Limited'   ? 'selected' : '' %>>Limited</option>
        </select>
      </div>

      <div class="col-sm-3 col-lg-2">
        <label class="form-label small mb-1">Expiration</label>
        <select name="expiryStatus" class="form-select form-select-sm">
          <option value="">All</option>
          <option value="expired"  <%= filters.expiryStatus === 'expired'  ? 'selected' : '' %>>Expired</option>
          <option value="expiring" <%= filters.expiryStatus === 'expiring' ? 'selected' : '' %>>Expiring (≤30 days)</option>
          <option value="ok"       <%= filters.expiryStatus === 'ok'       ? 'selected' : '' %>>OK</option>
        </select>
      </div>

      <div class="col-sm-3 col-lg-2">
        <label class="form-label small mb-1">Manufacturer</label>
        <select name="manufacturerID" class="form-select form-select-sm">
          <option value="">All Manufacturers</option>
          <% manufacturers.forEach(m => { %>
          <option value="<%= m.ManufacturerID %>" <%= filters.manufacturerID == m.ManufacturerID ? 'selected' : '' %>>
            <%= m.ManufacturerName %>
          </option>
          <% }) %>
        </select>
      </div>

      <div class="col-sm-2 col-lg-1">
        <div class="form-check mt-4">
          <input class="form-check-input" type="checkbox" name="includeInactive" id="includeInactive" value="1"
                 <%= filters.includeInactive === '1' ? 'checked' : '' %>>
          <label class="form-check-label small" for="includeInactive">Inactive</label>
        </div>
      </div>

      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-outline-primary">
          <i class="bi bi-search me-1"></i>Filter
        </button>
        <a href="/system-keys" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
      </div>
    </form>
  </div>
</div>

<% if (keys.length === 0) { %>
<div class="alert alert-info">No system keys found matching your filters.</div>
<% } else { %>

<%
  const today = new Date(); today.setHours(0,0,0,0);

  function expiryBadge(dateVal) {
    if (!dateVal) return '';
    const d = new Date(dateVal); d.setHours(0,0,0,0);
    const days = Math.ceil((d - today) / 86400000);
    if (days < 0)   return '<span class="badge bg-danger ms-1">Expired</span>';
    if (days <= 30) return `<span class="badge bg-warning text-dark ms-1">Expiring in ${days}d</span>`;
    return '';
  }

  function sortLink(col) {
    const newDir = (sort === col && dir === 'asc') ? 'desc' : 'asc';
    const parts = [];
    if (filters.search)         parts.push(`search=${encodeURIComponent(filters.search)}`);
    if (filters.includeInactive === '1') parts.push('includeInactive=1');
    if (filters.keyType)        parts.push(`keyType=${encodeURIComponent(filters.keyType)}`);
    if (filters.expiryStatus)   parts.push(`expiryStatus=${encodeURIComponent(filters.expiryStatus)}`);
    if (filters.manufacturerID) parts.push(`manufacturerID=${encodeURIComponent(filters.manufacturerID)}`);
    parts.push(`sort=${col}`, `dir=${newDir}`);
    return `/system-keys?${parts.join('&')}`;
  }

  function sortIcon(col) {
    if (sort !== col) return '<i class="bi bi-arrow-down-up text-muted ms-1 small opacity-50"></i>';
    return dir === 'asc'
      ? '<i class="bi bi-sort-up ms-1 small"></i>'
      : '<i class="bi bi-sort-down ms-1 small"></i>';
  }
%>

<div class="table-responsive">
  <table class="table table-hover align-middle">
    <thead>
      <tr>
        <th><a href="<%- sortLink('issuedTo') %>"      class="text-decoration-none text-body">Issued To<%- sortIcon('issuedTo') %></a></th>
        <th><a href="<%- sortLink('organization') %>"  class="text-decoration-none text-body">Organization<%- sortIcon('organization') %></a></th>
        <th><a href="<%- sortLink('dateIssued') %>"    class="text-decoration-none text-body">Date Issued<%- sortIcon('dateIssued') %></a></th>
        <th><a href="<%- sortLink('manufacturer') %>"  class="text-decoration-none text-body">Manufacturer<%- sortIcon('manufacturer') %></a></th>
        <th><a href="<%- sortLink('expiration') %>"    class="text-decoration-none text-body">Expiration<%- sortIcon('expiration') %></a></th>
        <th><a href="<%- sortLink('keyCode') %>"       class="text-decoration-none text-body">Key Code<%- sortIcon('keyCode') %></a></th>
        <th><a href="<%- sortLink('serialNumber') %>"  class="text-decoration-none text-body">Serial #<%- sortIcon('serialNumber') %></a></th>
        <th><a href="<%- sortLink('keyType') %>"       class="text-decoration-none text-body">Type<%- sortIcon('keyType') %></a></th>
        <th><a href="<%- sortLink('lastUpdatedBy') %>" class="text-decoration-none text-body">Last Updated By<%- sortIcon('lastUpdatedBy') %></a></th>
        <th></th>
      </tr>
    </thead>
    <tbody>
    <% for (const k of keys) { %>
      <tr class="<%= k.IsActive ? '' : 'text-muted' %>">
        <td><a href="/system-keys/<%= k.KeyID %>"><%= k.IssuedToName || '—' %></a></td>
        <td><%= k.Organization || '—' %></td>
        <td><%= k.DateIssued ? new Date(k.DateIssued).toLocaleDateString() : '—' %></td>
        <td><%= k.ManufacturerName || '—' %></td>
        <td>
          <% if (k.ExpirationDate) { %>
            <%= new Date(k.ExpirationDate).toLocaleDateString() %>
            <%- expiryBadge(k.ExpirationDate) %>
          <% } else { %>—<% } %>
        </td>
        <td><%= k.KeyCode || '—' %></td>
        <td><%= k.SerialNumber || '—' %></td>
        <td>
          <% if (k.KeyType === 'Limited') { %>
            <span class="badge bg-secondary">Limited</span>
          <% } else { %>
            <span class="badge bg-primary">Unlimited</span>
          <% } %>
        </td>
        <td><%= k.LastUpdatedByName || '—' %></td>
        <td class="text-end text-nowrap">
          <% if (k.IsActive) { %>
          <button type="button" class="btn btn-outline-success btn-sm me-1 js-renew-btn"
            data-key-id="<%= k.KeyID %>"
            data-expiry="<%= k.ExpirationDate ? new Date(k.ExpirationDate).toISOString().slice(0,10) : '' %>"
            title="Renew Key">
            <i class="bi bi-arrow-clockwise"></i>
          </button>
          <% } %>
          <a href="/system-keys/<%= k.KeyID %>/edit" class="btn btn-outline-secondary btn-sm">Edit</a>
        </td>
      </tr>
    <% } %>
    </tbody>
  </table>
</div>
<% } %>

<!-- Renew Modal (shared for list view) -->
<div class="modal fade" id="renewModal" tabindex="-1" aria-labelledby="renewModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="POST" id="renewForm" action="">
        <div class="modal-header">
          <h5 class="modal-title" id="renewModalLabel"><i class="bi bi-arrow-clockwise me-2"></i>Renew Key</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Renewal Date</label>
            <input type="date" name="lastRenewalDate" id="renewalDate" class="form-control"
                   value="<%= new Date().toISOString().slice(0,10) %>" required>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">New Expiration Date</label>
            <input type="date" name="expirationDate" id="renewExpiry" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Notes <span class="text-muted fw-normal">(optional — leave blank to keep existing)</span></label>
            <textarea name="notes" class="form-control" rows="3"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-success"><i class="bi bi-check-lg me-1"></i>Save Renewal</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('.js-renew-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    const keyID  = this.dataset.keyId;
    const expiry = this.dataset.expiry;
    document.getElementById('renewForm').action = '/system-keys/' + keyID + '/renew';
    document.getElementById('renewExpiry').value = expiry || '';
    new bootstrap.Modal(document.getElementById('renewModal')).show();
  });
});
</script>
