<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' — SiteMaintenance' : 'SiteMaintenance' %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/app.css" />
  <style>
    body { padding-top: 0; background: #f0f2f5; }
    .auth-card { max-width: 440px; width: 100%; }
  </style>
</head>
<body class="d-flex align-items-center justify-content-center min-vh-100">
  <div class="auth-card">
    <div class="text-center mb-4">
      <i class="bi bi-tools display-4 text-primary"></i>
      <h1 class="h3 mt-2 fw-bold">SiteMaintenance</h1>
    </div>
    <%- include('../partials/flash') %>
    <%- body %>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
