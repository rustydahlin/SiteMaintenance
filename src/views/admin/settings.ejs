<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0"><i class="bi bi-gear me-2"></i>Settings</h1>
  <a href="/admin" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<form action="/admin/settings" method="POST">
  <!-- General -->
  <div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold"><i class="bi bi-sliders me-2"></i>General</div>
    <div class="card-body row g-3">
      <div class="col-md-4">
        <label class="form-label">Application Name</label>
        <input type="text" name="app.name" class="form-control"
               value="<%= settings['app.name'] || 'SiteMaintenance' %>"
               placeholder="SiteMaintenance" maxlength="80" />
        <div class="form-text">Displayed in the top-left navigation bar.</div>
      </div>
      <div class="col-md-3">
        <label class="form-label">Enable System Keys Section</label>
        <select name="systemKeys.enabled" class="form-select">
          <option value="0" <%= settings['systemKeys.enabled'] === '1' ? '' : 'selected' %>>Disabled</option>
          <option value="1" <%= settings['systemKeys.enabled'] === '1' ? 'selected' : '' %>>Enabled</option>
        </select>
        <div class="form-text">Show / hide the System Keys section in the navigation.</div>
      </div>
      <div class="col-md-3">
        <label class="form-label">Enable Vendors Section</label>
        <select name="vendors.enabled" class="form-select">
          <option value="0" <%= settings['vendors.enabled'] === '1' ? '' : 'selected' %>>Disabled</option>
          <option value="1" <%= settings['vendors.enabled'] === '1' ? 'selected' : '' %>>Enabled</option>
        </select>
        <div class="form-text">Show / hide the Vendors section in the navigation.</div>
      </div>
      <div class="col-md-3">
        <label class="form-label">Enable Maintenance Section</label>
        <select name="maintenance.enabled" class="form-select">
          <option value="0" <%= settings['maintenance.enabled'] === '1' ? '' : 'selected' %>>Disabled</option>
          <option value="1" <%= settings['maintenance.enabled'] === '1' ? 'selected' : '' %>>Enabled</option>
        </select>
        <div class="form-text">Show / hide the Maintenance section in the navigation.</div>
      </div>
    </div>
  </div>

  <!-- OIDC / Entra ID -->
  <div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold"><i class="bi bi-microsoft me-2"></i>OIDC / Entra ID Authentication</div>
    <div class="card-body row g-3">
      <div class="col-md-3">
        <label class="form-label">Enable OIDC Login</label>
        <select name="oidc.enabled" class="form-select">
          <option value="0" <%= settings['oidc.enabled'] === '1' ? '' : 'selected' %>>Disabled</option>
          <option value="1" <%= settings['oidc.enabled'] === '1' ? 'selected' : '' %>>Enabled</option>
        </select>
      </div>
      <div class="col-md-9">
        <label class="form-label">Redirect URI</label>
        <input type="text" name="oidc.redirectUri" class="form-control" value="<%= settings['oidc.redirectUri'] || '' %>" placeholder="https://yourapp.example.com/auth/oidc/callback" />
      </div>
      <div class="col-md-4">
        <label class="form-label">Tenant ID</label>
        <input type="text" name="oidc.tenantId" class="form-control" value="<%= settings['oidc.tenantId'] || '' %>" />
      </div>
      <div class="col-md-4">
        <label class="form-label">Client ID</label>
        <input type="text" name="oidc.clientId" class="form-control" value="<%= settings['oidc.clientId'] || '' %>" />
      </div>
      <div class="col-md-4">
        <label class="form-label">Client Secret</label>
        <input type="password" name="oidc.clientSecret" class="form-control" placeholder="<%= settings['oidc.clientSecret'] ? '••••••' : 'Not set' %>" autocomplete="new-password" />
        <div class="form-text">Leave blank to keep existing secret.</div>
      </div>
    </div>
  </div>

  <!-- LDAP / Active Directory -->
  <div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold"><i class="bi bi-diagram-3 me-2"></i>Active Directory / LDAP</div>
    <div class="card-body row g-3">
      <div class="col-md-3">
        <label class="form-label">Enable AD Login</label>
        <select name="ldap.enabled" class="form-select">
          <option value="0" <%= settings['ldap.enabled'] === '1' ? '' : 'selected' %>>Disabled</option>
          <option value="1" <%= settings['ldap.enabled'] === '1' ? 'selected' : '' %>>Enabled</option>
        </select>
      </div>
      <div class="col-md-9">
        <label class="form-label">LDAP Server URL</label>
        <input type="text" name="ldap.url" class="form-control"
               value="<%= settings['ldap.url'] || '' %>" placeholder="dc.example.com or ldaps://dc.example.com:636" />
        <div class="form-text"><code>ldap://</code> is added automatically if omitted.</div>
      </div>
      <div class="col-md-6">
        <label class="form-label">Bind Username</label>
        <input type="text" name="ldap.bindDn" class="form-control"
               value="<%= settings['ldap.bindDn'] || '' %>" placeholder="binduser@example.com" />
        <div class="form-text">Account used to search the directory.</div>
      </div>
      <div class="col-md-6">
        <label class="form-label">Bind Password</label>
        <input type="password" name="ldap.bindCredentials" class="form-control"
               placeholder="<%= settings['ldap.bindCredentials'] ? '••••••' : 'Not set' %>"
               autocomplete="new-password" />
        <div class="form-text">Leave blank to keep existing password.</div>
      </div>
      <div class="col-md-6">
        <label class="form-label">Base DN for User Search</label>
        <input type="text" name="ldap.searchBase" class="form-control"
               value="<%= settings['ldap.searchBase'] || '' %>" placeholder="DC=example,DC=com" />
      </div>
      <div class="col-md-6">
        <label class="form-label">Search Filter</label>
        <input type="text" name="ldap.searchFilter" class="form-control"
               value="<%= settings['ldap.searchFilter'] || '(sAMAccountName={{username}})' %>"
               placeholder="(sAMAccountName={{username}})" />
        <div class="form-text"><code>{{username}}</code> is replaced with the entered username.</div>
      </div>
      <div class="col-md-3">
        <label class="form-label">Use STARTTLS</label>
        <select name="ldap.starttls" class="form-select">
          <option value="0" <%= settings['ldap.starttls'] === '1' ? '' : 'selected' %>>No</option>
          <option value="1" <%= settings['ldap.starttls'] === '1' ? 'selected' : '' %>>Yes</option>
        </select>
        <div class="form-text">Port 389 + TLS upgrade. Use <code>ldaps://</code> for port 636.</div>
      </div>
      <div class="col-md-3">
        <label class="form-label">Reject Unauthorized TLS</label>
        <select name="ldap.rejectUnauthorized" class="form-select">
          <option value="1" <%= settings['ldap.rejectUnauthorized'] === '0' ? '' : 'selected' %>>Yes (recommended)</option>
          <option value="0" <%= settings['ldap.rejectUnauthorized'] === '0' ? 'selected' : '' %>>No (allow self-signed)</option>
        </select>
      </div>
      <div class="col-12">
        <label class="form-label">Test Connection</label>
        <div class="d-flex gap-2 align-items-center">
          <input type="text" id="ldapTestUser" class="form-control" placeholder="AD username" style="max-width:220px" />
          <button type="button" class="btn btn-outline-secondary btn-sm" id="testLdapBtn">
            <i class="bi bi-plug me-1"></i>Test
          </button>
          <span id="ldapTestResult" class="small"></span>
        </div>
        <div class="form-text">Save settings first, then enter a username to verify the connection.</div>
      </div>
    </div>
  </div>

  <!-- Email Settings link -->
  <div class="card shadow-sm mb-4 border-0 bg-body-secondary">
    <div class="card-body d-flex align-items-center gap-3 py-3">
      <i class="bi bi-envelope fs-3 text-primary"></i>
      <div class="flex-grow-1">
        <div class="fw-semibold">Email &amp; Notification Settings</div>
        <div class="text-muted small">Configure SMTP, reminder thresholds, and notification email templates.</div>
      </div>
      <a href="/admin/email-settings" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-envelope-gear me-1"></i>Email Settings
      </a>
      <a href="/admin/email-templates" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-file-earmark-text me-1"></i>Email Templates
      </a>
    </div>
  </div>

  <!-- Logs & Audit -->
  <div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold"><i class="bi bi-journal-text me-2"></i>Logs &amp; Audit</div>
    <div class="card-body row g-3">
      <div class="col-md-3">
        <label class="form-label">App Log Retention (days)</label>
        <input type="number" name="logs.appRetentionDays" class="form-control"
               value="<%= settings['logs.appRetentionDays'] || '30' %>" min="1" />
        <div class="form-text">How many days to keep <code>app-*.log</code> files.</div>
      </div>
      <div class="col-md-3">
        <label class="form-label">Error Log Retention (days)</label>
        <input type="number" name="logs.errorRetentionDays" class="form-control"
               value="<%= settings['logs.errorRetentionDays'] || '90' %>" min="1" />
        <div class="form-text">How many days to keep <code>error-*.log</code> files.</div>
      </div>
      <div class="col-md-3">
        <label class="form-label">Audit Log Retention (days)</label>
        <input type="number" name="audit.retentionDays" class="form-control"
               value="<%= settings['audit.retentionDays'] || '365' %>" min="0" />
        <div class="form-text">Days to keep audit records. <code>0</code> = keep forever.</div>
      </div>
      <div class="col-12">
        <a href="/admin/logs" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-folder2-open me-1"></i>Browse &amp; Download Log Files
        </a>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i>Save All Settings</button>
    <a href="/admin" class="btn btn-outline-secondary">Cancel</a>
  </div>
</form>

<script>
document.getElementById('testLdapBtn').addEventListener('click', async () => {
  const btn      = document.getElementById('testLdapBtn');
  const result   = document.getElementById('ldapTestResult');
  const username = document.getElementById('ldapTestUser').value.trim();
  btn.disabled = true;
  result.textContent = 'Testing...';
  result.className = 'small text-muted';
  try {
    const res  = await fetch('/admin/settings/ldap/test', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username }),
    });
    const data = await res.json();
    result.textContent = data.message;
    result.className   = 'small ' + (data.success ? 'text-success' : 'text-danger');
  } catch (e) {
    result.textContent = 'Request failed.';
    result.className   = 'small text-danger';
  } finally {
    btn.disabled = false;
  }
});
</script>
