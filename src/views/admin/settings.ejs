<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0"><i class="bi bi-gear me-2"></i>Settings</h1>
  <a href="/admin" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<form action="/admin/settings" method="POST">
  <!-- General -->
  <div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold"><i class="bi bi-sliders me-2"></i>General</div>
    <div class="card-body row g-3">
      <div class="col-md-4">
        <label class="form-label">Application Name</label>
        <input type="text" name="app.name" class="form-control"
               value="<%= settings['app.name'] || 'SiteMaintenance' %>"
               placeholder="SiteMaintenance" maxlength="80" />
        <div class="form-text">Displayed in the top-left navigation bar.</div>
      </div>
    </div>
  </div>

  <!-- OIDC / Entra ID -->
  <div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold"><i class="bi bi-microsoft me-2"></i>OIDC / Entra ID Authentication</div>
    <div class="card-body row g-3">
      <div class="col-md-3">
        <label class="form-label">Enable OIDC Login</label>
        <select name="oidc.enabled" class="form-select">
          <option value="0" <%= settings['oidc.enabled'] === '1' ? '' : 'selected' %>>Disabled</option>
          <option value="1" <%= settings['oidc.enabled'] === '1' ? 'selected' : '' %>>Enabled</option>
        </select>
      </div>
      <div class="col-md-9">
        <label class="form-label">Redirect URI</label>
        <input type="text" name="oidc.redirectUri" class="form-control" value="<%= settings['oidc.redirectUri'] || '' %>" placeholder="https://yourapp.example.com/auth/oidc/callback" />
      </div>
      <div class="col-md-4">
        <label class="form-label">Tenant ID</label>
        <input type="text" name="oidc.tenantId" class="form-control" value="<%= settings['oidc.tenantId'] || '' %>" />
      </div>
      <div class="col-md-4">
        <label class="form-label">Client ID</label>
        <input type="text" name="oidc.clientId" class="form-control" value="<%= settings['oidc.clientId'] || '' %>" />
      </div>
      <div class="col-md-4">
        <label class="form-label">Client Secret</label>
        <input type="password" name="oidc.clientSecret" class="form-control" placeholder="<%= settings['oidc.clientSecret'] ? '••••••' : 'Not set' %>" autocomplete="new-password" />
        <div class="form-text">Leave blank to keep existing secret.</div>
      </div>
    </div>
  </div>

  <!-- LDAP / Active Directory -->
  <div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold"><i class="bi bi-diagram-3 me-2"></i>Active Directory / LDAP</div>
    <div class="card-body p-0">
      <p class="px-3 pt-3 mb-0 text-muted small">Changes to LDAP settings require a server restart to take effect.</p>

      <%
        function ldapRow(label, desc, inputHtml) {
          return `<div class="d-flex align-items-center border-top px-3 py-3 gap-3">
            <div style="min-width:260px">
              <div class="fw-semibold small">${label}</div>
              <div class="text-muted" style="font-size:0.78rem">${desc}</div>
            </div>
            <div class="flex-grow-1">${inputHtml}</div>
          </div>`;
        }
      %>

      <!-- Enable toggle -->
      <div class="d-flex align-items-center border-top px-3 py-3 gap-3">
        <div style="min-width:260px">
          <div class="fw-semibold small">Enable Active Directory Login</div>
          <div class="text-muted" style="font-size:0.78rem">Allow users with auth type "Active Directory (LDAP)" to sign in via on-premises AD</div>
        </div>
        <div class="flex-grow-1 d-flex justify-content-end">
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch"
                   name="ldap.enabled" value="1" style="width:3rem;height:1.5rem"
                   <%= settings['ldap.enabled'] === '1' ? 'checked' : '' %>>
          </div>
        </div>
      </div>

      <!-- LDAP Server URL -->
      <div class="d-flex align-items-center border-top px-3 py-3 gap-3">
        <div style="min-width:260px">
          <div class="fw-semibold small">LDAP Server URL</div>
          <div class="text-muted" style="font-size:0.78rem">
            Hostname, IP, or full URL of your domain controller. <code>ldap://</code> is added automatically if
            omitted — e.g. <code>dc.example.com</code> or <code>ldaps://dc.example.com:636</code>
          </div>
        </div>
        <div class="flex-grow-1">
          <input type="text" name="ldap.url" class="form-control"
                 value="<%= settings['ldap.url'] || '' %>" placeholder="dc.example.com" />
        </div>
      </div>

      <!-- Bind Username -->
      <div class="d-flex align-items-center border-top px-3 py-3 gap-3">
        <div style="min-width:260px">
          <div class="fw-semibold small">LDAP Bind Username</div>
          <div class="text-muted" style="font-size:0.78rem">
            Account used to search the directory — e.g. <code>binduser@example.com</code> or
            <code>CN=binduser,DC=example,DC=com</code>
          </div>
        </div>
        <div class="flex-grow-1">
          <input type="text" name="ldap.bindDn" class="form-control"
                 value="<%= settings['ldap.bindDn'] || '' %>" placeholder="binduser@example.com" />
        </div>
      </div>

      <!-- Bind Password -->
      <div class="d-flex align-items-center border-top px-3 py-3 gap-3">
        <div style="min-width:260px">
          <div class="fw-semibold small">LDAP Bind Password</div>
          <div class="text-muted" style="font-size:0.78rem">Password for the bind account</div>
        </div>
        <div class="flex-grow-1">
          <input type="password" name="ldap.bindCredentials" class="form-control"
                 placeholder="<%= settings['ldap.bindCredentials'] ? '••••••••••••••••••••' : 'Not set' %>"
                 autocomplete="new-password" />
        </div>
      </div>

      <!-- Search Base -->
      <div class="d-flex align-items-center border-top px-3 py-3 gap-3">
        <div style="min-width:260px">
          <div class="fw-semibold small">Base DN for User Search</div>
          <div class="text-muted" style="font-size:0.78rem">
            The LDAP subtree to search for users — e.g. <code>DC=example,DC=com</code>
          </div>
        </div>
        <div class="flex-grow-1">
          <input type="text" name="ldap.searchBase" class="form-control"
                 value="<%= settings['ldap.searchBase'] || '' %>" placeholder="DC=example,DC=com" />
        </div>
      </div>

      <!-- Search Filter -->
      <div class="d-flex align-items-center border-top px-3 py-3 gap-3">
        <div style="min-width:260px">
          <div class="fw-semibold small">Search Filter</div>
          <div class="text-muted" style="font-size:0.78rem">
            How to find the user — <code>&#123;&#123;username&#125;&#125;</code> is replaced with the entered username
          </div>
        </div>
        <div class="flex-grow-1">
          <input type="text" name="ldap.searchFilter" class="form-control"
                 value="<%= settings['ldap.searchFilter'] || '(sAMAccountName={{username}})' %>"
                 placeholder="(sAMAccountName={{username}})" />
        </div>
      </div>

      <!-- STARTTLS -->
      <div class="d-flex align-items-center border-top px-3 py-3 gap-3">
        <div style="min-width:260px">
          <div class="fw-semibold small">Use STARTTLS (port 389 + TLS upgrade)</div>
          <div class="text-muted" style="font-size:0.78rem">Enable if your DC requires encrypted searches on port 389. Use <code>ldaps://</code> instead for port 636 SSL.</div>
        </div>
        <div class="flex-grow-1 d-flex justify-content-end">
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch"
                   name="ldap.starttls" value="1" style="width:3rem;height:1.5rem"
                   <%= settings['ldap.starttls'] === '1' ? 'checked' : '' %>>
          </div>
        </div>
      </div>

      <!-- Reject Unauthorized TLS -->
      <div class="d-flex align-items-center border-top px-3 py-3 gap-3">
        <div style="min-width:260px">
          <div class="fw-semibold small">Reject Unauthorized TLS</div>
          <div class="text-muted" style="font-size:0.78rem">Reject self-signed or untrusted certificates (disable only for testing)</div>
        </div>
        <div class="flex-grow-1 d-flex justify-content-end">
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch"
                   name="ldap.rejectUnauthorized" value="1" style="width:3rem;height:1.5rem"
                   <%= (settings['ldap.rejectUnauthorized'] === '0') ? '' : 'checked' %>>
          </div>
        </div>
      </div>

      <!-- Test Connection -->
      <div class="d-flex align-items-center border-top px-3 py-3 gap-3">
        <div style="min-width:260px">
          <div class="fw-semibold small">Test Connection</div>
          <div class="text-muted" style="font-size:0.78rem">
            Save settings first. Enter a username to verify the server is reachable and the account can be found.
          </div>
        </div>
        <div class="flex-grow-1 d-flex gap-2 align-items-center">
          <input type="text" id="ldapTestUser" class="form-control" placeholder="AD username" style="max-width:220px" />
          <button type="button" class="btn btn-secondary btn-sm px-3" id="testLdapBtn">Test</button>
          <span id="ldapTestResult" class="small"></span>
        </div>
      </div>

    </div>
  </div>

  <!-- Email -->
  <div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold"><i class="bi bi-envelope me-2"></i>Email / SMTP Notifications</div>
    <div class="card-body row g-3">
      <div class="col-md-3">
        <label class="form-label">Enable Email</label>
        <select name="email.enabled" class="form-select">
          <option value="0" <%= settings['email.enabled'] === '1' ? '' : 'selected' %>>Disabled</option>
          <option value="1" <%= settings['email.enabled'] === '1' ? 'selected' : '' %>>Enabled</option>
        </select>
      </div>
      <div class="col-md-5">
        <label class="form-label">SMTP Host</label>
        <input type="text" name="email.host" class="form-control" value="<%= settings['email.host'] || '' %>" placeholder="smtp.office365.com" />
      </div>
      <div class="col-md-2">
        <label class="form-label">Port</label>
        <input type="number" name="email.port" class="form-control" value="<%= settings['email.port'] || '587' %>" />
      </div>
      <div class="col-md-2">
        <label class="form-label">Use TLS</label>
        <select name="email.secure" class="form-select">
          <option value="none" <%= settings['email.secure'] === 'none' ? 'selected' : '' %>>None (port 25)</option>
          <option value="0" <%= (!settings['email.secure'] || settings['email.secure'] === '0') ? 'selected' : '' %>>STARTTLS (port 587)</option>
          <option value="1" <%= settings['email.secure'] === '1' ? 'selected' : '' %>>TLS/SSL (port 465)</option>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">SMTP Username</label>
        <input type="text" name="email.user" class="form-control" value="<%= settings['email.user'] || '' %>" />
      </div>
      <div class="col-md-4">
        <label class="form-label">SMTP Password</label>
        <input type="password" name="email.password" class="form-control" placeholder="<%= settings['email.password'] ? '••••••' : 'Not set' %>" autocomplete="new-password" />
      </div>
      <div class="col-md-4">
        <label class="form-label">From Address</label>
        <input type="email" name="email.fromAddress" class="form-control" value="<%= settings['email.fromAddress'] || '' %>" />
      </div>
      <div class="col-md-4">
        <label class="form-label">From Name</label>
        <input type="text" name="email.fromName" class="form-control" value="<%= settings['email.fromName'] || 'SiteMaintenance' %>" />
      </div>
      <div class="col-12">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="testEmailBtn">
          <i class="bi bi-send me-1"></i>Send Test Email
        </button>
        <span id="emailTestResult" class="ms-3 small"></span>
      </div>
      <div class="col-12"><hr class="my-1" /><strong class="small text-muted">Reminder Thresholds</strong></div>
      <div class="col-md-4">
        <label class="form-label">PM Reminder (days before due)</label>
        <input type="number" name="email.pmReminderDays" class="form-control" value="<%= settings['email.pmReminderDays'] || '14' %>" min="1" />
      </div>
      <div class="col-md-4">
        <label class="form-label">Warranty Reminder (days before expiry)</label>
        <input type="number" name="email.warrantyReminderDays" class="form-control" value="<%= settings['email.warrantyReminderDays'] || '30' %>" min="1" />
      </div>
      <div class="col-md-4">
        <label class="form-label">Checkout Reminder (days before alert)</label>
        <input type="number" name="email.checkoutReminderDays" class="form-control" value="<%= settings['email.checkoutReminderDays'] || '30' %>" min="1" />
      </div>
    </div>
  </div>

  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i>Save All Settings</button>
    <a href="/admin" class="btn btn-outline-secondary">Cancel</a>
  </div>
</form>

<script>
document.getElementById('testEmailBtn').addEventListener('click', async () => {
  const btn = document.getElementById('testEmailBtn');
  const result = document.getElementById('emailTestResult');
  btn.disabled = true;
  result.textContent = 'Sending...';
  try {
    const res = await fetch('/admin/settings/email/test', { method: 'POST' });
    const data = await res.json();
    result.textContent = data.message;
    result.className = 'ms-3 small ' + (data.success ? 'text-success' : 'text-danger');
  } catch (e) {
    result.textContent = 'Request failed.';
    result.className = 'ms-3 small text-danger';
  } finally {
    btn.disabled = false;
  }
});

document.getElementById('testLdapBtn').addEventListener('click', async () => {
  const btn      = document.getElementById('testLdapBtn');
  const result   = document.getElementById('ldapTestResult');
  const username = document.getElementById('ldapTestUser').value.trim();
  btn.disabled = true;
  result.textContent = 'Testing...';
  result.className = 'small text-muted';
  try {
    const res  = await fetch('/admin/settings/ldap/test', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username }),
    });
    const data = await res.json();
    result.textContent = data.message;
    result.className   = 'small ' + (data.success ? 'text-success' : 'text-danger');
  } catch (e) {
    result.textContent = 'Request failed.';
    result.className   = 'small text-danger';
  } finally {
    btn.disabled = false;
  }
});
</script>
