<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0"><i class="bi bi-envelope me-2"></i>Email Settings</h1>
  <a href="/admin" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<form action="/admin/email-settings" method="POST">

  <!-- SMTP -->
  <div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold"><i class="bi bi-server me-2"></i>SMTP Configuration</div>
    <div class="card-body row g-3">
      <div class="col-md-3">
        <label class="form-label">Enable Email</label>
        <select name="email.enabled" class="form-select">
          <option value="0" <%= settings['email.enabled'] === '1' ? '' : 'selected' %>>Disabled</option>
          <option value="1" <%= settings['email.enabled'] === '1' ? 'selected' : '' %>>Enabled</option>
        </select>
      </div>
      <div class="col-md-5">
        <label class="form-label">SMTP Host</label>
        <input type="text" name="email.host" class="form-control" value="<%= settings['email.host'] || '' %>" placeholder="smtp.office365.com" />
      </div>
      <div class="col-md-2">
        <label class="form-label">Port</label>
        <input type="number" name="email.port" class="form-control" value="<%= settings['email.port'] || '587' %>" />
      </div>
      <div class="col-md-2">
        <label class="form-label">Use TLS</label>
        <select name="email.secure" class="form-select">
          <option value="none" <%= settings['email.secure'] === 'none' ? 'selected' : '' %>>None (port 25)</option>
          <option value="0" <%= (!settings['email.secure'] || settings['email.secure'] === '0') ? 'selected' : '' %>>STARTTLS (port 587)</option>
          <option value="1" <%= settings['email.secure'] === '1' ? 'selected' : '' %>>TLS/SSL (port 465)</option>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">SMTP Username</label>
        <input type="text" name="email.user" class="form-control" value="<%= settings['email.user'] || '' %>" />
      </div>
      <div class="col-md-4">
        <label class="form-label">SMTP Password</label>
        <input type="password" name="email.password" class="form-control"
               placeholder="<%= settings['email.password'] ? '••••••' : 'Not set' %>"
               autocomplete="new-password" />
        <div class="form-text">Leave blank to keep the existing password.</div>
      </div>
      <div class="col-md-4">
        <label class="form-label">From Address</label>
        <input type="email" name="email.fromAddress" class="form-control" value="<%= settings['email.fromAddress'] || '' %>" />
      </div>
      <div class="col-md-4">
        <label class="form-label">From Name</label>
        <input type="text" name="email.fromName" class="form-control" value="<%= settings['email.fromName'] || 'SiteMaintenance' %>" />
      </div>
      <div class="col-12">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="testEmailBtn">
          <i class="bi bi-send me-1"></i>Send Test Email
        </button>
        <span id="emailTestResult" class="ms-3 small"></span>
      </div>
    </div>
  </div>

  <!-- Reminder Thresholds -->
  <div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold"><i class="bi bi-bell me-2"></i>Reminder Thresholds</div>
    <div class="card-body row g-3">
      <div class="col-md-4">
        <label class="form-label">PM Reminder (days before due)</label>
        <input type="number" name="email.pmReminderDays" class="form-control"
               value="<%= settings['email.pmReminderDays'] || '14' %>" min="1" />
      </div>
      <div class="col-md-4">
        <label class="form-label">Warranty Reminder (days before expiry)</label>
        <input type="number" name="email.warrantyReminderDays" class="form-control"
               value="<%= settings['email.warrantyReminderDays'] || '30' %>" min="1" />
      </div>
      <div class="col-md-4">
        <label class="form-label">Repair Overdue (repeat every N days)</label>
        <input type="number" name="email.repairReminderIntervalDays" class="form-control"
               value="<%= settings['email.repairReminderIntervalDays'] || '3' %>" min="1" />
        <div class="form-text">After Expected Return Date passes, remind every this many days.</div>
      </div>
      <div class="col-md-4">
        <label class="form-label">Unsent RMA (repeat every N days)</label>
        <input type="number" name="email.unsentRmaReminderDays" class="form-control"
               value="<%= settings['email.unsentRmaReminderDays'] || '3' %>" min="1" />
        <div class="form-text">Remind assigned user while an RMA has no Sent Date.</div>
      </div>
      <div class="col-md-4">
        <label class="form-label">System Key Expiry (days before expiry)</label>
        <input type="number" name="email.systemKeyReminderDays" class="form-control"
               value="<%= settings['email.systemKeyReminderDays'] || '30' %>" min="1" />
      </div>
      <div class="col-md-4">
        <label class="form-label">Maintenance Reminder (repeat every N days)</label>
        <input type="number" name="email.maintenanceReminderDays" class="form-control"
               value="<%= settings['email.maintenanceReminderDays'] || '3' %>" min="1" />
        <div class="form-text">Email assigned user this often while item is open and not yet due.</div>
      </div>
      <div class="col-md-4">
        <label class="form-label">Maintenance Overdue (repeat every N days)</label>
        <input type="number" name="email.maintenanceOverdueDays" class="form-control"
               value="<%= settings['email.maintenanceOverdueDays'] || '1' %>" min="0" />
        <div class="form-text">Email after due date passes. Set to <code>0</code> to disable.</div>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i>Save Email Settings</button>
    <a href="/admin/email-templates" class="btn btn-outline-secondary">
      <i class="bi bi-file-earmark-text me-1"></i>Edit Email Templates
    </a>
    <a href="/admin" class="btn btn-outline-secondary">Cancel</a>
  </div>
</form>

<script>
document.getElementById('testEmailBtn').addEventListener('click', async () => {
  const btn    = document.getElementById('testEmailBtn');
  const result = document.getElementById('emailTestResult');
  btn.disabled = true;
  result.textContent = 'Sending...';
  try {
    const res  = await fetch('/admin/settings/email/test', { method: 'POST' });
    const data = await res.json();
    result.textContent = data.message;
    result.className = 'ms-3 small ' + (data.success ? 'text-success' : 'text-danger');
  } catch (e) {
    result.textContent = 'Request failed.';
    result.className = 'ms-3 small text-danger';
  } finally {
    btn.disabled = false;
  }
});
</script>
