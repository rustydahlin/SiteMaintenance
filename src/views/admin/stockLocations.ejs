<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0"><i class="bi bi-geo-alt me-2"></i>Stock Locations</h1>
  <a href="/admin" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>
<div class="row g-4">
  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-header" id="formTitle">Add Location</div>
      <div class="card-body">
        <form action="/admin/stock-locations" method="POST" id="locForm">
          <input type="hidden" name="id" id="locID" value="" />
          <div class="mb-3">
            <label class="form-label">Location Name <span class="text-danger">*</span></label>
            <input type="text" name="locationName" id="locName" class="form-control" required maxlength="150" />
          </div>
          <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea name="description" id="locDesc" class="form-control" rows="2" maxlength="500"></textarea>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm" id="submitBtn">Add</button>
            <button type="button" class="btn btn-outline-secondary btn-sm d-none" id="cancelBtn">Cancel</button>
          </div>
        </form>
      </div>
    </div>
  </div>
  <div class="col-md-8">
    <div class="card shadow-sm">
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
          <thead><tr><th>Name</th><th>Description</th><th>Status</th><th></th></tr></thead>
          <tbody>
            <% locations.forEach(l => { %>
            <tr class="<%= l.IsActive ? '' : 'text-muted' %>">
              <td><%= l.LocationName %></td>
              <td class="small"><%= l.Description || '—' %></td>
              <td><span class="badge <%= l.IsActive ? 'bg-success' : 'bg-secondary' %>"><%= l.IsActive ? 'Active' : 'Inactive' %></span></td>
              <td class="text-end">
                <button type="button" class="btn btn-sm btn-outline-primary py-0 me-1 js-edit"
                  data-id="<%= l.LocationID %>"
                  data-name="<%= l.LocationName %>"
                  data-desc="<%= l.Description || '' %>">
                  <i class="bi bi-pencil"></i>
                </button>
                <form action="/admin/stock-locations" method="POST" class="d-inline">
                  <input type="hidden" name="id" value="<%= l.LocationID %>" />
                  <input type="hidden" name="action" value="toggle" />
                  <button type="submit" class="btn btn-sm btn-outline-secondary py-0"><%= l.IsActive ? 'Disable' : 'Enable' %></button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('.js-edit').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.getElementById('locID').value   = this.dataset.id;
    document.getElementById('locName').value = this.dataset.name;
    document.getElementById('locDesc').value = this.dataset.desc;
    document.getElementById('formTitle').textContent = 'Edit Location';
    document.getElementById('submitBtn').textContent = 'Save Changes';
    document.getElementById('cancelBtn').classList.remove('d-none');
    document.getElementById('locName').focus();
  });
});

document.getElementById('cancelBtn').addEventListener('click', function() {
  document.getElementById('locForm').reset();
  document.getElementById('locID').value = '';
  document.getElementById('formTitle').textContent = 'Add Location';
  document.getElementById('submitBtn').textContent = 'Add';
  this.classList.add('d-none');
});
</script>
