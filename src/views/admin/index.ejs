<h1 class="h3 mb-4"><i class="bi bi-sliders me-2"></i>Administration</h1>

<div class="row g-3">
  <% if (!isNetworkMapUpdater) { %>
  <div class="col-sm-6 col-xl-4">
    <a href="/admin/users" class="card shadow-sm text-decoration-none text-body h-100">
      <div class="card-body">
        <i class="bi bi-people fs-2 text-primary"></i>
        <h5 class="mt-2">Users</h5>
        <p class="text-muted small mb-0">Manage user accounts and role assignments</p>
      </div>
    </a>
  </div>
  <div class="col-sm-6 col-xl-4">
    <a href="/admin/settings" class="card shadow-sm text-decoration-none text-body h-100">
      <div class="card-body">
        <i class="bi bi-gear fs-2 text-primary"></i>
        <h5 class="mt-2">Settings</h5>
        <p class="text-muted small mb-0">Configure authentication (OIDC, LDAP), logs, and general options</p>
      </div>
    </a>
  </div>

  <div class="col-sm-6 col-xl-4">
    <a href="/admin/audit" class="card shadow-sm text-decoration-none text-body h-100">
      <div class="card-body">
        <i class="bi bi-journal-check fs-2 text-primary"></i>
        <h5 class="mt-2">Audit Log</h5>
        <p class="text-muted small mb-0">Review all user actions and system changes</p>
      </div>
    </a>
  </div>
  <div class="col-sm-6 col-xl-4">
    <a href="/admin/site-types" class="card shadow-sm text-decoration-none text-body h-100">
      <div class="card-body">
        <i class="bi bi-tags fs-2 text-secondary"></i>
        <h5 class="mt-2">Site Types</h5>
        <p class="text-muted small mb-0">Define the types of sites in your system</p>
      </div>
    </a>
  </div>
  <div class="col-sm-6 col-xl-4">
    <a href="/admin/inventory" class="card shadow-sm text-decoration-none text-body h-100">
      <div class="card-body">
        <i class="bi bi-box-seam fs-2 text-secondary"></i>
        <h5 class="mt-2">Inventory</h5>
        <p class="text-muted small mb-0">Categories, stock locations, common names, model numbers, and manufacturers</p>
      </div>
    </a>
  </div>
  <div class="col-sm-6 col-xl-4">
    <a href="/admin/log-types" class="card shadow-sm text-decoration-none text-body h-100">
      <div class="card-body">
        <i class="bi bi-journal-text fs-2 text-secondary"></i>
        <h5 class="mt-2">Log Types</h5>
        <p class="text-muted small mb-0">Configure categories for log entries</p>
      </div>
    </a>
  </div>
  <div class="col-sm-6 col-xl-4">
    <a href="/admin/key-manufacturers" class="card shadow-sm text-decoration-none text-body h-100">
      <div class="card-body">
        <i class="bi bi-building fs-2 text-secondary"></i>
        <h5 class="mt-2">Key Manufacturers</h5>
        <p class="text-muted small mb-0">Manage manufacturers for system keys</p>
      </div>
    </a>
  </div>
  <div class="col-sm-6 col-xl-4">
    <a href="/admin/maintenance-types" class="card shadow-sm text-decoration-none text-body h-100">
      <div class="card-body">
        <i class="bi bi-tools fs-2 text-secondary"></i>
        <h5 class="mt-2">Maintenance Types</h5>
        <p class="text-muted small mb-0">Define types of maintenance work items</p>
      </div>
    </a>
  </div>
  <% } %>

  <div class="col-12 mt-2"><h6 class="text-muted text-uppercase small fw-semibold mb-0">Network / Tower Map</h6></div>

  <div class="col-sm-6 col-xl-4">
    <a href="/admin/monitoring-location-types" class="card shadow-sm text-decoration-none text-body h-100">
      <div class="card-body">
        <i class="bi bi-broadcast-pin fs-2 text-secondary"></i>
        <h5 class="mt-2">Monitoring Location Types</h5>
        <p class="text-muted small mb-0">Tower, PSAP, and other site classifications for the tower map</p>
      </div>
    </a>
  </div>
  <div class="col-sm-6 col-xl-4">
    <a href="/admin/network-device-types" class="card shadow-sm text-decoration-none text-body h-100">
      <div class="card-body">
        <i class="bi bi-hdd-network fs-2 text-secondary"></i>
        <h5 class="mt-2">Network Device Types</h5>
        <p class="text-muted small mb-0">SRX, MRG, CradlePoint, Peplink, and other device type labels</p>
      </div>
    </a>
  </div>
  <div class="col-sm-6 col-xl-4">
    <a href="/admin/circuit-types" class="card shadow-sm text-decoration-none text-body h-100">
      <div class="card-body">
        <i class="bi bi-diagram-2 fs-2 text-secondary"></i>
        <h5 class="mt-2">Circuit Types</h5>
        <p class="text-muted small mb-0">Fiber, Microwave, Satellite, and other circuit classifications</p>
      </div>
    </a>
  </div>
  <div class="col-sm-6 col-xl-4">
    <a href="/admin/network-resources-import" class="card shadow-sm text-decoration-none text-body h-100">
      <div class="card-body">
        <i class="bi bi-cloud-upload fs-2 text-secondary"></i>
        <h5 class="mt-2">Network Resources Import / Export</h5>
        <p class="text-muted small mb-0">Bulk-import from or export to a devices.json file</p>
      </div>
    </a>
  </div>
</div>
