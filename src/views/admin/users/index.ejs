<%
  const curSort = typeof sort !== 'undefined' ? sort : 'displayName';
  const curDir  = typeof dir  !== 'undefined' ? dir  : 'asc';
  function sortLink(col) {
    const newDir = (curSort === col && curDir === 'asc') ? 'desc' : 'asc';
    return `/admin/users?sort=${col}&dir=${newDir}`;
  }
  function sortIcon(col) {
    if (curSort !== col) return '<i class="bi bi-arrow-down-up text-muted ms-1 small opacity-50"></i>';
    return curDir === 'asc'
      ? '<i class="bi bi-sort-up ms-1 small"></i>'
      : '<i class="bi bi-sort-down ms-1 small"></i>';
  }
%>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0"><i class="bi bi-people me-2"></i>Users</h1>
  <div class="d-flex gap-2">
    <a href="/admin/users/new" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>New User</a>
    <a href="/admin" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
  </div>
</div>

<div class="card shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th><a href="<%- sortLink('displayName') %>" class="text-decoration-none text-body">Display Name<%- sortIcon('displayName') %></a></th>
          <th><a href="<%- sortLink('username') %>" class="text-decoration-none text-body">Username<%- sortIcon('username') %></a></th>
          <th><a href="<%- sortLink('email') %>" class="text-decoration-none text-body">Email<%- sortIcon('email') %></a></th>
          <th><a href="<%- sortLink('auth') %>" class="text-decoration-none text-body">Auth<%- sortIcon('auth') %></a></th>
          <th>Roles</th>
          <th><a href="<%- sortLink('status') %>" class="text-decoration-none text-body">Status<%- sortIcon('status') %></a></th>
          <th><a href="<%- sortLink('lastLogin') %>" class="text-decoration-none text-body">Last Login<%- sortIcon('lastLogin') %></a></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
        <tr class="<%= u.DeletedAt ? 'text-muted fst-italic opacity-50' : (u.IsActive ? '' : 'text-muted') %>">
          <td><%= u.DisplayName %></td>
          <td class="small"><%= u.Username %></td>
          <td class="small"><%= u.Email || '—' %></td>
          <td>
            <% if (!u.DeletedAt) { %>
            <span class="badge <%=
              u.AuthProvider === 'oidc' ? 'bg-info text-dark' :
              u.AuthProvider === 'ldap' ? 'bg-warning text-dark' :
              'bg-secondary'
            %>"><%= u.AuthProvider %></span>
            <% } else { %>—<% } %>
          </td>
          <td>
            <% if (!u.DeletedAt) { %>
              <% (u.roles || []).forEach(r => { %>
                <span class="badge <%= r === 'Admin' ? 'bg-danger' : 'bg-primary' %> me-1"><%= r %></span>
              <% }) %>
            <% } %>
          </td>
          <td>
            <% if (u.DeletedAt) { %>
              <span class="badge bg-dark">Deleted</span>
            <% } else { %>
              <span class="badge <%= u.IsActive ? 'bg-success' : 'bg-secondary' %>"><%= u.IsActive ? 'Active' : 'Inactive' %></span>
            <% } %>
          </td>
          <td class="small text-muted"><%= u.LastLoginAt ? new Date(u.LastLoginAt).toLocaleDateString() : 'Never' %></td>
          <td class="text-end">
            <% if (u.DeletedAt) { %>
              <form action="/admin/users/<%= u.UserID %>/restore" method="POST" class="d-inline"
                    data-confirm="Restore <%= u.DisplayName %>? They will be active but have no password — set one after restoring.">
                <button type="submit" class="btn btn-sm btn-outline-success py-0">Restore</button>
              </form>
            <% } else { %>
              <a href="/admin/users/<%= u.UserID %>/edit" class="btn btn-sm btn-outline-secondary py-0 me-1">Edit</a>
              <% if (u.UserID !== user.UserID) { %>
                <form action="/admin/users/<%= u.UserID %>/toggle" method="POST" class="d-inline"
                      data-confirm="<%= u.IsActive ? 'Deactivate this user?' : 'Activate this user?' %>">
                  <button type="submit" class="btn btn-sm <%= u.IsActive ? 'btn-outline-warning' : 'btn-outline-success' %> py-0">
                    <%= u.IsActive ? 'Deactivate' : 'Activate' %>
                  </button>
                </form>
                <form action="/admin/users/<%= u.UserID %>/delete" method="POST" class="d-inline"
                      data-confirm="Delete <%= u.DisplayName %>? If they have any history, their name will be preserved but they cannot log in. This cannot be undone.">
                  <button type="submit" class="btn btn-sm btn-outline-danger py-0 ms-1">Delete</button>
                </form>
              <% } %>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
