<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0"><i class="bi bi-people me-2"></i>Users</h1>
  <div class="d-flex gap-2">
    <a href="/admin/users/new" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>New User</a>
    <a href="/admin" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
  </div>
</div>

<div class="card shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th>Display Name</th>
          <th>Username</th>
          <th>Email</th>
          <th>Auth</th>
          <th>Roles</th>
          <th>Status</th>
          <th>Last Login</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
        <tr class="<%= u.IsActive ? '' : 'text-muted' %>">
          <td><%= u.DisplayName %></td>
          <td class="small"><%= u.Username %></td>
          <td class="small"><%= u.Email || '—' %></td>
          <td>
            <span class="badge <%=
              u.AuthProvider === 'oidc' ? 'bg-info text-dark' :
              u.AuthProvider === 'ldap' ? 'bg-warning text-dark' :
              'bg-secondary'
            %>"><%= u.AuthProvider %></span>
          </td>
          <td>
            <% (u.roles || []).forEach(r => { %>
              <span class="badge <%= r === 'Admin' ? 'bg-danger' : 'bg-primary' %> me-1"><%= r %></span>
            <% }) %>
          </td>
          <td><span class="badge <%= u.IsActive ? 'bg-success' : 'bg-secondary' %>"><%= u.IsActive ? 'Active' : 'Inactive' %></span></td>
          <td class="small text-muted"><%= u.LastLoginAt ? new Date(u.LastLoginAt).toLocaleDateString() : 'Never' %></td>
          <td class="text-end">
            <a href="/admin/users/<%= u.UserID %>/edit" class="btn btn-sm btn-outline-secondary py-0 me-1">Edit</a>
            <% if (u.UserID !== user.UserID) { %>
            <form action="/admin/users/<%= u.UserID %>/toggle" method="POST" class="d-inline"
                  data-confirm="<%= u.IsActive ? 'Deactivate this user?' : 'Activate this user?' %>">
              <button type="submit" class="btn btn-sm <%= u.IsActive ? 'btn-outline-danger' : 'btn-outline-success' %> py-0">
                <%= u.IsActive ? 'Deactivate' : 'Activate' %>
              </button>
            </form>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
