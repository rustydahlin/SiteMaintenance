<style>
.role-card { cursor: pointer; transition: border-color 0.15s, background-color 0.15s; }
.role-card:hover { border-color: var(--bs-primary) !important; }
</style>

<script>
(function () {
  <% if (!editUser) { %>
  const providerSelect = document.getElementById('authProviderSelect');
  const passwordField  = document.getElementById('passwordField');
  const passwordInput  = document.getElementById('passwordInput');

  function togglePassword() {
    const isLocal = providerSelect.value === 'local';
    passwordField.style.display = isLocal ? '' : 'none';
    passwordInput.required = isLocal;
  }
  providerSelect.addEventListener('change', togglePassword);
  togglePassword();
  <% } %>

  // Role card highlight toggle
  document.querySelectorAll('.role-card input[type=checkbox]').forEach(cb => {
    cb.addEventListener('change', function () {
      const label = document.getElementById('roleLabel_' + this.id.replace('role_', ''));
      if (this.checked) {
        label.classList.add('border-primary', 'bg-primary', 'bg-opacity-10');
      } else {
        label.classList.remove('border-primary', 'bg-primary', 'bg-opacity-10');
      }
    });
  });
})();
</script>
