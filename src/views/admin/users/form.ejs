<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">
    <i class="bi bi-person-plus me-2"></i><%= editUser ? 'Edit User' : 'New User' %>
  </h1>
  <a href="/admin/users" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="card shadow-sm">
  <div class="card-body">
    <form action="<%= editUser ? '/admin/users/' + editUser.UserID : '/admin/users' %>" method="POST">
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label">Username <span class="text-danger">*</span></label>
          <input type="text" name="username" class="form-control"
                 value="<%= editUser ? editUser.Username : '' %>"
                 <%= editUser ? 'readonly' : 'required' %> maxlength="100" />
          <% if (editUser) { %><div class="form-text">Username cannot be changed.</div><% } %>
        </div>
        <div class="col-md-6">
          <label class="form-label">Display Name <span class="text-danger">*</span></label>
          <input type="text" name="displayName" class="form-control"
                 value="<%= editUser ? editUser.DisplayName : '' %>" required maxlength="150" />
        </div>
        <div class="col-md-6">
          <label class="form-label">Email</label>
          <input type="email" name="email" class="form-control"
                 value="<%= editUser ? (editUser.Email || '') : '' %>" maxlength="255" />
        </div>
        <div class="col-md-6">
          <label class="form-label">Organization</label>
          <input type="text" name="organization" class="form-control"
                 value="<%= editUser ? (editUser.Organization || '') : '' %>" maxlength="150"
                 placeholder="e.g. NDIT, Stutsman County" />
        </div>
        <% if (!editUser) { %>
        <div class="col-md-6">
          <label class="form-label">Auth Provider</label>
          <select name="authProvider" class="form-select" id="authProviderSelect">
            <% (authProviders || [{value:'local', label:'Local (username + password)'}]).forEach(p => { %>
              <option value="<%= p.value %>"><%= p.label %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6" id="passwordField">
          <label class="form-label">Password <span class="text-danger">*</span></label>
          <input type="password" name="password" id="passwordInput" class="form-control" autocomplete="new-password" minlength="8" />
          <div class="form-text">Minimum 8 characters. Not required for LDAP/OIDC accounts.</div>
        </div>
        <% } else { %>
        <div class="col-md-6">
          <label class="form-label">New Password</label>
          <input type="password" name="newPassword" class="form-control" autocomplete="new-password" minlength="8" />
          <div class="form-text">Leave blank to keep existing password. Only applies to local accounts.</div>
        </div>
        <% } %>

        <!-- ── Roles ─────────────────────────────────────────────────────────── -->
        <div class="col-12">
          <div class="d-flex align-items-center gap-2 mb-2">
            <label class="form-label mb-0">Roles</label>
            <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-2"
                    data-bs-toggle="modal" data-bs-target="#rolesMatrixModal">
              <i class="bi bi-table me-1"></i>Permissions Reference
            </button>
          </div>
          <div class="row g-2">
            <% roles.forEach(r => {
                 const checked = editUser && editUser.roles && editUser.roles.includes(r.RoleName);
            %>
            <div class="col-sm-6 col-lg-4">
              <label class="role-card d-flex align-items-start gap-2 p-2 rounded border cursor-pointer
                            <%= checked ? 'border-primary bg-primary bg-opacity-10' : '' %>"
                     for="role_<%= r.RoleID %>" id="roleLabel_<%= r.RoleID %>">
                <input type="checkbox" name="roles" value="<%= r.RoleName %>"
                       id="role_<%= r.RoleID %>" class="form-check-input mt-1 flex-shrink-0"
                       <%= checked ? 'checked' : '' %> />
                <div>
                  <div class="fw-semibold small"><%= r.RoleName %></div>
                  <% if (r.Description) { %>
                  <div class="text-muted" style="font-size:0.78rem"><%= r.Description %></div>
                  <% } %>
                </div>
              </label>
            </div>
            <% }) %>
          </div>
        </div>
      </div>

      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i><%= editUser ? 'Save Changes' : 'Create User' %></button>
        <a href="/admin/users" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>

