<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0"><i class="bi bi-tags me-2"></i>Site Types</h1>
  <a href="/admin" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="row g-4">
  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-header" id="formTitle">Add Site Type</div>
      <div class="card-body">
        <form action="/admin/site-types" method="POST" id="typeForm">
          <input type="hidden" name="id" id="typeID" value="" />
          <div class="mb-3">
            <label class="form-label">Type Name <span class="text-danger">*</span></label>
            <input type="text" name="typeName" id="typeName" class="form-control" required maxlength="100" />
          </div>
          <div class="mb-3">
            <label class="form-label">Description</label>
            <input type="text" name="description" id="typeDesc" class="form-control" maxlength="255" />
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm" id="submitBtn">Add</button>
            <button type="button" class="btn btn-outline-secondary btn-sm d-none" id="cancelBtn">Cancel</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="col-md-8">
    <div class="card shadow-sm">
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
          <thead><tr><th>Name</th><th>Description</th><th>Status</th><th></th></tr></thead>
          <tbody>
            <% siteTypes.forEach(t => { %>
            <tr class="<%= t.IsActive ? '' : 'text-muted' %>">
              <td><%= t.TypeName %></td>
              <td class="small"><%= t.Description || '—' %></td>
              <td><span class="badge <%= t.IsActive ? 'bg-success' : 'bg-secondary' %>"><%= t.IsActive ? 'Active' : 'Inactive' %></span></td>
              <td class="text-end">
                <button type="button" class="btn btn-sm btn-outline-primary py-0 me-1 js-edit"
                  data-id="<%= t.SiteTypeID %>"
                  data-name="<%= t.TypeName %>"
                  data-desc="<%= t.Description || '' %>">
                  <i class="bi bi-pencil"></i>
                </button>
                <form action="/admin/site-types" method="POST" class="d-inline">
                  <input type="hidden" name="id" value="<%= t.SiteTypeID %>" />
                  <input type="hidden" name="action" value="toggle" />
                  <button type="submit" class="btn btn-sm btn-outline-secondary py-0"><%= t.IsActive ? 'Disable' : 'Enable' %></button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('.js-edit').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.getElementById('typeID').value   = this.dataset.id;
    document.getElementById('typeName').value = this.dataset.name;
    document.getElementById('typeDesc').value = this.dataset.desc;
    document.getElementById('formTitle').textContent  = 'Edit Site Type';
    document.getElementById('submitBtn').textContent  = 'Save Changes';
    document.getElementById('cancelBtn').classList.remove('d-none');
    document.getElementById('typeName').focus();
  });
});

document.getElementById('cancelBtn').addEventListener('click', function() {
  document.getElementById('typeForm').reset();
  document.getElementById('typeID').value  = '';
  document.getElementById('formTitle').textContent = 'Add Site Type';
  document.getElementById('submitBtn').textContent = 'Add';
  this.classList.add('d-none');
});
</script>
