<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0"><i class="bi bi-file-earmark-spreadsheet me-2"></i>Import Vendors — Preview</h1>
  <a href="/vendors/import" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Back
  </a>
</div>

<!-- Summary cards -->
<div class="d-flex gap-3 mb-4 flex-wrap">
  <div class="card text-center px-4 py-3 border-success">
    <div class="fs-2 fw-bold text-success"><%= summary.created %></div>
    <div class="small text-muted">New Vendors</div>
  </div>
  <div class="card text-center px-4 py-3 border-primary">
    <div class="fs-2 fw-bold text-primary"><%= summary.updated %></div>
    <div class="small text-muted">Will Update</div>
  </div>
  <div class="card text-center px-4 py-3 border-warning">
    <div class="fs-2 fw-bold text-warning"><%= summary.skipped %></div>
    <div class="small text-muted">Skipped</div>
  </div>
  <div class="card text-center px-4 py-3 border-danger">
    <div class="fs-2 fw-bold text-danger"><%= summary.errors %></div>
    <div class="small text-muted">Errors</div>
  </div>
</div>

<% if (summary.errors > 0) { %>
<div class="alert alert-warning d-flex align-items-center gap-2 mb-4">
  <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
  <span><%= summary.errors %> row<%= summary.errors !== 1 ? 's' : '' %> have errors and will be skipped.</span>
</div>
<% } %>

<form method="POST" action="/vendors/import/confirm">
  <input type="hidden" name="importPlan" value="<%= importPlan %>" />

  <%
    const newEntries        = plan.filter(e => e.action === 'create'  && !e.entity);
    const updatedEntries    = plan.filter(e => e.action === 'update'  && !e.entity);
    const removedEntries    = plan.filter(e => e.action === 'remove');
    const errorEntries      = plan.filter(e => e.action === 'error');
    const newContacts       = plan.filter(e => e.action === 'create'  && e.entity === 'contact');
    const updatedContacts   = plan.filter(e => e.action === 'update'  && e.entity === 'contact');
  %>

  <!-- ── New Vendors ────────────────────────────────────────────────────────── -->
  <% if (newEntries.length > 0) { %>
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-success bg-opacity-10 d-flex align-items-center gap-2">
      <i class="bi bi-plus-circle text-success"></i>
      <strong>New Vendors</strong>
      <span class="badge bg-success ms-1"><%= newEntries.length %></span>
    </div>
    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0">
        <thead>
          <tr>
            <th>Vendor Name</th>
            <th>City</th>
            <th>State</th>
          </tr>
        </thead>
        <tbody>
          <% newEntries.forEach(e => { %>
          <tr>
            <td class="small fw-semibold"><%= e.display.vendorName %></td>
            <td class="small text-muted"><%= e.data.city || '—' %></td>
            <td class="small text-muted"><%= e.data.state || '—' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>

  <!-- ── Updated Vendors ───────────────────────────────────────────────────── -->
  <% if (updatedEntries.length > 0) { %>
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-primary bg-opacity-10 d-flex align-items-center gap-2">
      <i class="bi bi-pencil text-primary"></i>
      <strong>Updated Vendors</strong>
      <span class="badge bg-primary ms-1"><%= updatedEntries.length %></span>
    </div>
    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0">
        <thead>
          <tr>
            <th>Vendor Name</th>
            <th>Changes</th>
          </tr>
        </thead>
        <tbody>
          <% updatedEntries.forEach(e => { %>
          <tr>
            <td class="small fw-semibold"><%= e.display.vendorName %></td>
            <td class="small">
              <% e.diff.forEach(d => { %>
              <div>
                <span class="text-muted"><%= d.field %>:</span>
                <span class="text-danger text-decoration-line-through"><%= d.from ?? '—' %></span>
                <i class="bi bi-arrow-right mx-1 text-muted"></i>
                <span class="text-success"><%= d.to ?? '—' %></span>
              </div>
              <% }) %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>

  <!-- ── Not in Import File (informational) ───────────────────────────────── -->
  <% if (removedEntries.length > 0) { %>
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-danger bg-opacity-10 d-flex align-items-center gap-2">
      <i class="bi bi-dash-circle text-danger"></i>
      <strong>Not in Import File</strong>
      <span class="badge bg-danger ms-1"><%= removedEntries.length %></span>
      <span class="ms-2 small text-muted fw-normal">These vendors exist in the database but are missing from this file. They will not be affected by this import.</span>
    </div>
    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0">
        <thead>
          <tr>
            <th>Vendor Name</th>
            <th>City</th>
            <th>State</th>
          </tr>
        </thead>
        <tbody>
          <% removedEntries.forEach(e => { %>
          <tr class="text-muted">
            <td class="small"><%= e.display.vendorName %></td>
            <td class="small"><%= e.display.city || '—' %></td>
            <td class="small"><%= e.display.state || '—' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>

  <!-- ── New Contacts ─────────────────────────────────────────────────────── -->
  <% if (newContacts.length > 0) { %>
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-success bg-opacity-10 d-flex align-items-center gap-2">
      <i class="bi bi-person-plus text-success"></i>
      <strong>New Contacts</strong>
      <span class="badge bg-success ms-1"><%= newContacts.length %></span>
    </div>
    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0">
        <thead>
          <tr>
            <th>Vendor</th>
            <th>First Name</th>
            <th>Last Name</th>
          </tr>
        </thead>
        <tbody>
          <% newContacts.forEach(e => { %>
          <tr>
            <td class="small text-muted"><%= e.display.vendorName %></td>
            <td class="small fw-semibold"><%= e.display.firstName %></td>
            <td class="small"><%= e.display.lastName || '—' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>

  <!-- ── Updated Contacts ──────────────────────────────────────────────────── -->
  <% if (updatedContacts.length > 0) { %>
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-primary bg-opacity-10 d-flex align-items-center gap-2">
      <i class="bi bi-person-lines-fill text-primary"></i>
      <strong>Updated Contacts</strong>
      <span class="badge bg-primary ms-1"><%= updatedContacts.length %></span>
    </div>
    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0">
        <thead>
          <tr>
            <th>Vendor</th>
            <th>Name</th>
            <th>Changes</th>
          </tr>
        </thead>
        <tbody>
          <% updatedContacts.forEach(e => { %>
          <tr>
            <td class="small text-muted"><%= e.display.vendorName %></td>
            <td class="small fw-semibold"><%= e.display.firstName %> <%= e.display.lastName || '' %></td>
            <td class="small">
              <% e.diff.forEach(d => { %>
              <div>
                <span class="text-muted"><%= d.field %>:</span>
                <span class="text-danger text-decoration-line-through"><%= d.from ?? '—' %></span>
                <i class="bi bi-arrow-right mx-1 text-muted"></i>
                <span class="text-success"><%= d.to ?? '—' %></span>
              </div>
              <% }) %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>

  <!-- ── Errors ─────────────────────────────────────────────────────────────── -->
  <% if (errorEntries.length > 0) { %>
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-danger bg-opacity-10 d-flex align-items-center gap-2">
      <i class="bi bi-exclamation-circle text-danger"></i>
      <strong>Errors</strong>
      <span class="badge bg-danger ms-1"><%= errorEntries.length %></span>
    </div>
    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0">
        <thead>
          <tr>
            <th>Row</th>
            <th>Vendor Name</th>
            <th>Reason</th>
          </tr>
        </thead>
        <tbody>
          <% errorEntries.forEach(e => { %>
          <tr>
            <td class="small text-muted"><%= e.rowNum %></td>
            <td class="small fw-semibold"><%= e.display.vendorName || '—' %></td>
            <td class="small text-danger"><%= e.message %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>

  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary" <%= (summary.created + summary.updated) === 0 ? 'disabled' : '' %>>
      <i class="bi bi-check-circle me-1"></i>Confirm Import
      <% if (summary.created + summary.updated > 0) { %>
        (<%= summary.created + summary.updated %> change<%= (summary.created + summary.updated) !== 1 ? 's' : '' %>)
      <% } %>
    </button>
    <a href="/vendors/import" class="btn btn-outline-secondary">Cancel</a>
  </div>
</form>
