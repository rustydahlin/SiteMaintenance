<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">
    <i class="bi bi-building-check me-2"></i><%= vendor ? 'Edit Vendor' : 'New Vendor' %>
  </h1>
  <a href="<%= vendor ? '/vendors/' + vendor.VendorID : '/vendors' %>" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Back
  </a>
</div>

<form action="<%= action %>" method="POST">
  <div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold"><i class="bi bi-info-circle me-2"></i>Vendor Details</div>
    <div class="card-body row g-3">

      <div class="col-md-6">
        <label class="form-label">Vendor Name <span class="text-danger">*</span></label>
        <input type="text" name="vendorName" class="form-control" required maxlength="200"
               value="<%= vendor ? vendor.VendorName : '' %>" />
      </div>

      <div class="col-md-3">
        <label class="form-label">Phone</label>
        <input type="text" name="phone" class="form-control" maxlength="50"
               value="<%= vendor ? (vendor.Phone || '') : '' %>" />
      </div>

      <div class="col-md-3">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-control" maxlength="255"
               value="<%= vendor ? (vendor.Email || '') : '' %>" />
        <div class="form-text">General contact email for the vendor.</div>
      </div>

      <div class="col-md-8">
        <label class="form-label">Address</label>
        <input type="text" name="address" class="form-control" maxlength="500"
               value="<%= vendor ? (vendor.Address || '') : '' %>" />
      </div>

      <div class="col-md-4">
        <label class="form-label">Website</label>
        <input type="text" name="website" class="form-control" maxlength="255"
               value="<%= vendor ? (vendor.Website || '') : '' %>" placeholder="https://…" />
      </div>

      <div class="col-md-4">
        <label class="form-label">City</label>
        <input type="text" name="city" class="form-control" maxlength="100"
               value="<%= vendor ? (vendor.City || '') : '' %>" />
      </div>

      <div class="col-md-2">
        <label class="form-label">State</label>
        <input type="text" name="state" class="form-control" maxlength="50"
               value="<%= vendor ? (vendor.State || '') : '' %>" />
      </div>

      <div class="col-md-2">
        <label class="form-label">Zip</label>
        <input type="text" name="zip" class="form-control" maxlength="20"
               value="<%= vendor ? (vendor.Zip || '') : '' %>" />
      </div>

      <div class="col-md-4">
        <label class="form-label">Performs PM Work?</label>
        <select name="doesPMWork" class="form-select">
          <option value="0" <%= (!vendor || !vendor.DoesPMWork) ? 'selected' : '' %>>No</option>
          <option value="1" <%= (vendor && vendor.DoesPMWork)   ? 'selected' : '' %>>Yes — appears in PM Assigned To</option>
        </select>
      </div>

      <div class="col-12">
        <label class="form-label">Notes</label>
        <textarea name="notes" class="form-control" rows="4" maxlength="4000"><%= vendor ? (vendor.Notes || '') : '' %></textarea>
      </div>

    </div>
  </div>

  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i>Save</button>
    <a href="<%= vendor ? '/vendors/' + vendor.VendorID : '/vendors' %>" class="btn btn-outline-secondary">Cancel</a>
  </div>
</form>
