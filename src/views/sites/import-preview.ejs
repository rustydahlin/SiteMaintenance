<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0"><i class="bi bi-file-earmark-spreadsheet me-2"></i>Import Sites — Preview</h1>
  <a href="/sites/import" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Back
  </a>
</div>

<!-- Summary cards -->
<div class="d-flex gap-3 mb-4 flex-wrap">
  <div class="card text-center px-4 py-3 border-success">
    <div class="fs-2 fw-bold text-success"><%= summary.created %></div>
    <div class="small text-muted">Will Create</div>
  </div>
  <div class="card text-center px-4 py-3 border-primary">
    <div class="fs-2 fw-bold text-primary"><%= summary.updated %></div>
    <div class="small text-muted">Will Update</div>
  </div>
  <div class="card text-center px-4 py-3 border-warning">
    <div class="fs-2 fw-bold text-warning"><%= summary.skipped %></div>
    <div class="small text-muted">Skipped</div>
  </div>
  <div class="card text-center px-4 py-3 border-danger">
    <div class="fs-2 fw-bold text-danger"><%= summary.errors %></div>
    <div class="small text-muted">Errors</div>
  </div>
  <div class="card text-center px-4 py-3">
    <div class="fs-2 fw-bold"><%= summary.total %></div>
    <div class="small text-muted">Total Rows</div>
  </div>
</div>

<% if (summary.errors > 0) { %>
<div class="alert alert-warning d-flex align-items-center gap-2 mb-4">
  <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
  <span><%= summary.errors %> row<%= summary.errors !== 1 ? 's' : '' %> have errors and will be skipped. Review below before confirming.</span>
</div>
<% } %>

<form method="POST" action="/sites/import/confirm">
  <input type="hidden" name="importPlan" value="<%= importPlan %>" />

  <div class="card shadow-sm mb-4">
    <div class="card-header"><strong>Row-by-Row Preview</strong></div>
    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0">
        <thead>
          <tr>
            <th style="width:3rem">Row</th>
            <th>Site Name</th>
            <th>Site #</th>
            <th>Type</th>
            <th style="width:6rem">Action</th>
            <th>Changes</th>
          </tr>
        </thead>
        <tbody>
          <% plan.forEach(entry => { %>
          <tr>
            <td class="text-muted small"><%= entry.rowNum %></td>
            <td class="small fw-semibold"><%= entry.display.siteName || '—' %></td>
            <td class="small text-muted"><%= entry.display.siteNumber || '—' %></td>
            <td class="small text-muted"><%= entry.display.siteType || '—' %></td>
            <td>
              <% if (entry.action === 'create') { %>
                <span class="badge bg-success">New</span>
              <% } else if (entry.action === 'update') { %>
                <span class="badge bg-primary">Update</span>
              <% } else if (entry.action === 'skip') { %>
                <span class="badge bg-warning text-dark">Skip</span>
              <% } else { %>
                <span class="badge bg-danger">Error</span>
              <% } %>
            </td>
            <td class="small">
              <% if (entry.action === 'update' && entry.diff && entry.diff.length > 0) { %>
                <% entry.diff.forEach(d => { %>
                  <div>
                    <span class="text-muted"><%= d.field %>:</span>
                    <span class="text-danger text-decoration-line-through"><%= d.from ?? '—' %></span>
                    <i class="bi bi-arrow-right mx-1 text-muted"></i>
                    <span class="text-success"><%= d.to ?? '—' %></span>
                  </div>
                <% }) %>
              <% } else if (entry.action === 'update') { %>
                <span class="text-muted fst-italic">No changes</span>
              <% } else if (entry.action === 'create') { %>
                <span class="text-muted fst-italic">New record</span>
              <% } else if (entry.message) { %>
                <span class="text-danger"><%= entry.message %></span>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary" <%= (summary.created + summary.updated) === 0 ? 'disabled' : '' %>>
      <i class="bi bi-check-circle me-1"></i>Confirm Import
      <% if (summary.created + summary.updated > 0) { %>
        (<%= summary.created + summary.updated %> change<%= (summary.created + summary.updated) !== 1 ? 's' : '' %>)
      <% } %>
    </button>
    <a href="/sites/import" class="btn btn-outline-secondary">Cancel</a>
  </div>
</form>
