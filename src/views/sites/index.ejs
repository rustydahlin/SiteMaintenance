<%
  function warrantyBadge(dateStr) {
    if (!dateStr) return '<span class="badge bg-secondary">N/A</span>';
    const now = new Date();
    const exp = new Date(dateStr);
    const daysLeft = Math.ceil((exp - now) / (1000 * 60 * 60 * 24));
    if (daysLeft < 0)   return '<span class="badge bg-danger">Expired</span>';
    if (daysLeft <= 90) return '<span class="badge bg-warning text-dark">Expiring Soon</span>';
    return '<span class="badge bg-success">In Warranty</span>';
  }
  function statusDot(statusName) {
    const map = {
      'Active':      'bg-success',
      'Inactive':    'bg-secondary',
      'Maintenance': 'bg-warning',
      'Decommissioned': 'bg-danger',
    };
    const cls = map[statusName] || 'bg-secondary';
    return `<span class="badge rounded-pill ${cls}" style="width:.65rem;height:.65rem;padding:0;vertical-align:middle;display:inline-block;">&nbsp;</span>`;
  }
%>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0"><i class="bi bi-building me-2"></i>Sites</h1>
  <% if (user && user.roles && user.roles.includes('Admin')) { %>
    <a href="/sites/new" class="btn btn-primary btn-sm">
      <i class="bi bi-plus-lg me-1"></i>New Site
    </a>
  <% } %>
</div>

<!-- Filter form -->
<div class="card mb-3 shadow-sm">
  <div class="card-body py-2">
    <form method="GET" action="/sites" class="row g-2 align-items-end">
      <div class="col-sm-4 col-lg-3">
        <label class="form-label small mb-1">Search</label>
        <input type="text" name="search" class="form-control form-control-sm"
               placeholder="Name, city, address…"
               value="<%= typeof filters !== 'undefined' && filters.search ? filters.search : '' %>" />
      </div>
      <div class="col-sm-3 col-lg-2">
        <label class="form-label small mb-1">Type</label>
        <select name="typeID" class="form-select form-select-sm">
          <option value="">All Types</option>
          <% siteTypes.forEach(t => { %>
            <option value="<%= t.SiteTypeID %>"
              <%= (typeof filters !== 'undefined' && filters.typeID == t.SiteTypeID) ? 'selected' : '' %>>
              <%= t.TypeName %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-sm-3 col-lg-2">
        <label class="form-label small mb-1">Status</label>
        <select name="statusID" class="form-select form-select-sm">
          <option value="">All Statuses</option>
          <% siteStatuses.forEach(s => { %>
            <option value="<%= s.SiteStatusID %>"
              <%= (typeof filters !== 'undefined' && filters.statusID == s.SiteStatusID) ? 'selected' : '' %>>
              <%= s.StatusName %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-sm-2 col-lg-2">
        <div class="form-check mt-4">
          <input class="form-check-input" type="checkbox" name="pmDue" value="1" id="pmDueChk"
            <%= (typeof filters !== 'undefined' && filters.pmDue == 1) ? 'checked' : '' %>>
          <label class="form-check-label small" for="pmDueChk">PM Due</label>
        </div>
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-outline-primary">
          <i class="bi bi-search me-1"></i>Filter
        </button>
        <a href="/sites" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
      </div>
    </form>
  </div>
</div>

<!-- Results -->
<% if (sites.length === 0) { %>
  <div class="alert alert-info">No sites found matching your filters.</div>
<% } else { %>
<div class="table-responsive">
  <table class="table table-hover table-sm align-middle mb-0">
    <thead>
      <tr>
        <th>Site Name</th>
        <th>Type</th>
        <th>Status</th>
        <th>City / State</th>
        <th>Warranty</th>
        <th>Created</th>
      </tr>
    </thead>
    <tbody>
      <% sites.forEach(site => { %>
      <tr>
        <td>
          <a href="/sites/<%= site.SiteID %>" class="fw-semibold text-decoration-none">
            <%= site.SiteName %>
          </a>
        </td>
        <td><span class="text-muted small"><%= site.SiteTypeName || '—' %></span></td>
        <td>
          <%- statusDot(site.SiteStatusName) %>
          <span class="ms-1 small"><%= site.SiteStatusName || '—' %></span>
        </td>
        <td class="small text-muted">
          <%= [site.City, site.State].filter(Boolean).join(', ') || '—' %>
        </td>
        <td><%- warrantyBadge(site.WarrantyExpires) %></td>
        <td class="small text-muted">
          <%= site.CreatedAt ? new Date(site.CreatedAt).toLocaleDateString() : '—' %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Pagination -->
<div class="d-flex justify-content-between align-items-center mt-3">
  <small class="text-muted">
    Showing <%= sites.length %> of <%= pagination.total %> site<%= pagination.total !== 1 ? 's' : '' %>
  </small>
  <%- include('../partials/pagination') %>
</div>
<% } %>
