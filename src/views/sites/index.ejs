<%
  function warrantyBadge(dateStr) {
    if (!dateStr) return '<span class="badge bg-secondary">N/A</span>';
    const now = new Date();
    const exp = new Date(dateStr);
    const daysLeft = Math.ceil((exp - now) / (1000 * 60 * 60 * 24));
    if (daysLeft < 0)   return '<span class="badge bg-danger">Expired</span>';
    if (daysLeft <= 90) return '<span class="badge bg-warning text-dark">Expiring Soon</span>';
    return '<span class="badge bg-success">In Warranty</span>';
  }
  function pmBadge(dateStr) {
    if (!dateStr) return '<span class="text-muted small">—</span>';
    const now = new Date();
    const due = new Date(dateStr);
    const daysLeft = Math.ceil((due - now) / (1000 * 60 * 60 * 24));
    if (daysLeft < 0)   return `<span class="badge bg-danger">Overdue</span>`;
    if (daysLeft <= 14) return `<span class="badge bg-warning text-dark">${due.toLocaleDateString()}</span>`;
    return `<span class="small text-muted">${due.toLocaleDateString()}</span>`;
  }
  function statusDot(statusName) {
    const map = {
      'Current':        'bg-success',
      'Maintenance':    'bg-warning',
      'Past-Due':       'bg-danger',
      'Active':         'bg-success',
      'Inactive':       'bg-secondary',
      'Decommissioned': 'bg-secondary',
    };
    const cls = map[statusName] || 'bg-secondary';
    return `<span class="badge rounded-pill ${cls}" style="width:.65rem;height:.65rem;padding:0;vertical-align:middle;display:inline-block;">&nbsp;</span>`;
  }
  // Build a sortable header link
  const curSort = typeof sort !== 'undefined' ? sort : 'siteName';
  const curDir  = typeof dir  !== 'undefined' ? dir  : 'asc';
  function sortLink(col) {
    const newDir = (curSort === col && curDir === 'asc') ? 'desc' : 'asc';
    const f = typeof filters !== 'undefined' ? filters : {};
    const parts = [];
    if (f.typeID)   parts.push(`typeID=${encodeURIComponent(f.typeID)}`);
    if (f.statusID) parts.push(`statusID=${encodeURIComponent(f.statusID)}`);
    if (f.search)   parts.push(`search=${encodeURIComponent(f.search)}`);
    if (f.pmDue)    parts.push(`pmDue=${encodeURIComponent(f.pmDue)}`);
    parts.push(`sort=${col}`, `dir=${newDir}`);
    return `/sites?${parts.join('&')}`;
  }
  function sortIcon(col) {
    if (curSort !== col) return '<i class="bi bi-arrow-down-up text-muted ms-1 small opacity-50"></i>';
    return curDir === 'asc'
      ? '<i class="bi bi-sort-up ms-1 small"></i>'
      : '<i class="bi bi-sort-down ms-1 small"></i>';
  }
%>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0"><i class="bi bi-building me-2"></i>Sites</h1>
  <div class="d-flex gap-2">
    <%
      const exportParts = [];
      if (filters.typeID)   exportParts.push(`typeID=${encodeURIComponent(filters.typeID)}`);
      if (filters.statusID) exportParts.push(`statusID=${encodeURIComponent(filters.statusID)}`);
      if (filters.search)   exportParts.push(`search=${encodeURIComponent(filters.search)}`);
      if (filters.pmDue)    exportParts.push(`pmDue=${encodeURIComponent(filters.pmDue)}`);
      exportParts.push(`sort=${encodeURIComponent(curSort)}`, `dir=${encodeURIComponent(curDir)}`);
    %>
    <a href="/sites/export?<%= exportParts.join('&') %>" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-file-earmark-arrow-down me-1"></i>Export
    </a>
    <% if (user && user.roles && user.roles.includes('Admin')) { %>
    <a href="/sites/import" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-file-earmark-spreadsheet me-1"></i>Import
    </a>
    <a href="/sites/new" class="btn btn-primary btn-sm">
      <i class="bi bi-plus-lg me-1"></i>New Site
    </a>
    <% } %>
  </div>
</div>

<!-- Filter form -->
<div class="card mb-3 shadow-sm">
  <div class="card-body py-2">
    <form method="GET" action="/sites" class="row g-2 align-items-end">
      <input type="hidden" name="sort" value="<%= curSort %>" />
      <input type="hidden" name="dir"  value="<%= curDir %>" />
      <div class="col-sm-4 col-lg-3">
        <label class="form-label small mb-1">Search</label>
        <input type="text" name="search" class="form-control form-control-sm"
               placeholder="Name, site #, city, address…"
               value="<%= typeof filters !== 'undefined' && filters.search ? filters.search : '' %>" />
      </div>
      <div class="col-sm-3 col-lg-2">
        <label class="form-label small mb-1">Type</label>
        <select name="typeID" class="form-select form-select-sm">
          <option value="">All Types</option>
          <% siteTypes.forEach(t => { %>
            <option value="<%= t.SiteTypeID %>"
              <%= (typeof filters !== 'undefined' && filters.typeID == t.SiteTypeID) ? 'selected' : '' %>>
              <%= t.TypeName %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-sm-3 col-lg-2">
        <label class="form-label small mb-1">Status</label>
        <select name="statusID" class="form-select form-select-sm">
          <option value="">All Statuses</option>
          <% siteStatuses.forEach(s => { %>
            <option value="<%= s.SiteStatusID %>"
              <%= (typeof filters !== 'undefined' && filters.statusID == s.SiteStatusID) ? 'selected' : '' %>>
              <%= s.StatusName %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-sm-2 col-lg-2">
        <div class="form-check mt-4">
          <input class="form-check-input" type="checkbox" name="pmDue" value="1" id="pmDueChk"
            <%= (typeof filters !== 'undefined' && filters.pmDue == 1) ? 'checked' : '' %>>
          <label class="form-check-label small" for="pmDueChk">PM Due</label>
        </div>
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-outline-primary">
          <i class="bi bi-search me-1"></i>Filter
        </button>
        <a href="/sites" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
      </div>
    </form>
  </div>
</div>

<!-- Results -->
<% if (sites.length === 0) { %>
  <div class="alert alert-info">No sites found matching your filters.</div>
<% } else { %>
<div class="table-responsive">
  <table class="table table-hover table-sm align-middle mb-0">
    <thead>
      <tr>
        <th><a href="<%- sortLink('siteNumber') %>" class="text-decoration-none text-body">Site #<%- sortIcon('siteNumber') %></a></th>
        <th><a href="<%- sortLink('siteName') %>" class="text-decoration-none text-body">Site Name<%- sortIcon('siteName') %></a></th>
        <th><a href="<%- sortLink('type') %>" class="text-decoration-none text-body">Type<%- sortIcon('type') %></a></th>
        <th><a href="<%- sortLink('status') %>" class="text-decoration-none text-body">Status<%- sortIcon('status') %></a></th>
        <th><a href="<%- sortLink('city') %>" class="text-decoration-none text-body">City / State<%- sortIcon('city') %></a></th>
        <th><a href="<%- sortLink('warranty') %>" class="text-decoration-none text-body">Warranty<%- sortIcon('warranty') %></a></th>
        <th><a href="<%- sortLink('nextPM') %>" class="text-decoration-none text-body">Next PM<%- sortIcon('nextPM') %></a></th>
      </tr>
    </thead>
    <tbody>
      <% sites.forEach(site => { %>
      <tr>
        <td class="small text-muted"><%= site.SiteNumber || '—' %></td>
        <td>
          <a href="/sites/<%= site.SiteID %>" class="fw-semibold text-decoration-none">
            <%= site.SiteName %>
          </a>
        </td>
        <td><span class="text-muted small"><%= site.SiteTypeName || '—' %></span></td>
        <td>
          <%- statusDot(site.SiteStatusName) %>
          <span class="ms-1 small"><%= site.SiteStatusName || '—' %></span>
        </td>
        <td class="small text-muted">
          <%= [site.City, site.State].filter(Boolean).join(', ') || '—' %>
        </td>
        <td><%- warrantyBadge(site.WarrantyExpires) %></td>
        <td><%- pmBadge(site.NextPMDate) %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Pagination -->
<div class="d-flex justify-content-between align-items-center mt-3">
  <small class="text-muted">
    Showing <%= sites.length %> of <%= pagination.total %> site<%= pagination.total !== 1 ? 's' : '' %>
  </small>
  <%- include('../partials/pagination') %>
</div>
<% } %>
