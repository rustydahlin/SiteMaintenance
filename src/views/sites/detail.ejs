            <a class="nav-link active" data-bs-toggle="tab" href="#tabExisting">Select In-Stock Item</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#tabNew">Create New Item</a>
          </li>
        </ul>

        <div class="tab-content">

          <!-- Tab: Select Existing -->
          <div class="tab-pane fade show active" id="tabExisting">
            <%
              const serializedItems = (inStockItems || []).filter(i => i.TrackingType !== 'bulk');
              const bulkItems       = (inStockItems || []).filter(i => i.TrackingType === 'bulk');
            %>
            <% if (!inStockItems || inStockItems.length === 0) { %>
              <p class="text-muted mb-0">No items currently in stock. Use the <strong>Create New Item</strong> tab to add and install a new item.</p>
            <% } else { %>

            <!-- Serialized items -->
            <% if (serializedItems.length > 0) { %>
            <form method="POST" action="/sites/<%= site.SiteID %>/inventory/install" class="mb-4">
              <input type="hidden" name="mode" value="existing" />
              <h6 class="text-muted small text-uppercase mb-2">Serialized / Asset-Tracked Items</h6>
              <div class="mb-2">
                <input type="text" id="stockSearch" class="form-control form-control-sm"
                       placeholder="Filter by serial, model, manufacturer..." autocomplete="off" />
              </div>
              <select name="itemID" id="stockSelect" class="form-select mb-2" required size="6">
                <% serializedItems.forEach(si => { %>
                <option value="<%= si.ItemID %>"
                  data-search="<%= ((si.CommonName||'') + ' ' + (si.SerialNumber||'') + ' ' + (si.ModelNumber||'') + ' ' + (si.Manufacturer||'')).toLowerCase() %>">
                  <%= si.SerialNumber || '(no serial)' %>
                  <% if (si.CommonName) { %> — <%= si.CommonName %><% } %>
                  <% if (si.ModelNumber) { %> (<%= si.ModelNumber %><% if (si.Manufacturer) { %>/<%= si.Manufacturer %><% } %>)<% } else if (si.Manufacturer) { %> (<%= si.Manufacturer %>)<% } %>
                  <% if (si.StockLocationName) { %> [<%= si.StockLocationName %>]<% } %>
                </option>
                <% }) %>
              </select>
              <div class="mb-2">
                <textarea name="installNotes" class="form-control form-control-sm" rows="2"
                          placeholder="Install notes (optional)"></textarea>
              </div>
              <button type="submit" class="btn btn-sm btn-primary">
                <i class="bi bi-box-arrow-in-down-right me-1"></i>Install Selected Item
              </button>
            </form>
            <% } %>

            <!-- Bulk / FRU items -->
            <% if (bulkItems.length > 0) { %>
            <h6 class="text-muted small text-uppercase mb-2">Bulk / FRU Items</h6>
            <div class="table-responsive">
              <table class="table table-sm table-hover align-middle mb-0">
                <thead>
                  <tr>
                    <th>Item</th>
                    <th class="text-center">Available</th>
                    <th>Pull From / Qty / Install</th>
                  </tr>
                </thead>
                <tbody>
                  <% bulkItems.forEach(bi => { %>
                  <% var biStock = (stockByItem && stockByItem[bi.ItemID]) ? stockByItem[bi.ItemID] : []; %>
                  <tr>
                    <td>
                      <div class="fw-semibold small"><%= bi.CommonName || bi.ModelNumber || '(no name)' %></div>
                      <% if (bi.Manufacturer) { %><div class="small text-muted"><%= bi.Manufacturer %></div><% } %>
                      <% if (bi.CategoryName) { %><span class="badge bg-body-secondary text-body border small"><%= bi.CategoryName %></span><% } %>
                    </td>
                    <td class="text-center">
                      <span class="badge <%= bi.QuantityAvailable > 0 ? 'bg-success' : 'bg-secondary' %>">
                        <%= bi.QuantityAvailable %> / <%= bi.QuantityTotal %>
                      </span>
                    </td>
                    <td>
                      <form method="POST" action="/sites/<%= site.SiteID %>/inventory/install"
                            class="d-flex gap-2 align-items-center flex-wrap">
                        <input type="hidden" name="mode" value="existing" />
                        <input type="hidden" name="itemID" value="<%= bi.ItemID %>" />
                        <select name="pulledFrom" class="form-select form-select-sm" style="min-width:170px">
                          <% var allocatedQty = biStock.reduce(function(sum, s) { return sum + (s.Quantity || 0); }, 0); %>
                          <% var unallocatedQty = (bi.QuantityAvailable || 0) - allocatedQty; %>
                          <option value="">— Unallocated (<%= unallocatedQty %> avail) —</option>
                          <% biStock.forEach(function(s) { %>
                            <% if (s.LocationID) { %>
                              <option value="location:<%= s.LocationID %>">
                                <%= s.LocationName %> (<%= s.Quantity %> avail)
                              </option>
                            <% } else if (s.UserID) { %>
                              <option value="user:<%= s.UserID %>">
                                <%= s.UserDisplayName %> (<%= s.Quantity %> avail)
                              </option>
                            <% } %>
                          <% }); %>
                        </select>
                        <input type="number" name="quantity" class="form-control form-control-sm"
                               value="1" min="1" max="<%= bi.QuantityAvailable %>"
                               style="width:70px" required />
                        <button type="submit" class="btn btn-sm btn-primary"
                                <%= bi.QuantityAvailable < 1 ? 'disabled' : '' %>>
                          Install
                        </button>
                      </form>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            <% } %>

            <% } %>
          </div>

          <!-- Tab: Create New Item & Install -->
          <div class="tab-pane fade" id="tabNew">
            <form method="POST" action="/sites/<%= site.SiteID %>/inventory/install">
              <input type="hidden" name="mode" value="new" />
              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label">Serial Number <span class="text-danger">*</span></label>
                  <input type="text" name="serialNumber" class="form-control" required maxlength="100" />
                </div>
                <div class="col-md-4">
                  <label class="form-label">Model Number</label>
                  <input type="text" name="modelNumber" class="form-control" maxlength="100" />
                </div>
                <div class="col-md-4">
                  <label class="form-label">Manufacturer</label>
                  <input type="text" name="manufacturer" class="form-control" maxlength="150" />
                </div>
                <div class="col-md-4">
                  <label class="form-label">Category</label>
                  <select name="categoryID" class="form-select">
                    <option value="">— None —</option>
                    <% categories.forEach(cat => { %>
                    <option value="<%= cat.CategoryID %>"><%= cat.CategoryName %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-md-4">
                  <label class="form-label">Purchase Date</label>
                  <input type="date" name="purchaseDate" class="form-control" />
                </div>
                <div class="col-md-4">
                  <label class="form-label">Warranty Expires</label>
                  <input type="date" name="warrantyExpires" class="form-control" />
                </div>
                <div class="col-12">
                  <label class="form-label">Install Notes</label>
                  <textarea name="installNotes" class="form-control" rows="2" placeholder="Optional notes about this installation"></textarea>
                </div>
              </div>
              <button type="submit" class="btn btn-primary mt-3">
                <i class="bi bi-plus-circle me-1"></i>Create & Install
              </button>
            </form>
          </div>

        </div><!-- /.tab-content -->
      </div>
    </div>
  </div>
</div>
<% } %>

