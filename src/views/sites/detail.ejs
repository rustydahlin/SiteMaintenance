<%
  const isAdminUser = user && user.roles && user.roles.includes('Admin');
  const canWriteUser = user && user.roles &&
    (user.roles.includes('Admin') || user.roles.includes('Technician') || user.roles.includes('Contractor'));

  function warrantyBadge(dateStr) {
    if (!dateStr) return '<span class="badge bg-secondary">N/A</span>';
    const now = new Date();
    const exp = new Date(dateStr);
    const daysLeft = Math.ceil((exp - now) / (1000 * 60 * 60 * 24));
    if (daysLeft < 0)   return '<span class="badge bg-danger">Expired</span>';
    if (daysLeft <= 90) return '<span class="badge bg-warning text-dark">Expiring Soon</span>';
    return '<span class="badge bg-success">In Warranty</span>';
  }

  function statusBadge(name) {
    const map = { 'Active': 'bg-success', 'Inactive': 'bg-secondary', 'Maintenance': 'bg-warning text-dark', 'Decommissioned': 'bg-danger' };
    const cls = map[name] || 'bg-secondary';
    return `<span class="badge ${cls}">${name || 'Unknown'}</span>`;
  }

  function logTypeBadge(typeName) {
    const map = { 'Maintenance': 'bg-warning text-dark', 'Repair': 'bg-danger', 'Inspection': 'bg-info text-dark', 'Installation': 'bg-primary', 'Note': 'bg-secondary' };
    const cls = map[typeName] || 'bg-secondary';
    return `<span class="badge ${cls}">${typeName || ''}</span>`;
  }

  function pmDueBadge(nextDue) {
    if (!nextDue) return '<span class="text-muted">—</span>';
    const now = new Date();
    const due = new Date(nextDue);
    const daysLeft = Math.ceil((due - now) / (1000 * 60 * 60 * 24));
    if (daysLeft < 0)   return `<span class="badge bg-danger">${Math.abs(daysLeft)}d overdue</span>`;
    if (daysLeft === 0) return `<span class="badge bg-warning text-dark">Due today</span>`;
    if (daysLeft <= 7)  return `<span class="badge bg-warning text-dark">${daysLeft}d</span>`;
    return `<span class="text-muted small">${due.toLocaleDateString()}</span>`;
  }
%>

<!-- Page header -->
<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
  <div>
    <h1 class="h2 mb-1"><i class="bi bi-building me-2"></i><%= site.SiteName %></h1>
    <div class="d-flex gap-2 flex-wrap">
      <%- statusBadge(site.SiteStatusName) %>
      <% if (site.WarrantyExpires) { %><%- warrantyBadge(site.WarrantyExpires) %><% } %>
      <% if (site.SiteTypeName) { %>
        <span class="badge bg-body-secondary text-body border"><%= site.SiteTypeName %></span>
      <% } %>
    </div>
  </div>
  <% if (isAdminUser) { %>
  <div class="d-flex gap-2 flex-wrap">
    <a href="/sites/<%= site.SiteID %>/edit" class="btn btn-sm btn-outline-primary">
      <i class="bi bi-pencil me-1"></i>Edit
    </a>
    <form method="POST" action="/sites/<%= site.SiteID %>/delete"
          data-confirm="Delete this site? This action cannot be undone.">
      <button type="submit" class="btn btn-sm btn-outline-danger">
        <i class="bi bi-trash me-1"></i>Delete
      </button>
    </form>
  </div>
  <% } %>
</div>

<% if (site.ParentSiteID) { %>
<a href="/sites/<%= site.ParentSiteID %>" class="text-decoration-none text-muted small">
  <i class="bi bi-arrow-left me-1"></i>Back to <%= site.ParentSiteName || 'Parent Site' %>
</a>
<% } else { %>
<a href="/sites" class="text-decoration-none text-muted small">
  <i class="bi bi-arrow-left me-1"></i>Back to Sites
</a>
<% } %>

<!-- Tabs -->
<ul class="nav nav-tabs mt-3" id="siteTab" role="tablist">
  <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#overview">Overview</a></li>
  <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#logs" id="logs-tab">Log Entries</a></li>
  <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#network-resources">Network Resources</a></li>
  <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#equipment">Installed Equipment</a></li>
  <% if (!site.ParentSiteID) { %>
  <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#subsites">Sub-Sites</a></li>
  <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#pm">PM Schedules</a></li>
  <% } %>
  <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#docs">Documents & Photos</a></li>
</ul>

<div class="tab-content border border-top-0 rounded-bottom p-3 bg-body shadow-sm">

  <!-- ── Overview ─────────────────────────────────────────────────────────── -->
  <div class="tab-pane fade show active" id="overview">
    <div class="row g-3 mt-1">

      <!-- Address / Location -->
      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-header small fw-semibold">
            <i class="bi bi-geo-alt me-1"></i>Location
          </div>
          <div class="card-body small">
            <% if (site.Address || site.City || site.State) { %>
              <div><%= site.Address || '' %></div>
              <div><%= [site.City, site.State, site.ZipCode].filter(Boolean).join(', ') %></div>
            <% } else { %>
              <span class="text-muted">No address on record.</span>
            <% } %>
            <% if (site.Latitude && site.Longitude) { %>
              <div class="mt-2 text-muted">
                GPS: <%= site.Latitude %>, <%= site.Longitude %>
                <a href="https://maps.google.com/?q=<%= site.Latitude %>,<%= site.Longitude %>"
                   target="_blank" class="ms-1">
                  <i class="bi bi-box-arrow-up-right"></i>
                </a>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Status / Warranty -->
      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-header small fw-semibold">
            <i class="bi bi-info-circle me-1"></i>Details
          </div>
          <div class="card-body small">
            <dl class="row mb-0">
              <dt class="col-sm-5 text-muted">Status</dt>
              <dd class="col-sm-7"><%- statusBadge(site.SiteStatusName) %></dd>

              <dt class="col-sm-5 text-muted">Type</dt>
              <dd class="col-sm-7"><%= site.SiteTypeName || '—' %></dd>

              <% if (site.SiteNumber) { %>
              <dt class="col-sm-5 text-muted">Site #</dt>
              <dd class="col-sm-7"><%= site.SiteNumber %></dd>
              <% } %>

              <% if (site.ContractNumber) { %>
              <dt class="col-sm-5 text-muted">Contract #</dt>
              <dd class="col-sm-7"><%= site.ContractNumber %></dd>
              <% } %>

              <dt class="col-sm-5 text-muted">Warranty</dt>
              <dd class="col-sm-7">
                <%- warrantyBadge(site.WarrantyExpires) %>
                <% if (site.WarrantyExpires) { %>
                  <span class="ms-1 text-muted">(<%= new Date(site.WarrantyExpires).toLocaleDateString() %>)</span>
                <% } %>
              </dd>

              <dt class="col-sm-5 text-muted">Created</dt>
              <dd class="col-sm-7"><%= site.CreatedAt ? new Date(site.CreatedAt).toLocaleDateString() : '—' %></dd>

              <% if (site.CreatedByName) { %>
              <dt class="col-sm-5 text-muted">Created By</dt>
              <dd class="col-sm-7"><%= site.CreatedByName %></dd>
              <% } %>
            </dl>
          </div>
        </div>
      </div>

      <!-- Description -->
      <% if (site.Description) { %>
      <div class="col-12">
        <div class="card">
          <div class="card-header small fw-semibold">
            <i class="bi bi-text-left me-1"></i>Description
          </div>
          <div class="card-body small" style="white-space: pre-wrap;"><%= site.Description %></div>
        </div>
      </div>
      <% } %>

    </div>
  </div>

  <!-- ── Log Entries ──────────────────────────────────────────────────────── -->
  <div class="tab-pane fade" id="logs">
    <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
      <h6 class="mb-0">Recent Log Entries</h6>
      <% if (canWriteUser) { %>
        <a href="/sites/<%= site.SiteID %>/logs/new" class="btn btn-sm btn-primary">
          <i class="bi bi-plus-lg me-1"></i>New Log Entry
        </a>
      <% } %>
    </div>

    <% if (!recentLogs || recentLogs.length === 0) { %>
      <p class="text-muted">No log entries yet.</p>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover table-sm align-middle">
        <thead>
          <tr>
            <th>Type</th>
            <th>Date</th>
            <th>Subject</th>
            <th>Performed By</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% recentLogs.forEach(log => { %>
          <tr>
            <td><%- logTypeBadge(log.TypeName) %></td>
            <td class="small text-muted text-nowrap">
              <%= log.EntryDate ? new Date(log.EntryDate).toLocaleDateString('en-US', { timeZone: 'UTC' }) : '—' %>
            </td>
            <td class="small"><%= log.Subject || '—' %></td>
            <td class="small text-muted"><%= log.PerformedBy || '—' %></td>
            <td>
              <a href="/sites/<%= site.SiteID %>/logs/<%= log.LogEntryID %>"
                 class="btn btn-xs btn-outline-secondary btn-sm">View</a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <!-- ── Installed Equipment ──────────────────────────────────────────────── -->
  <div class="tab-pane fade" id="equipment">
    <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
      <h6 class="mb-0">Currently Installed Equipment</h6>
      <% if (isAdminUser) { %>
        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#installModal">
          <i class="bi bi-plus-lg me-1"></i>Install Item
        </button>
      <% } %>
    </div>

    <% if (!inventory || inventory.length === 0) { %>
      <p class="text-muted">No equipment currently installed at this site.</p>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover table-sm align-middle">
        <thead>
          <tr>
            <th>Item</th>
            <th>Category</th>
            <th class="text-center">Qty</th>
            <th>Installed</th>
            <th>Installed By</th>
            <% if (isAdminUser) { %><th></th><% } %>
          </tr>
        </thead>
        <tbody>
          <% inventory.forEach(item => { %>
          <tr>
            <td>
              <a href="/inventory/<%= item.ItemID %>" class="text-decoration-none fw-semibold">
                <%= item.CommonName || item.ModelNumber || item.SerialNumber || '(no name)' %>
              </a>
              <% if (item.TrackingType === 'bulk') { %>
                <span class="badge bg-info text-dark small ms-1">FRU</span>
              <% } %>
              <div class="small text-muted">
                <% if (item.TrackingType !== 'bulk' && item.SerialNumber) { %><%= item.SerialNumber %><% if (item.Manufacturer) { %> &bull; <% } %><% } %>
                <%= item.Manufacturer || '' %>
              </div>
            </td>
            <td class="small"><%= item.CategoryName || '—' %></td>
            <td class="text-center small fw-semibold"><%= item.Quantity || 1 %></td>
            <td class="small text-muted text-nowrap">
              <%= item.InstalledAt ? new Date(item.InstalledAt).toLocaleDateString() : '—' %>
            </td>
            <td class="small text-muted"><%= item.InstalledByName || '—' %></td>
            <% if (isAdminUser) { %>
            <td>
              <div class="d-flex gap-1">
              <% if (item.TrackingType === 'bulk') { %>
                <button type="button" class="btn btn-sm btn-outline-danger"
                        data-bs-toggle="modal" data-bs-target="#removeBulkModal"
                        data-item-id="<%= item.ItemID %>"
                        data-item-name="<%= (item.CommonName || item.ModelNumber || item.Manufacturer || 'Item') %>"
                        data-max-qty="<%= item.Quantity %>">
                  <i class="bi bi-dash-circle me-1"></i>Remove
                </button>
                <button type="button" class="btn btn-sm btn-outline-warning"
                        data-bs-toggle="modal" data-bs-target="#replaceBulkModal"
                        data-item-id="<%= item.ItemID %>"
                        data-item-name="<%= (item.CommonName || item.ModelNumber || item.Manufacturer || 'Item') %>"
                        data-max-qty="<%= item.Quantity %>">
                  <i class="bi bi-arrow-repeat me-1"></i>Replace
                </button>
              <% } else { %>
                <form method="POST" action="/sites/<%= site.SiteID %>/inventory/<%= item.SiteInventoryID %>/remove"
                      data-confirm="Remove this item from the site?">
                  <button type="submit" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-dash-circle me-1"></i>Remove
                  </button>
                </form>
                <button type="button" class="btn btn-sm btn-outline-warning"
                        data-bs-toggle="modal" data-bs-target="#replaceModal"
                        data-si-id="<%= item.SiteInventoryID %>"
                        data-serial="<%= item.SerialNumber %>"
                        data-model="<%= item.ModelNumber || '' %>">
                  <i class="bi bi-arrow-repeat me-1"></i>Replace
                </button>
              <% } %>
              </div>
            </td>
            <% } %>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>

    <!-- Sub-site equipment (parent sites only) -->
    <% if (subsiteInventory && subsiteInventory.some(s => s.items.length > 0)) { %>
      <% subsiteInventory.forEach(({ sub, items }) => { %>
        <% if (items.length > 0) { %>
        <h6 class="mt-4 mb-2 d-flex align-items-center gap-2">
          <i class="bi bi-diagram-2 text-muted"></i>
          <a href="/sites/<%= sub.SiteID %>" class="text-decoration-none"><%= sub.SiteName %></a>
          <% if (sub.SiteTypeName) { %>
            <span class="badge bg-body-secondary text-body fw-normal" style="font-size:.7rem"><%= sub.SiteTypeName %></span>
          <% } %>
        </h6>
        <div class="table-responsive mb-2">
          <table class="table table-hover table-sm align-middle">
            <thead>
              <tr>
                <th>Item</th>
                <th>Category</th>
                <th class="text-center">Qty</th>
                <th>Installed</th>
                <th>Installed By</th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach(item => { %>
              <tr>
                <td>
                  <a href="/inventory/<%= item.ItemID %>" class="text-decoration-none fw-semibold">
                    <%= item.CommonName || item.ModelNumber || item.SerialNumber || '(no name)' %>
                  </a>
                  <% if (item.TrackingType === 'bulk') { %>
                    <span class="badge bg-info text-dark small ms-1">FRU</span>
                  <% } %>
                  <div class="small text-muted">
                    <% if (item.TrackingType !== 'bulk' && item.SerialNumber) { %><%= item.SerialNumber %><% if (item.Manufacturer) { %> &bull; <% } %><% } %>
                    <%= item.Manufacturer || '' %>
                  </div>
                </td>
                <td class="small"><%= item.CategoryName || '—' %></td>
                <td class="text-center small fw-semibold"><%= item.Quantity || 1 %></td>
                <td class="small text-muted text-nowrap">
                  <%= item.InstalledAt ? new Date(item.InstalledAt).toLocaleDateString() : '—' %>
                </td>
                <td class="small text-muted"><%= item.InstalledByName || '—' %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      <% }) %>
    <% } %>
  </div>

  <!-- ── Sub-Sites (parent sites only) ───────────────────────────────────── -->
  <% if (!site.ParentSiteID) { %>
  <div class="tab-pane fade" id="subsites">
    <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
      <h6 class="mb-0">Sub-Sites</h6>
      <% if (isAdminUser) { %>
        <a href="/sites/new?parentSiteID=<%= site.SiteID %>" class="btn btn-sm btn-primary">
          <i class="bi bi-plus-lg me-1"></i>Add Sub-Site
        </a>
      <% } %>
    </div>

    <% if (!subsites || subsites.length === 0) { %>
      <p class="text-muted">No sub-sites yet.</p>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover table-sm align-middle">
        <thead>
          <tr>
            <th>Name</th>
            <th>Status</th>
            <th>Type</th>
          </tr>
        </thead>
        <tbody>
          <% subsites.forEach(sub => { %>
          <tr>
            <td>
              <a href="/sites/<%= sub.SiteID %>" class="text-decoration-none fw-semibold">
                <%= sub.SiteName %>
              </a>
            </td>
            <td><%- statusBadge(sub.StatusName) %></td>
            <td class="small text-muted"><%= sub.SiteTypeName || '—' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <!-- ── PM Schedules ─────────────────────────────────────────────────────── -->
  <div class="tab-pane fade" id="pm">
    <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
      <h6 class="mb-0">Preventive Maintenance Schedules</h6>
      <% if (isAdminUser) { %>
        <button type="button" class="btn btn-sm btn-primary"
                data-bs-toggle="modal" data-bs-target="#pmModal">
          <i class="bi bi-plus-lg me-1"></i>Add Schedule
        </button>
      <% } %>
    </div>

    <% if (!pmSchedules || pmSchedules.length === 0) { %>
      <p class="text-muted">No PM schedules configured for this site.</p>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover table-sm align-middle">
        <thead>
          <tr>
            <th>Title</th>
            <th>Frequency</th>
            <th>Last Performed</th>
            <th>Next Due</th>
            <th>Assigned To</th>
            <% if (isAdminUser) { %><th></th><% } %>
          </tr>
        </thead>
        <tbody>
          <% pmSchedules.forEach(pm => { %>
          <%
            const lastPerf = pm.LastPerformedAt ? new Date(pm.LastPerformedAt) : null;
            const nextDue  = pm.NextDueDate ? new Date(pm.NextDueDate) : null;
          %>
          <tr>
            <td class="fw-semibold small"><%= pm.Title %></td>
            <td class="small text-muted"><%= pm.FrequencyDays ? `Every ${pm.FrequencyDays} days` : '—' %></td>
            <td class="small text-muted text-nowrap">
              <%= lastPerf ? lastPerf.toLocaleDateString() : 'Never' %>
            </td>
            <td><%- pmDueBadge(nextDue) %></td>
            <td class="small text-muted"><%= pm.AssignedUserName || pm.AssignedVendorName || '—' %></td>
            <% if (isAdminUser) { %>
            <td>
              <div class="d-flex gap-1">
                <button type="button" class="btn btn-sm btn-outline-success py-0"
                        data-bs-toggle="modal" data-bs-target="#pmCompleteModal"
                        data-schedule-id="<%= pm.ScheduleID %>"
                        data-title="<%= pm.Title %>">
                  <i class="bi bi-check-lg"></i> Complete
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary py-0"
                        data-bs-toggle="modal" data-bs-target="#pmEditModal"
                        data-schedule-id="<%= pm.ScheduleID %>"
                        data-title="<%= pm.Title %>"
                        data-frequency="<%= pm.FrequencyDays %>"
                        data-assigned-to="<%= pm.AssignedUserID ? 'user:' + pm.AssignedUserID : (pm.AssignedVendorID ? 'vendor:' + pm.AssignedVendorID : '') %>"
                        data-notes="<%= pm.Notes || '' %>"
                        data-next-due-date="<%= pm.NextDueDate ? new Date(pm.NextDueDate).toISOString().split('T')[0] : '' %>">
                  <i class="bi bi-pencil"></i>
                </button>
                <form method="POST" action="/sites/<%= site.SiteID %>/pm/<%= pm.ScheduleID %>"
                      data-confirm="Delete this PM schedule?">
                  <input type="hidden" name="action" value="delete" />
                  <button type="submit" class="btn btn-sm btn-outline-danger py-0">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </div>
            </td>
            <% } %>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
  <% } %>

  <!-- ── Documents & Photos ───────────────────────────────────────────────── -->
  <div class="tab-pane fade" id="docs">
    <div class="mt-2">
      <%- include('../partials/fileList', {
        documents:  documents,
        uploadUrl:  `/documents/upload`,
        canUpload:  canWriteUser,
        entityType: 'site',
        entityId:   site.SiteID,
        returnTo:   `/sites/${site.SiteID}#docs`
      }) %>
    </div>
  </div>

  <!-- ── Network Resources ───────────────────────────────────────────────── -->
  <div class="tab-pane fade" id="network-resources">
    <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
      <h6 class="mb-0">
        <i class="bi bi-broadcast-pin me-1"></i>Network Resources
        <% if (site.MonitoringLocationTypeName) { %>
          <span class="badge bg-body-secondary text-body border ms-1"><%= site.MonitoringLocationTypeName %></span>
        <% } else { %>
          <span class="badge bg-warning text-dark ms-1" title="Set Monitoring Location Type on the Edit page to include this site on the tower map">Not on Tower Map</span>
        <% } %>
      </h6>
      <% if (isAdminUser) { %>
      <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addResourceModal">
        <i class="bi bi-plus-lg me-1"></i>Add Resource
      </button>
      <% } %>
    </div>

    <div id="networkResourceTableWrapper">
      <% if (networkResources && networkResources.length > 0) { %>
      <table class="table table-sm table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>Hostname</th>
            <th>IP Address</th>
            <th>Type</th>
            <th>Alert Status</th>
            <th>SolarWinds ID</th>
            <th>Circuit Type</th>
            <th>Circuit ID</th>
            <% if (isAdminUser) { %><th class="text-end">Actions</th><% } %>
          </tr>
        </thead>
        <tbody id="networkResourceTbody">
          <% networkResources.forEach(r => { %>
          <tr data-res-id="<%= r.ResourceID %>">
            <td class="fw-semibold"><%= r.Hostname %></td>
            <td class="font-monospace small"><%= r.IPAddress || '—' %></td>
            <td><span class="badge bg-body-secondary text-body border"><%= r.DeviceTypeName %></span></td>
            <td>
              <% if (r.AlertStatus) { %>
                <span class="badge bg-danger">Yes</span>
              <% } else { %>
                <span class="badge bg-secondary">No</span>
              <% } %>
            </td>
            <td class="small"><%= r.SolarwindsNodeId || '—' %></td>
            <td class="small"><%= r.CircuitTypeName || '—' %></td>
            <td class="small"><%= r.CircuitID || '—' %></td>
            <% if (isAdminUser) { %>
            <td class="text-end text-nowrap">
              <% if (r.Notes) { %>
              <button class="btn btn-sm btn-link p-0 me-2 text-muted" title="<%= r.Notes.replace(/"/g, '&quot;') %>"
                      data-bs-toggle="tooltip"><i class="bi bi-sticky me-1"></i></button>
              <% } %>
              <button class="btn btn-sm btn-outline-secondary py-0 me-1 js-edit-resource"
                data-id="<%= r.ResourceID %>"
                data-hostname="<%= r.Hostname %>"
                data-ip="<%= r.IPAddress || '' %>"
                data-device-type-id="<%= r.DeviceTypeID %>"
                data-alert-status="<%= r.AlertStatus ? '1' : '0' %>"
                data-solarwinds-node-id="<%= r.SolarwindsNodeId != null ? r.SolarwindsNodeId : '' %>"
                data-sort-order="<%= r.SortOrder != null ? r.SortOrder : 0 %>"
                data-circuit-type-id="<%= r.CircuitTypeID || '' %>"
                data-circuit-id="<%= r.CircuitID || '' %>"
                data-notes="<%= (r.Notes || '').replace(/"/g, '&quot;') %>">
