<div class="modal fade" id="removeBulkModal" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-dash-circle me-2 text-danger"></i>Remove Equipment</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" id="removeBulkForm">
        <div class="modal-body">
          <p class="small mb-2">
            Removing <strong id="removeBulkName"></strong> from this site.<br>
            <span class="text-muted">Currently installed: <strong id="removeBulkMax"></strong> unit(s)</span>
          </p>
          <div class="mb-3">
            <label class="form-label small">Quantity to remove</label>
            <input type="number" name="quantity" id="removeBulkQty"
                   class="form-control" min="1" value="1" required />
          </div>
          <div>
            <label class="form-label small">After removal</label>
            <div class="d-flex flex-column gap-1">
              <div class="form-check">
                <input class="form-check-input" type="radio" name="disposition" id="dispReturn" value="return" checked>
                <label class="form-check-label small" for="dispReturn">Return to inventory (unallocated)</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="disposition" id="dispDelete" value="delete">
                <label class="form-check-label small" for="dispDelete">Delete from inventory</label>
              </div>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-sm btn-danger">Remove</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ── Replace Bulk Item Modal ───────────────────────────────────────────────── -->
<div class="modal fade" id="replaceBulkModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-arrow-repeat me-2 text-warning"></i>Replace Bulk / FRU Units</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" id="replaceBulkForm">
        <div class="modal-body">
          <p class="small text-muted mb-3">
            Replacing units of: <strong id="replaceBulkName"></strong>
            &nbsp;·&nbsp; Installed: <strong id="replaceBulkInstalled"></strong>
          </p>

          <div class="row g-3">
            <div class="col-sm-4">
              <label class="form-label small fw-semibold">Units to replace <span class="text-danger">*</span></label>
              <input type="number" name="replaceQty" id="replaceBulkQty"
                     class="form-control form-control-sm" min="1" value="1" required />
            </div>
            <div class="col-sm-4">
              <label class="form-label small fw-semibold">Replacement qty to install</label>
              <input type="number" name="installQty" id="replaceBulkInstallQty"
                     class="form-control form-control-sm" min="0" value="1" />
              <div class="form-text">Leave blank to match replaced qty.</div>
            </div>
          </div>

          <div class="mt-3">
            <label class="form-label small fw-semibold">Pull replacement from</label>
            <select name="pulledFrom" id="replaceBulkPullFrom" class="form-select form-select-sm">
              <option value="">— Unallocated / General Stock —</option>
            </select>
          </div>

          <div class="mt-3">
            <label class="form-label small">Install notes (optional)</label>
            <textarea name="installNotes" class="form-control form-control-sm" rows="2"></textarea>
          </div>

          <hr class="my-3" />

          <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" name="startRepair" value="1"
                   id="replaceBulkRepairCheck" />
            <label class="form-check-label fw-semibold" for="replaceBulkRepairCheck">
              Send replaced units for repair / start RMA(s)
            </label>
          </div>
          <div id="replaceBulkRepairGroup" style="display:none" class="ms-4">
            <div class="alert alert-info py-2 small mb-2" id="replaceBulkRmaNote"></div>
            <label class="form-label small">Reason for repair <span class="text-danger">*</span></label>
            <textarea name="repairReason" id="replaceBulkReasonInput"
                      class="form-control form-control-sm" rows="2"
                      placeholder="Describe the fault or reason..."></textarea>
            <div class="form-text">You'll be taken to the first RMA to finish filling in details.</div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-warning btn-sm">
            <i class="bi bi-arrow-repeat me-1"></i>Replace Units
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ── Replace Item Modal ─────────────────────────────────────────────────── -->
<div class="modal fade" id="replaceModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-arrow-repeat me-2 text-warning"></i>Replace Equipment</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" id="replaceForm">
        <div class="modal-body">
          <p class="small text-muted mb-3">
            Replacing: <strong id="replaceItemLabel"></strong>
          </p>

          <!-- Replacement item select -->
          <div class="mb-3">
            <label class="form-label fw-semibold">Replacement Item <span class="text-danger">*</span></label>
            <% const replaceableItems = (inStockItems || []).filter(i => i.TrackingType !== 'bulk'); %>
            <% if (replaceableItems.length === 0) { %>
              <p class="text-muted small">No serialized items currently in stock. Add inventory first.</p>
            <% } else { %>
              <input type="text" id="replaceSearch" class="form-control form-control-sm mb-1"
                     placeholder="Filter by serial, model, manufacturer..." autocomplete="off" />
              <select name="replacementItemID" id="replaceSelect" class="form-select" required size="5">
                <% replaceableItems.forEach(ri => { %>
                <option value="<%= ri.ItemID %>"
                  data-search="<%= ((ri.CommonName||'') + ' ' + (ri.SerialNumber||'') + ' ' + (ri.ModelNumber||'') + ' ' + (ri.Manufacturer||'')).toLowerCase() %>">
                  <%= ri.SerialNumber || '(no serial)' %>
                  <% if (ri.CommonName) { %> — <%= ri.CommonName %><% } %>
                  <% if (ri.ModelNumber) { %> (<%= ri.ModelNumber %><% if (ri.Manufacturer) { %>/<%= ri.Manufacturer %><% } %>)<% } else if (ri.Manufacturer) { %> (<%= ri.Manufacturer %>)<% } %>
                  <% if (ri.StockLocationName) { %> [<%= ri.StockLocationName %>]<% } %>
                </option>
                <% }) %>
              </select>
            <% } %>
          </div>

          <!-- Install notes -->
          <div class="mb-3">
            <label class="form-label small">Install Notes (optional)</label>
            <textarea name="installNotes" class="form-control form-control-sm" rows="2"></textarea>
          </div>

          <!-- Start RMA checkbox -->
          <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" name="startRepair" value="1" id="startRepairCheck" />
            <label class="form-check-label fw-semibold" for="startRepairCheck">
              Send replaced item for repair / start RMA
            </label>
          </div>
          <div id="repairReasonGroup" style="display:none" class="ms-4 mb-2">
            <label class="form-label small">Reason for repair <span class="text-danger">*</span></label>
            <textarea name="repairReason" id="repairReasonInput" class="form-control form-control-sm" rows="2"
                      placeholder="Describe the fault or reason for sending to repair..."></textarea>
            <div class="form-text">You'll be taken to the RMA record to finish filling in details.</div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-warning btn-sm" id="replaceSubmitBtn">
            <i class="bi bi-arrow-repeat me-1"></i>Replace Item
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>

  // Replace modal — populate from data attributes and wire up checkbox/search
  var replaceModal = document.getElementById('replaceModal');
  if (replaceModal) {
    replaceModal.addEventListener('show.bs.modal', function (e) {
      var btn    = e.relatedTarget;
      var siID   = btn.dataset.siId;
      var serial = btn.dataset.serial;
      var model  = btn.dataset.model;
      var label  = serial + (model ? ' — ' + model : '');
      document.getElementById('replaceItemLabel').textContent = label;
      document.getElementById('replaceForm').action =
        `/sites/<%= site.SiteID %>/inventory/${siID}/replace`;
      // Reset state
      document.getElementById('startRepairCheck').checked = false;
      document.getElementById('repairReasonGroup').style.display = 'none';
      document.getElementById('repairReasonInput').required = false;
    });

    document.getElementById('startRepairCheck').addEventListener('change', function () {
      var group = document.getElementById('repairReasonGroup');
      var input = document.getElementById('repairReasonInput');
      group.style.display = this.checked ? '' : 'none';
      input.required = this.checked;
    });

    var replaceSearch = document.getElementById('replaceSearch');
    if (replaceSearch) {
      replaceSearch.addEventListener('input', function () {
        var q = this.value.toLowerCase();
        document.querySelectorAll('#replaceSelect option').forEach(function (opt) {
          opt.hidden = q.length > 0 && !opt.dataset.search.includes(q);
        });
      });
    }
  }

  // PM Complete modal
  var pmCompleteModal = document.getElementById('pmCompleteModal');
  if (pmCompleteModal) {
    pmCompleteModal.addEventListener('show.bs.modal', function (e) {
      var btn = e.relatedTarget;
      document.getElementById('pmCompleteTitle').textContent = btn.dataset.title;
      document.getElementById('pmCompleteDate').value = new Date().toISOString().slice(0, 10);
      document.getElementById('pmCompleteForm').action =
        '/sites/<%= site.SiteID %>/pm/' + btn.dataset.scheduleId;
    });
  }

  // PM Edit modal
  var pmEditModal = document.getElementById('pmEditModal');
  if (pmEditModal) {
    pmEditModal.addEventListener('show.bs.modal', function (e) {
      var btn = e.relatedTarget;
      document.getElementById('pmEditTitle').value    = btn.dataset.title;
      document.getElementById('pmEditFreq').value     = btn.dataset.frequency;
      document.getElementById('pmEditNotes').value    = btn.dataset.notes;
      document.getElementById('pmEditAssignedTo').value = btn.dataset.assignedTo || '';
      document.getElementById('pmEditNextDate').value = btn.dataset.nextDueDate || '';
      document.getElementById('pmEditForm').action =
        '/sites/<%= site.SiteID %>/pm/' + btn.dataset.scheduleId;
    });
  }

  // Replace Bulk modal
  var replaceBulkModal = document.getElementById('replaceBulkModal');
  if (replaceBulkModal) {
    // Stock data from server for pull-from options
    var stockByItem  = <%- JSON.stringify(stockByItem || {}) %>;
    var availByItem  = <%- JSON.stringify(Object.fromEntries((inStockItems||[]).filter(i=>i.TrackingType==='bulk').map(i=>[i.ItemID, i.QuantityAvailable||0]))) %>;

    replaceBulkModal.addEventListener('show.bs.modal', function (e) {
      var btn    = e.relatedTarget;
      var itemID = btn.dataset.itemId;
      var name   = btn.dataset.itemName;
      var maxQty = parseInt(btn.dataset.maxQty, 10);

      document.getElementById('replaceBulkName').textContent      = name;
      document.getElementById('replaceBulkInstalled').textContent = maxQty;
      document.getElementById('replaceBulkQty').max               = maxQty;
      document.getElementById('replaceBulkQty').value             = 1;
      document.getElementById('replaceBulkInstallQty').value      = 1;
      document.getElementById('replaceBulkRepairCheck').checked   = false;
      document.getElementById('replaceBulkRepairGroup').style.display = 'none';
      document.getElementById('replaceBulkReasonInput').required  = false;
      document.getElementById('replaceBulkForm').action =
        `/sites/<%= site.SiteID %>/inventory/${itemID}/replace-bulk`;

      // Populate pull-from select
      var sel = document.getElementById('replaceBulkPullFrom');
      var rows = stockByItem[itemID] || [];
      var totalAllocated = rows.reduce(function(sum, s) { return sum + (s.Quantity || 0); }, 0);
      var unallocQty = (availByItem[itemID] || 0) - totalAllocated;
      sel.innerHTML = '<option value="">— Unallocated (' + unallocQty + ' avail) —</option>';
      rows.forEach(function (s) {
        var opt = document.createElement('option');
        if (s.LocationID) {
          opt.value = 'location:' + s.LocationID;
          opt.textContent = s.LocationName + ' (' + s.Quantity + ' avail)';
        } else if (s.UserID) {
          opt.value = 'user:' + s.UserID;
          opt.textContent = s.UserDisplayName + ' (' + s.Quantity + ' avail)';
        }
        sel.appendChild(opt);
      });
    });

    document.getElementById('replaceBulkRepairCheck').addEventListener('change', function () {
      var group  = document.getElementById('replaceBulkRepairGroup');
      var input  = document.getElementById('replaceBulkReasonInput');
      var note   = document.getElementById('replaceBulkRmaNote');
      group.style.display = this.checked ? '' : 'none';
      input.required = this.checked;
      if (this.checked) {
        var qty = parseInt(document.getElementById('replaceBulkQty').value, 10) || 1;
        note.textContent = qty === 1
          ? '1 RMA record will be created.'
          : qty + ' separate RMA records will be created (one per replaced unit).';
      }
    });

    document.getElementById('replaceBulkQty').addEventListener('input', function () {
      var check = document.getElementById('replaceBulkRepairCheck');
      if (check.checked) {
        var qty  = parseInt(this.value, 10) || 1;
        var note = document.getElementById('replaceBulkRmaNote');
        note.textContent = qty === 1
          ? '1 RMA record will be created.'
          : qty + ' separate RMA records will be created (one per replaced unit).';
      }
      // Keep install qty in sync by default
      var installInput = document.getElementById('replaceBulkInstallQty');
      if (!installInput._manuallyChanged) installInput.value = this.value;
    });

    document.getElementById('replaceBulkInstallQty').addEventListener('change', function () {
      this._manuallyChanged = true;
    });
  }

  // Remove bulk modal — populate from data attributes
  document.getElementById('removeBulkModal').addEventListener('show.bs.modal', function (e) {
    const btn    = e.relatedTarget;
    const itemID = btn.dataset.itemId;
    const name   = btn.dataset.itemName;
    const max    = parseInt(btn.dataset.maxQty, 10);
    document.getElementById('removeBulkName').textContent = name;
    document.getElementById('removeBulkMax').textContent  = max;
    document.getElementById('removeBulkQty').max          = max;
    document.getElementById('removeBulkQty').value        = max;
    document.getElementById('removeBulkForm').action      =
      `/sites/<%= site.SiteID %>/inventory/${itemID}/remove-bulk`;
  });

  // Filter in-stock items list
  const stockSearch = document.getElementById('stockSearch');
  if (stockSearch) {
    stockSearch.addEventListener('input', function () {
      const q = this.value.toLowerCase();
      document.querySelectorAll('#stockSelect option').forEach(opt => {
        opt.hidden = q.length > 0 && !opt.dataset.search.includes(q);
      });
      // Deselect hidden option if it's currently selected
      const sel = document.getElementById('stockSelect');
      if (sel.selectedOptions.length && sel.selectedOptions[0].hidden) {
        sel.value = '';
      }
    });
  }

  // Activate tab from URL hash on load
  const hash = window.location.hash;
  if (hash) {
    const tabEl = document.querySelector('.nav-link[href="' + hash + '"]');
    if (tabEl) bootstrap.Tab.getOrCreateInstance(tabEl).show();
  }
</script>
