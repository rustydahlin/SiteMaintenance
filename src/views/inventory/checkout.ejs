<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">
    <i class="bi bi-box-arrow-right me-2"></i>Check Out — <%= item.SerialNumber %>
  </h1>
  <a href="/inventory/<%= item.ItemID %>" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Cancel
  </a>
</div>

<div class="card shadow-sm" style="max-width: 600px;">
  <div class="card-body">
    <p class="text-muted small mb-3">
      <strong><%= item.SerialNumber %></strong>
      <% if (item.ModelNumber) { %> — <%= item.ModelNumber %><% } %>
      <% if (item.Manufacturer) { %> (<%= item.Manufacturer %>)<% } %>
    </p>

    <form method="POST" action="/inventory/<%= item.ItemID %>/checkout" novalidate>

      <div class="mb-3">
        <label for="userID" class="form-label">
          Check Out To <span class="text-danger">*</span>
        </label>
        <select id="userID" name="userID" class="form-select" required>
          <option value="">— Select User —</option>
          <% users.forEach(u => { %>
            <option value="<%= u.UserID %>"><%= u.DisplayName %> (<%= u.Username %>)</option>
          <% }) %>
        </select>
      </div>

      <div class="mb-3">
        <label for="pulledFromLocationID" class="form-label">Pull From Stock Location</label>
        <select id="pulledFromLocationID" name="pulledFromLocationID" class="form-select">
          <option value="">— Not pulling from stock —</option>
          <% locations.forEach(l => { %>
            <option value="<%= l.LocationID %>"
              <%= item.StockLocationID == l.LocationID ? 'selected' : '' %>>
              <%= l.LocationName %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="mb-3">
        <label for="notes" class="form-label">Notes</label>
        <textarea id="notes" name="notes" class="form-control" rows="3" maxlength="1000"></textarea>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-warning">
          <i class="bi bi-box-arrow-right me-1"></i>Check Out
        </button>
        <a href="/inventory/<%= item.ItemID %>" class="btn btn-outline-secondary">Cancel</a>
      </div>

    </form>
  </div>
</div>
