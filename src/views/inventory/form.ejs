<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">
    <i class="bi bi-box-seam me-2"></i>
    <%= item ? `Edit Item — ${item.SerialNumber}` : 'Add Inventory Item' %>
  </h1>
  <a href="<%= item ? `/inventory/${item.ItemID}` : '/inventory' %>" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Cancel
  </a>
</div>

<div class="card shadow-sm">
  <div class="card-body">
    <form method="POST" action="<%= action %>" novalidate>

      <%
        const isBulkItem = item && item.TrackingType === 'bulk';
      %>

      <!-- Tracking Type -->
      <div class="row g-3 mb-3 pb-3 border-bottom">
        <div class="col-12">
          <label class="form-label fw-semibold">Item Type</label>
          <div class="d-flex gap-4">
            <div class="form-check">
              <input class="form-check-input" type="radio" name="trackingType" id="typeSerial"
                     value="serialized" <%= !isBulkItem ? 'checked' : '' %> />
              <label class="form-check-label" for="typeSerial">
                <strong>Serialized / Asset-Tracked</strong>
                <div class="small text-muted">Tracked individually by serial number and asset tag</div>
              </label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="radio" name="trackingType" id="typeBulk"
                     value="bulk" <%= isBulkItem ? 'checked' : '' %> />
              <label class="form-check-label" for="typeBulk">
                <strong>Bulk / FRU</strong>
                <div class="small text-muted">Field Replaceable Unit — tracked by quantity, not individual serial numbers</div>
              </label>
            </div>
          </div>
        </div>
      </div>

      <div class="row g-3">

        <!-- Common Name (required for all) -->
        <div class="col-md-4">
          <label for="commonName" class="form-label">
            Common Name <span class="text-danger">*</span>
          </label>
          <select id="commonName" name="commonName" class="form-select" required>
            <option value="">— Select Common Name —</option>
            <% (typeof commonNames !== 'undefined' ? commonNames : []).forEach(n => { %>
              <option value="<%= n.Name %>"
                <%= (item && item.CommonName === n.Name) ? 'selected' : '' %>>
                <%= n.Name %>
              </option>
            <% }) %>
          </select>
          <div class="form-text">Manage options in <a href="/admin/inventory/common-names" target="_blank">Admin → Inventory</a>.</div>
        </div>

        <!-- Serial Number (serialized only) -->
        <div class="col-md-4" id="fieldSerialNumber">
          <label for="serialNumber" class="form-label">Serial Number</label>
          <input type="text" id="serialNumber" name="serialNumber"
                 class="form-control"
                 value="<%= item ? (item.SerialNumber || '') : '' %>"
                 maxlength="100" />
        </div>

        <!-- Asset Tag (serialized only) -->
        <div class="col-md-4" id="fieldAssetTag">
          <label for="assetTag" class="form-label">Asset Tag #</label>
          <input type="text" id="assetTag" name="assetTag"
                 class="form-control"
                 value="<%= item ? (item.AssetTag || '') : '' %>"
                 maxlength="100" />
        </div>

        <!-- Quantity Total (bulk only) -->
        <div class="col-md-4" id="fieldQuantity" style="display: none;">
          <label for="quantityTotal" class="form-label">
            Quantity in Stock <span class="text-danger">*</span>
          </label>
          <input type="number" id="quantityTotal" name="quantityTotal"
                 class="form-control" min="1"
                 value="<%= item && item.QuantityTotal ? item.QuantityTotal : 1 %>" />
          <div class="form-text">Total units owned. Available = Total − Deployed.</div>
        </div>

        <!-- Part Number -->
        <div class="col-md-4">
          <label for="partNumber" class="form-label">Part #</label>
          <input type="text" id="partNumber" name="partNumber"
                 class="form-control"
                 value="<%= item && item.PartNumber ? item.PartNumber : '' %>"
                 maxlength="100" />
        </div>

        <!-- Model Number -->
        <div class="col-md-4">
          <label for="modelNumber" class="form-label">Model Number</label>
          <%
            const mnList = (typeof modelNumbers !== 'undefined' ? modelNumbers : []);
            const mnMatch = item && item.ModelNumber && mnList.some(n => n.Name === item.ModelNumber);
          %>
          <select id="modelNumber" name="modelNumber" class="form-select">
            <option value="">— Select Model Number —</option>
            <% if (item && item.ModelNumber && !mnMatch) { %>
              <option value="<%= item.ModelNumber %>" selected><%= item.ModelNumber %> (renamed — please reselect)</option>
            <% } %>
            <% mnList.forEach(n => { %>
              <option value="<%= n.Name %>"
                <%= (item && item.ModelNumber === n.Name) ? 'selected' : '' %>>
                <%= n.Name %>
              </option>
            <% }) %>
          </select>
        </div>

        <!-- Manufacturer -->
        <div class="col-md-4">
          <label for="manufacturer" class="form-label">Manufacturer</label>
          <%
            const mfrList = (typeof manufacturers !== 'undefined' ? manufacturers : []);
            const mfrMatch = item && item.Manufacturer && mfrList.some(n => n.Name === item.Manufacturer);
          %>
          <select id="manufacturer" name="manufacturer" class="form-select">
            <option value="">— Select Manufacturer —</option>
            <% if (item && item.Manufacturer && !mfrMatch) { %>
              <option value="<%= item.Manufacturer %>" selected><%= item.Manufacturer %> (renamed — please reselect)</option>
            <% } %>
            <% mfrList.forEach(n => { %>
              <option value="<%= n.Name %>"
                <%= (item && item.Manufacturer === n.Name) ? 'selected' : '' %>>
                <%= n.Name %>
              </option>
            <% }) %>
          </select>
        </div>

        <!-- Related System -->
        <div class="col-md-4">
          <label for="relatedSystemID" class="form-label">Related System</label>
          <select id="relatedSystemID" name="relatedSystemID" class="form-select">
            <option value="">— None —</option>
            <% (systems || []).forEach(s => { %>
              <option value="<%= s.ItemID %>"
                <%= ((item && item.RelatedSystemID == s.ItemID) || (!item && typeof presetSystemID !== 'undefined' && presetSystemID == s.ItemID)) ? 'selected' : '' %>>
                <%= s.DisplayLabel %>
                <% if (s.Manufacturer) { %> (<%= s.Manufacturer %>)<% } %>
              </option>
            <% }) %>
          </select>
          <div class="form-text">Optional — link this item to a parent system it belongs to.</div>
        </div>

        <!-- Category -->
        <div class="col-md-4">
          <label for="categoryID" class="form-label">
            Category <span class="text-danger">*</span>
          </label>
          <select id="categoryID" name="categoryID" class="form-select" required>
            <option value="">— Select Category —</option>
            <% categories.forEach(c => { %>
              <option value="<%= c.CategoryID %>"
                <%= (item && item.CategoryID == c.CategoryID) ? 'selected' : '' %>>
                <%= c.CategoryName %>
              </option>
            <% }) %>
          </select>
        </div>

        <!-- Status -->
        <div class="col-md-4">
          <label for="statusID" class="form-label">
            Status <span class="text-danger">*</span>
          </label>
          <select id="statusID" name="statusID" class="form-select" required>
            <option value="">— Select Status —</option>
            <%
              const systemStatuses = ['Checked-Out', 'Deployed'];
              // If item currently has a system-managed status, show it as a read-only option
              const currentIsSystem = item && systemStatuses.includes(item.StatusName);
            %>
            <% if (currentIsSystem) { %>
              <option value="<%= item.StatusID %>" selected disabled><%= item.StatusName %> (system managed)</option>
            <% } %>
            <% statuses.filter(s => !systemStatuses.includes(s.StatusName)).forEach(s => { %>
              <option value="<%= s.StatusID %>"
                data-name="<%= s.StatusName %>"
                <%= (!currentIsSystem && item && item.StatusID == s.StatusID) ? 'selected' : '' %>>
                <%= s.StatusName %>
              </option>
            <% }) %>
          </select>
          <% if (currentIsSystem) { %>
          <div class="form-text">Status is managed automatically while the item is <%= item.StatusName.toLowerCase() %>.</div>
          <% } %>
        </div>

        <!-- Stock Holder (shown when In-Stock, serialized only) -->
        <%
          const showHolder     = item && item.StatusName === 'In-Stock' && !isBulkItem;
          const holderIsUser   = item && item.AssignedToUserID && !item.StockLocationID;
          const initHolderType = holderIsUser ? 'user' : 'location';
        %>
        <div class="col-md-4" id="stockHolderGroup"
             style="display: <%= showHolder ? 'block' : 'none' %>">
          <label class="form-label">Stock Holder</label>
          <div class="input-group">
            <select id="holderType" name="holderType" class="form-select" style="max-width: 155px;">
              <option value="location" <%= initHolderType === 'location' ? 'selected' : '' %>>Stock Location</option>
              <option value="user"     <%= initHolderType === 'user'     ? 'selected' : '' %>>Person</option>
            </select>
            <select id="stockLocationID" name="stockLocationID" class="form-select"
                    style="display:<%= initHolderType === 'location' ? 'block' : 'none' %>">
              <option value="">— Select Location —</option>
              <% locations.forEach(l => { %>
                <option value="<%= l.LocationID %>"
                  <%= (item && item.StockLocationID == l.LocationID) ? 'selected' : '' %>>
                  <%= l.LocationName %>
                </option>
              <% }) %>
            </select>
            <select id="assignedToUserID" name="assignedToUserID" class="form-select"
                    style="display:<%= initHolderType === 'user' ? 'block' : 'none' %>">
              <option value="">— Select Person —</option>
              <% (typeof allUsers !== 'undefined' ? allUsers : []).forEach(u => { %>
                <option value="<%= u.UserID %>"
                  <%= (item && item.AssignedToUserID == u.UserID) ? 'selected' : '' %>>
                  <%= u.DisplayName %>
                </option>
              <% }) %>
            </select>
          </div>
        </div>

        <!-- Purchase Date -->
        <div class="col-md-3">
          <label for="purchaseDate" class="form-label">Purchase Date</label>
          <input type="date" id="purchaseDate" name="purchaseDate"
                 class="form-control"
                 value="<%= item && item.PurchaseDate ? new Date(item.PurchaseDate).toISOString().split('T')[0] : '' %>" />
        </div>

        <!-- Warranty Expires -->
        <div class="col-md-3">
          <label for="warrantyExpires" class="form-label">Warranty Expires</label>
          <input type="date" id="warrantyExpires" name="warrantyExpires"
                 class="form-control"
                 value="<%= item && item.WarrantyExpires ? new Date(item.WarrantyExpires).toISOString().split('T')[0] : '' %>" />
        </div>

        <!-- Description -->
        <div class="col-12">
          <label for="description" class="form-label">Description</label>
          <textarea id="description" name="description"
                    class="form-control" rows="3"
                    maxlength="2000"><%= item && item.Description ? item.Description : '' %></textarea>
        </div>

        <!-- Notes -->
        <div class="col-12">
          <label for="notes" class="form-label">Notes</label>
          <textarea id="notes" name="notes"
                    class="form-control" rows="3"
                    maxlength="2000"><%= item && item.Notes ? item.Notes : '' %></textarea>
        </div>

      </div><!-- /.row -->

      <hr class="my-4" />

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-floppy me-1"></i>
          <%= item ? 'Save Changes' : 'Add Item' %>
        </button>
        <a href="<%= item ? `/inventory/${item.ItemID}` : '/inventory' %>"
           class="btn btn-outline-secondary">Cancel</a>
      </div>

    </form>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var typeBulk        = document.getElementById('typeBulk');
  var typeSerial      = document.getElementById('typeSerial');
  var fieldSN         = document.getElementById('fieldSerialNumber');
  var fieldAT         = document.getElementById('fieldAssetTag');
  var fieldQty        = document.getElementById('fieldQuantity');
  var inputQty        = document.getElementById('quantityTotal');
  var statusSel       = document.getElementById('statusID');
  var holderGroup     = document.getElementById('stockHolderGroup');
  var holderTypeSel   = document.getElementById('holderType');
  var locSel          = document.getElementById('stockLocationID');
  var userSel         = document.getElementById('assignedToUserID');

  function updateHolderType() {
    var isUser = holderTypeSel && holderTypeSel.value === 'user';
    if (locSel)  locSel.style.display  = isUser ? 'none' : 'block';
    if (userSel) userSel.style.display = isUser ? 'block' : 'none';
  }

  function updateForm() {
    var bulk = typeBulk && typeBulk.checked;

    if (fieldSN)  fieldSN.style.display  = bulk ? 'none' : 'block';
    if (fieldAT)  fieldAT.style.display  = bulk ? 'none' : 'block';
    if (fieldQty) fieldQty.style.display = bulk ? 'block' : 'none';
    if (inputQty) inputQty.required      = bulk;

    if (holderGroup && statusSel) {
      var chosen = statusSel.options[statusSel.selectedIndex];
      var statusName = chosen ? chosen.getAttribute('data-name') : '';
      holderGroup.style.display = (!bulk && statusName === 'In-Stock') ? 'block' : 'none';
    }

    updateHolderType();
  }

  if (typeSerial)    typeSerial.addEventListener('change', updateForm);
  if (typeBulk)      typeBulk.addEventListener('change', updateForm);
  if (statusSel)     statusSel.addEventListener('change', updateForm);
  if (holderTypeSel) holderTypeSel.addEventListener('change', updateHolderType);

  updateForm();
});
</script>
