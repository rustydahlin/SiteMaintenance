<%
  function statusBadge(statusName) {
    const map = {
      'In-Stock':    'bg-success',
      'Out of Stock':'bg-danger',
      'Deployed':    'bg-primary',
      'Checked-Out': 'bg-warning text-dark',
      'In-Repair':   'bg-danger',
      'Retired':     'bg-secondary',
    };
    const cls = map[statusName] || 'bg-secondary';
    return `<span class="badge ${cls}">${statusName || '—'}</span>`;
  }

  const curSort = typeof sort !== 'undefined' ? sort : 'commonName';
  const curDir  = typeof dir  !== 'undefined' ? dir  : 'asc';
  function sortLink(col) {
    const newDir = (curSort === col && curDir === 'asc') ? 'desc' : 'asc';
    const f = typeof filters !== 'undefined' ? filters : {};
    const parts = [];
    if (f.categoryID) parts.push(`categoryID=${encodeURIComponent(f.categoryID)}`);
    if (f.statusID)   parts.push(`statusID=${encodeURIComponent(f.statusID)}`);
    if (f.search)     parts.push(`search=${encodeURIComponent(f.search)}`);
    if (f.locationID) parts.push(`locationID=${encodeURIComponent(f.locationID)}`);
    parts.push(`sort=${col}`, `dir=${newDir}`);
    return `/inventory?${parts.join('&')}`;
  }
  function sortIcon(col) {
    if (curSort !== col) return '<i class="bi bi-arrow-down-up text-muted ms-1 small opacity-50"></i>';
    return curDir === 'asc'
      ? '<i class="bi bi-sort-up ms-1 small"></i>'
      : '<i class="bi bi-sort-down ms-1 small"></i>';
  }
%>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0"><i class="bi bi-box-seam me-2"></i>Inventory</h1>
  <div class="d-flex gap-2">
    <%
      const exportParts = [];
      if (filters.categoryID) exportParts.push(`categoryID=${encodeURIComponent(filters.categoryID)}`);
      if (filters.statusID)   exportParts.push(`statusID=${encodeURIComponent(filters.statusID)}`);
      if (filters.search)     exportParts.push(`search=${encodeURIComponent(filters.search)}`);
      if (filters.locationID) exportParts.push(`locationID=${encodeURIComponent(filters.locationID)}`);
      exportParts.push(`sort=${encodeURIComponent(curSort)}`, `dir=${encodeURIComponent(curDir)}`);
    %>
    <a href="/inventory/export?<%= exportParts.join('&') %>" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-file-earmark-arrow-down me-1"></i>Export
    </a>
    <% if (user && user.roles && user.roles.includes('Admin')) { %>
      <a href="/inventory/import" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-file-earmark-spreadsheet me-1"></i>Import
      </a>
      <a href="/inventory/new" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Add Item
      </a>
    <% } %>
  </div>
</div>

<!-- Filter form -->
<div class="card mb-3 shadow-sm">
  <div class="card-body py-2">
    <form method="GET" action="/inventory" class="row g-2 align-items-end">
      <input type="hidden" name="sort" value="<%= curSort %>" />
      <input type="hidden" name="dir"  value="<%= curDir %>" />
      <div class="col-sm-4 col-lg-3">
        <label class="form-label small mb-1">Search</label>
        <input type="text" name="search" class="form-control form-control-sm"
               placeholder="Serial #, model, manufacturer…"
               value="<%= typeof filters !== 'undefined' && filters.search ? filters.search : '' %>" />
      </div>
      <div class="col-sm-3 col-lg-2">
        <label class="form-label small mb-1">Category</label>
        <select name="categoryID" class="form-select form-select-sm">
          <option value="">All Categories</option>
          <% categories.forEach(c => { %>
            <option value="<%= c.CategoryID %>"
              <%= (typeof filters !== 'undefined' && filters.categoryID == c.CategoryID) ? 'selected' : '' %>>
              <%= c.CategoryName %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-sm-3 col-lg-2">
        <label class="form-label small mb-1">Status</label>
        <select name="statusID" class="form-select form-select-sm">
          <option value="">All Statuses</option>
          <% statuses.forEach(s => { %>
            <option value="<%= s.StatusID %>"
              <%= (typeof filters !== 'undefined' && filters.statusID == s.StatusID) ? 'selected' : '' %>>
              <%= s.StatusName %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-sm-3 col-lg-2">
        <label class="form-label small mb-1">Location</label>
        <select name="locationID" class="form-select form-select-sm">
          <option value="">All Locations</option>
          <% locations.forEach(l => { %>
            <option value="<%= l.LocationID %>"
              <%= (typeof filters !== 'undefined' && filters.locationID == l.LocationID) ? 'selected' : '' %>>
              <%= l.LocationName %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-outline-primary">
          <i class="bi bi-search me-1"></i>Filter
        </button>
        <a href="/inventory" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
      </div>
    </form>
  </div>
</div>

<!-- Results -->
<% if (items.length === 0) { %>
  <div class="alert alert-info">No inventory items found matching your filters.</div>
<% } else { %>
<div class="table-responsive">
  <table class="table table-hover table-sm align-middle mb-0">
    <thead>
      <tr>
        <th><a href="<%- sortLink('commonName') %>" class="text-decoration-none text-body">Item<%- sortIcon('commonName') %></a></th>
        <th><a href="<%- sortLink('category') %>" class="text-decoration-none text-body">Category<%- sortIcon('category') %></a></th>
        <th><a href="<%- sortLink('status') %>" class="text-decoration-none text-body">Status<%- sortIcon('status') %></a></th>
        <th class="text-center">In Stock</th>
        <th><a href="<%- sortLink('location') %>" class="text-decoration-none text-body">Location / Assigned To<%- sortIcon('location') %></a></th>
      </tr>
    </thead>
    <tbody>
      <% items.forEach(item => { %>

      <% if (item._displayType === 'group') { %>
      <%/* ── Serialized Common Name group row ── */%>
      <tr>
        <td>
          <a href="/inventory/group/<%= encodeURIComponent(item.commonName) %>" class="fw-semibold text-decoration-none">
            <%= item.commonName %>
          </a>
          <% if (item.ModelNumber) { %>
            <div class="small text-muted"><%= item.ModelNumber %><% if (item.Manufacturer) { %> / <%= item.Manufacturer %><% } %></div>
          <% } else if (item.Manufacturer) { %>
            <div class="small text-muted"><%= item.Manufacturer %></div>
          <% } %>
        </td>
        <td class="small"><%= item.CategoryName || '—' %></td>
        <td>
          <% if (item.inStockCount > 0)  { %><span class="badge bg-success me-1"><%= item.inStockCount %> In-Stock</span><% } %>
          <% if (item.inStockCount === 0) { %><span class="badge bg-danger me-1">Out of Stock</span><% } %>
          <% if (item.deployedCount > 0) { %><span class="badge bg-primary me-1"><%= item.deployedCount %> Deployed</span><% } %>
          <% if (item.inRepairCount > 0) { %><span class="badge bg-danger me-1"><%= item.inRepairCount %> In-Repair</span><% } %>
          <% if (item.otherCount > 0)    { %><span class="badge bg-secondary me-1"><%= item.otherCount %> Other</span><% } %>
        </td>
        <td class="text-center small">
          <span class="fw-semibold"><%= item.inStockCount %></span>
          <span class="text-muted">/ <%= item.totalCount %></span>
        </td>
        <td class="small text-muted">
          <% if (item.primaryLocation && item.locationCount > 1) { %>
            <i class="bi bi-box me-1"></i><%= item.primaryLocation %> +<%= item.locationCount - 1 %> more
          <% } else if (item.primaryLocation) { %>
            <i class="bi bi-box me-1"></i><%= item.primaryLocation %>
          <% } else if (item.deployedCount > 0 && item.inStockCount === 0) { %>
            <span class="fst-italic">All deployed</span>
          <% } else { %>
            —
          <% } %>
        </td>
      </tr>

      <% } else { %>
      <%/* ── Bulk item or ungrouped serialized item ── */%>
      <tr>
        <td>
          <a href="/inventory/<%= item.ItemID %>" class="fw-semibold text-decoration-none">
            <%= item.CommonName || item.ModelNumber || item.Manufacturer || item.SerialNumber || ('Item #' + item.ItemID) %>
          </a>
          <% if (item.TrackingType === 'bulk') { %>
            <span class="badge bg-info text-dark ms-1 small">FRU</span>
          <% } %>
          <% if (item.ModelNumber) { %>
            <div class="small text-muted"><%= item.ModelNumber %><% if (item.Manufacturer) { %> / <%= item.Manufacturer %><% } %></div>
          <% } else if (item.Manufacturer) { %>
            <div class="small text-muted"><%= item.Manufacturer %></div>
          <% } %>
        </td>
        <td class="small"><%= item.CategoryName || '—' %></td>
        <td>
          <%- statusBadge(item.TrackingType === 'bulk' ? (item.QuantityAvailable > 0 ? 'In-Stock' : 'Out of Stock') : item.StatusName) %>
          <% if (item.TrackingType === 'bulk' && item.InRepairCount > 0) { %>
            <span class="badge bg-danger ms-1"><%= item.InRepairCount %> In-Repair</span>
          <% } %>
        </td>
        <td class="text-center small">
          <% if (item.TrackingType === 'bulk') { %>
            <span class="fw-semibold"><%= item.QuantityAvailable %></span>
            <span class="text-muted">/ <%= item.QuantityTotal %></span>
          <% } else if (item.StatusName === 'In-Stock') { %>
            <span class="badge bg-success">1</span>
          <% } else { %>
            <span class="text-muted">—</span>
          <% } %>
        </td>
        <td class="small">
          <% if (item.TrackingType === 'bulk') { %>
            <% if (item.BulkLocationCount > 1) { %>
              <span class="text-muted"><i class="bi bi-box me-1"></i><%= item.BulkPrimaryLocation %> +<%= item.BulkLocationCount - 1 %> more</span>
            <% } else if (item.BulkPrimaryLocation) { %>
              <span class="text-muted"><i class="bi bi-box me-1"></i><%= item.BulkPrimaryLocation %></span>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          <% } else if (item.CurrentSiteName) { %>
            <a href="/sites/<%= item.CurrentSiteID %>" class="text-decoration-none text-muted">
              <i class="bi bi-geo-alt me-1"></i><%= item.CurrentSiteName %>
            </a>
          <% } else if (item.StockLocationName) { %>
            <span class="text-muted"><i class="bi bi-box me-1"></i><%= item.StockLocationName %></span>
          <% } else if (item.AssignedToUserName) { %>
            <span class="text-muted"><i class="bi bi-person me-1"></i><%= item.AssignedToUserName %></span>
          <% } else { %>
            <span class="text-muted">—</span>
          <% } %>
        </td>
      </tr>
      <% } /* end if _displayType === 'group' */ %>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Pagination -->
<div class="d-flex justify-content-between align-items-center mt-3">
  <small class="text-muted">
    Showing <%= items.length %> of <%= pagination.total %> item<%= pagination.total !== 1 ? 's' : '' %>
  </small>
  <%- include('../partials/pagination') %>
</div>
<% } %>
