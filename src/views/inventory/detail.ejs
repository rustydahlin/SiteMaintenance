<%
  const isAdminUser  = user && user.roles && user.roles.includes('Admin');
  const canWriteUser = user && user.roles &&
    (user.roles.includes('Admin') || user.roles.includes('Technician') || user.roles.includes('Contractor'));

  function statusBadge(statusName) {
    const map = {
      'In-Stock':    'bg-success',
      'Deployed':    'bg-primary',
      'Checked-Out': 'bg-warning text-dark',
      'In-Repair':   'bg-danger',
      'Retired':     'bg-secondary',
    };
    const cls = map[statusName] || 'bg-secondary';
    return `<span class="badge ${cls}">${statusName || '—'}</span>`;
  }

  function warrantyBadge(dateStr) {
    if (!dateStr) return '<span class="badge bg-secondary">N/A</span>';
    const now = new Date();
    const exp = new Date(dateStr);
    const daysLeft = Math.ceil((exp - now) / (1000 * 60 * 60 * 24));
    if (daysLeft < 0)   return '<span class="badge bg-danger">Expired</span>';
    if (daysLeft <= 90) return '<span class="badge bg-warning text-dark">Expiring Soon</span>';
    return '<span class="badge bg-success">In Warranty</span>';
  }
%>

<!-- Page header -->
<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
  <div>
    <h1 class="h2 mb-1">
      <i class="bi bi-box-seam me-2"></i>
      <% if (item.TrackingType === 'bulk') { %>
        <%= item.CommonName || item.ModelNumber || item.Manufacturer || ('Item #' + item.ItemID) %>
        <span class="badge bg-info text-dark fs-6 ms-1">FRU / Bulk</span>
      <% } else { %>
        <%= item.CommonName || item.SerialNumber %>
      <% } %>
    </h1>
    <div class="d-flex gap-2 flex-wrap">
      <%- statusBadge(item.StatusName) %>
      <%- warrantyBadge(item.WarrantyExpires) %>
      <% if (item.CategoryName) { %>
        <span class="badge bg-body-secondary text-body border"><%= item.CategoryName %></span>
      <% } %>
    </div>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <% if (isAdminUser) { %>
      <a href="/inventory/<%= item.ItemID %>/edit" class="btn btn-sm btn-outline-primary">
        <i class="bi bi-pencil me-1"></i>Edit
      </a>
      <form method="POST" action="/inventory/<%= item.ItemID %>/delete"
            data-confirm="Delete this item? This cannot be undone.">
        <button type="submit" class="btn btn-sm btn-outline-danger">
          <i class="bi bi-trash me-1"></i>Delete
        </button>
      </form>
      <% if (item.StatusName === 'In-Stock' || item.TrackingType === 'bulk') { %>
        <button type="button" class="btn btn-sm btn-outline-warning"
                data-bs-toggle="modal" data-bs-target="#deployModal">
          <i class="bi bi-box-arrow-right me-1"></i>Deploy to Site
        </button>
      <% } %>
    <% } %>
  </div>
</div>

<a href="/inventory" data-back-list="/inventory" class="text-decoration-none text-muted small">
  <i class="bi bi-arrow-left me-1"></i>Back to Inventory
</a>

<!-- Tabs -->
<ul class="nav nav-tabs mt-3" id="invTab" role="tablist">
  <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#overview">Overview</a></li>
  <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#history">History</a></li>
  <li class="nav-item">
    <a class="nav-link" data-bs-toggle="tab" href="#repairs">
      Repairs
      <% if (repairs && repairs.length > 0) { %>
        <span class="badge bg-secondary ms-1"><%= repairs.length %></span>
      <% } %>
    </a>
  </li>
  <% if (relatedParts && relatedParts.length > 0) { %>
  <li class="nav-item">
    <a class="nav-link" data-bs-toggle="tab" href="#parts">
      Related Parts
      <span class="badge bg-secondary ms-1"><%= relatedParts.length %></span>
    </a>
  </li>
  <% } %>
  <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#docs">Documents</a></li>
</ul>

<div class="tab-content border border-top-0 rounded-bottom p-3 bg-body shadow-sm">

  <!-- ── Overview ─────────────────────────────────────────────────────────── -->
  <div class="tab-pane fade show active" id="overview">
    <div class="row g-3 mt-1">
      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-header small fw-semibold">
            <i class="bi bi-tag me-1"></i>Item Details
          </div>
          <div class="card-body small">
            <dl class="row mb-0">
              <% if (item.CommonName) { %>
              <dt class="col-sm-5 text-muted">Common Name</dt>
              <dd class="col-sm-7 fw-semibold"><%= item.CommonName %></dd>
              <% } %>

              <% if (item.TrackingType !== 'bulk') { %>
              <dt class="col-sm-5 text-muted">Serial Number</dt>
              <dd class="col-sm-7 fw-semibold"><%= item.SerialNumber || '—' %></dd>

              <% if (item.AssetTag) { %>
              <dt class="col-sm-5 text-muted">Asset Tag #</dt>
              <dd class="col-sm-7"><%= item.AssetTag %></dd>
              <% } %>
              <% } %>

              <% if (item.PartNumber) { %>
              <dt class="col-sm-5 text-muted">Part #</dt>
              <dd class="col-sm-7"><%= item.PartNumber %></dd>
              <% } %>

              <dt class="col-sm-5 text-muted">Model Number</dt>
              <dd class="col-sm-7"><%= item.ModelNumber || '—' %></dd>

              <dt class="col-sm-5 text-muted">Manufacturer</dt>
              <dd class="col-sm-7"><%= item.Manufacturer || '—' %></dd>

              <dt class="col-sm-5 text-muted">Category</dt>
              <dd class="col-sm-7"><%= item.CategoryName || '—' %></dd>

              <% if (item.RelatedSystemName) { %>
              <dt class="col-sm-5 text-muted">Related System</dt>
              <dd class="col-sm-7">
                <a href="/inventory/<%= item.RelatedSystemID %>" class="text-decoration-none">
                  <%= item.RelatedSystemName %>
                </a>
              </dd>
              <% } %>
            </dl>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-header small fw-semibold">
            <i class="bi bi-info-circle me-1"></i>Status & Location
          </div>
          <div class="card-body small">
            <dl class="row mb-0">
              <dt class="col-sm-5 text-muted">Status</dt>
              <dd class="col-sm-7"><%- statusBadge(item.StatusName) %></dd>

              <% if (item.TrackingType === 'bulk') { %>
              <dt class="col-sm-5 text-muted">Total Units</dt>
              <dd class="col-sm-7 fw-semibold"><%= item.QuantityTotal %></dd>

              <dt class="col-sm-5 text-muted">Available</dt>
              <dd class="col-sm-7">
                <span class="badge <%= item.QuantityAvailable > 0 ? 'bg-success' : 'bg-secondary' %>">
                  <%= item.QuantityAvailable %>
                </span>
                <span class="text-muted small ms-1">of <%= item.QuantityTotal %></span>
              </dd>
              <% } else { %>
              <dt class="col-sm-5 text-muted">Location</dt>
              <dd class="col-sm-7"><%= item.StockLocationName || '—' %></dd>

              <% } %>

              <dt class="col-sm-5 text-muted">Warranty</dt>
              <dd class="col-sm-7">
                <%- warrantyBadge(item.WarrantyExpires) %>
                <% if (item.WarrantyExpires) { %>
                  <span class="ms-1 text-muted">(<%= new Date(item.WarrantyExpires).toLocaleDateString() %>)</span>
                <% } %>
              </dd>

              <dt class="col-sm-5 text-muted">Purchase Date</dt>
              <dd class="col-sm-7">
                <%= item.PurchaseDate ? new Date(item.PurchaseDate).toLocaleDateString() : '—' %>
              </dd>
            </dl>
          </div>
        </div>
      </div>

      <% if (item.Description || item.Notes) { %>
      <div class="col-12">
        <div class="card">
          <div class="card-header small fw-semibold">Notes</div>
          <div class="card-body small">
            <% if (item.Description) { %>
              <p class="mb-1" style="white-space:pre-wrap;"><%= item.Description %></p>
            <% } %>
            <% if (item.Notes) { %>
              <p class="mb-0 text-muted" style="white-space:pre-wrap;"><%= item.Notes %></p>
            <% } %>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Stock Distribution (bulk items only) -->
      <% if (item.TrackingType === 'bulk') { %>
      <div class="col-12">
        <div class="card">
          <div class="card-header small fw-semibold d-flex justify-content-between align-items-center">
            <span><i class="bi bi-diagram-3 me-1"></i>Stock Distribution</span>
            <span class="text-muted fw-normal">
              Total: <%= item.QuantityTotal %> &nbsp;|&nbsp;
              Available: <%= item.QuantityAvailable %>
            </span>
          </div>
          <div class="card-body">
            <!-- Current distribution table -->
            <%
              const allocatedQty   = (stockDistribution || []).reduce((sum, r) => sum + r.Quantity, 0);
              const unallocatedQty = Math.max(0, (item.QuantityAvailable || 0) - allocatedQty);
            %>
            <div class="table-responsive mb-3">
              <table class="table table-sm table-hover align-middle mb-0">
                <thead>
                  <tr><th>Location / Person</th><th class="text-center">Qty</th><th>Notes</th><% if (isAdminUser) { %><th></th><% } %></tr>
                </thead>
                <tbody>
                  <% (stockDistribution || []).forEach(row => { %>
                  <tr class="stock-row" style="cursor:pointer"
                      data-stock-id="<%= row.StockID %>"
                      data-holder-type="<%= row.LocationName ? 'location' : 'user' %>"
                      data-location-id="<%= row.LocationID || '' %>"
                      data-user-id="<%= row.UserID || '' %>"
                      data-quantity="<%= row.Quantity %>"
                      data-notes="<%= row.Notes || '' %>">
                    <td class="small">
                      <% if (row.LocationName) { %>
                        <i class="bi bi-geo-alt text-muted me-1"></i><%= row.LocationName %>
                      <% } else { %>
                        <i class="bi bi-person text-muted me-1"></i><%= row.UserDisplayName %>
                      <% } %>
                    </td>
                    <td class="text-center fw-semibold"><%= row.Quantity %></td>
                    <td class="small text-muted"><%= row.Notes || '—' %></td>
                    <% if (isAdminUser) { %>
                    <td>
                      <form method="POST" action="/inventory/<%= item.ItemID %>/stock/<%= row.StockID %>/delete"
                            data-confirm="Remove this stock entry?">
                        <button type="submit" class="btn btn-sm btn-outline-danger py-0" onclick="event.stopPropagation()">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </td>
                    <% } %>
                  </tr>
                  <% }) %>
                  <tr id="unallocatedRow" <% if (isAdminUser) { %>style="cursor:pointer"<% } %>>
                    <td class="small text-muted fst-italic"><i class="bi bi-inbox me-1"></i>Unallocated</td>
                    <td class="text-center text-muted fst-italic" id="unallocatedQtyCell"><%= unallocatedQty %></td>
                    <td class="small text-muted fst-italic">—</td>
                    <% if (isAdminUser) { %>
                    <td class="text-end">
                      <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-1" id="editUnallocatedBtn" title="Edit unallocated quantity">
                        <i class="bi bi-pencil"></i>
                      </button>
                    </td>
                    <% } %>
                  </tr>
                </tbody>
              </table>
            </div>

            <!-- Add / update stock entry form -->
            <% if (isAdminUser) { %>
            <form method="POST" action="/inventory/<%= item.ItemID %>/stock" id="stockForm" class="border rounded p-3 bg-body-secondary">
              <div class="row g-2 align-items-end">
                <div class="col-sm-3">
                  <label class="form-label small mb-1">Holder Type</label>
                  <select name="holderType" id="holderType" class="form-select form-select-sm">
                    <option value="location">Stock Location</option>
                    <option value="user">Person</option>
                    <option value="unallocated">Unallocated</option>
                  </select>
                </div>
                <div class="col-sm-3" id="stockLocGroup">
                  <label class="form-label small mb-1">Location</label>
                  <select name="locationID" id="stockLocationID" class="form-select form-select-sm">
                    <option value="">— Select —</option>
                    <% stockLocations.forEach(l => { %>
                    <option value="<%= l.LocationID %>"><%= l.LocationName %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-sm-3" id="stockUserGroup" style="display:none">
                  <label class="form-label small mb-1">Person</label>
                  <select name="userID" id="stockUserID" class="form-select form-select-sm">
                    <option value="">— Select —</option>
                    <% allUsers.forEach(u => { %>
                    <option value="<%= u.UserID %>"><%= u.DisplayName %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-sm-2">
                  <label class="form-label small mb-1">Quantity</label>
                  <input type="number" name="quantity" id="stockQuantity" class="form-control form-control-sm" min="0" value="1" required />
                </div>
                <div class="col-sm-3">
                  <label class="form-label small mb-1">Notes (optional)</label>
                  <input type="text" name="notes" id="stockNotes" class="form-control form-control-sm" maxlength="255" />
                </div>
                <div class="col-auto d-flex gap-1">
                  <button type="submit" id="stockSaveBtn" class="btn btn-sm btn-primary">Save</button>
                  <button type="button" id="stockCancelBtn" class="btn btn-sm btn-outline-secondary" style="display:none">Cancel</button>
                </div>
              </div>
              <div class="form-text mt-1">Setting quantity to 0 on an existing entry will remove it from the list.</div>
            </form>
            <% } %>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Open RMAs -->
      <% const openRepairs = (repairs || []).filter(r => !r.ReceivedDate); %>
      <% if (openRepairs.length > 0) { %>
      <div class="col-12">
        <div class="card border-warning">
          <div class="card-header small fw-semibold d-flex justify-content-between align-items-center bg-warning bg-opacity-10">
            <span><i class="bi bi-wrench-adjustable me-1 text-warning"></i>Open Repairs / RMAs</span>
            <span class="badge bg-warning text-dark"><%= openRepairs.length %> open</span>
          </div>
          <div class="card-body p-0">
            <table class="table table-sm table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th>RMA #</th>
                  <th>Sent Date</th>
                  <th>Reason</th>
                  <th>Sent By</th>
                  <th>Expected Return</th>
                  <th>Follow-Up</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% openRepairs.forEach(r => { %>
                <tr>
                  <td class="small fw-semibold"><%= r.RMANumber || '—' %></td>
                  <td class="small text-muted text-nowrap">
                    <%= r.SentDate ? new Date(r.SentDate).toLocaleDateString() : '—' %>
                  </td>
                  <td class="small"><%= r.Reason || '—' %></td>
                  <td class="small text-muted"><%= r.SentByName || '—' %></td>
                  <td class="small text-muted text-nowrap">
                    <% if (r.ExpectedReturnDate) { %>
                      <% var exp = new Date(r.ExpectedReturnDate); var overdue = exp < new Date(); %>
                      <span class="<%= overdue ? 'text-danger fw-semibold' : '' %>">
                        <%= exp.toLocaleDateString() %><%= overdue ? ' ⚠' : '' %>
                      </span>
                    <% } else { %>—<% } %>
                  </td>
                  <td class="small text-muted text-nowrap">
                    <%= r.FollowUpDate ? new Date(r.FollowUpDate).toLocaleDateString() : '—' %>
                  </td>
                  <td>
                    <a href="/repairs/<%= r.RepairID %>" class="btn btn-sm btn-outline-secondary py-0">View</a>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <% } %>

      <!-- All RMAs (collapsed link) -->
      <% const allRepairs = repairs || []; %>
      <% if (allRepairs.length > 0 && openRepairs.length < allRepairs.length) { %>
      <div class="col-12">
        <a href="/repairs?itemID=<%= item.ItemID %>&status=all" class="small text-muted">
          <i class="bi bi-clock-history me-1"></i>View all <%= allRepairs.length %> repair records for this item
        </a>
      </div>
      <% } %>

    </div>
  </div>

  <!-- ── History ───────────────────────────────────────────────────────────── -->
  <div class="tab-pane fade" id="history">
    <h6 class="mt-2 mb-3">Site Install History</h6>

    <% if (!siteHistory || siteHistory.length === 0) { %>
      <p class="text-muted">No site install history on record for this item.</p>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-sm align-middle">
        <thead>
          <tr>
            <th>Site</th>
            <th>Installed</th>
            <th>Installed By</th>
            <th>Removed</th>
          </tr>
        </thead>
        <tbody>
          <% siteHistory.forEach(entry => { %>
          <tr>
            <td class="small">
              <a href="/sites/<%= entry.SiteID %>" class="text-decoration-none">
                <%= entry.SiteName || `Site #${entry.SiteID}` %>
              </a>
            </td>
            <td class="small text-muted text-nowrap">
              <%= entry.InstalledAt ? new Date(entry.InstalledAt).toLocaleDateString() : '—' %>
            </td>
            <td class="small text-muted">
              <%= entry.InstalledByName || '—' %>
            </td>
            <td class="small text-muted text-nowrap">
              <%= entry.RemovedAt ? new Date(entry.RemovedAt).toLocaleDateString() : (entry.IsActive ? 'Present' : '—') %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <!-- ── Repairs ───────────────────────────────────────────────────────────── -->
  <div class="tab-pane fade" id="repairs">
    <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
      <h6 class="mb-0">Repair / RMA Records</h6>
      <% if (isAdminUser) { %>
        <a href="/repairs/new?itemID=<%= item.ItemID %>" class="btn btn-sm btn-primary">
          <i class="bi bi-plus-lg me-1"></i>New Repair
        </a>
      <% } %>
    </div>

    <% if (!repairs || repairs.length === 0) { %>
      <p class="text-muted">No repair records for this item.</p>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-sm align-middle">
        <thead>
          <tr>
            <th>Sent Date</th>
            <th>RMA #</th>
            <th>Reason</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% repairs.forEach(repair => { %>
          <tr>
            <td class="small text-muted text-nowrap">
              <%= repair.SentDate ? new Date(repair.SentDate).toLocaleDateString() : '—' %>
            </td>
            <td class="small"><%= repair.RMANumber || '—' %></td>
            <td class="small"><%= repair.Reason || '—' %></td>
            <td>
              <span class="badge <%= repair.ReceivedDate ? 'bg-success' : 'bg-warning text-dark' %>">
                <%= repair.ReceivedDate ? 'Closed' : 'Open' %>
              </span>
            </td>
            <td>
              <a href="/repairs/<%= repair.RepairID %>" class="btn btn-sm btn-outline-secondary">View</a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <!-- ── Related Parts ────────────────────────────────────────────────────── -->
  <% if (relatedParts && relatedParts.length > 0) { %>
  <div class="tab-pane fade" id="parts">
    <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
      <h6 class="mb-0">Parts Associated with this System</h6>
      <% if (isAdminUser) { %>
        <a href="/inventory/new?relatedSystemID=<%= item.ItemID %>" class="btn btn-sm btn-primary">
          <i class="bi bi-plus-lg me-1"></i>Add Part
        </a>
      <% } %>
    </div>
    <div class="table-responsive">
      <table class="table table-sm table-hover align-middle">
        <thead>
          <tr>
            <th>Part</th>
            <th>Part #</th>
            <th>Category</th>
            <th>Status</th>
            <th class="text-center">Available</th>
          </tr>
        </thead>
        <tbody>
          <% relatedParts.forEach(part => { %>
          <tr>
            <td>
              <a href="/inventory/<%= part.ItemID %>" class="fw-semibold text-decoration-none">
                <%= part.CommonName %>
              </a>
              <% if (part.TrackingType === 'bulk') { %>
                <span class="badge bg-info text-dark small ms-1">FRU</span>
              <% } %>
              <% if (part.ModelNumber) { %>
                <div class="small text-muted"><%= part.ModelNumber %><% if (part.Manufacturer) { %> / <%= part.Manufacturer %><% } %></div>
              <% } %>
            </td>
            <td class="small text-muted"><%= part.PartNumber || '—' %></td>
            <td class="small"><%= part.CategoryName || '—' %></td>
            <td>
              <%
                const statusMap = { 'In-Stock':'bg-success','Deployed':'bg-primary','Checked-Out':'bg-warning text-dark','In-Repair':'bg-danger','Retired':'bg-secondary' };
                const sBadge = statusMap[part.StatusName] || 'bg-secondary';
              %>
              <span class="badge <%= sBadge %>"><%= part.StatusName || '—' %></span>
            </td>
            <td class="text-center small">
              <% if (part.TrackingType === 'bulk') { %>
                <span class="fw-semibold"><%= part.QuantityAvailable %></span>
                <span class="text-muted">/ <%= part.QuantityTotal %></span>
              <% } else if (part.StatusName === 'In-Stock') { %>
                <span class="badge bg-success">1</span>
              <% } else { %>
                <span class="text-muted">—</span>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>

  <!-- ── Documents ─────────────────────────────────────────────────────────── -->
  <div class="tab-pane fade" id="docs">
    <div class="mt-2">
      <%- include('../partials/fileList', {
        documents:  documents,
        uploadUrl:  `/documents/upload`,
        canUpload:  canWriteUser,
        entityType: 'item',
        entityId:   item.ItemID,
        returnTo:   `/inventory/${item.ItemID}#docs`
      }) %>
    </div>
  </div>

</div><!-- /.tab-content -->

<!-- ── Deploy to Site Modal ──────────────────────────────────────────────────── -->
<% if (isAdminUser) { %>
<div class="modal fade" id="deployModal" tabindex="-1" aria-labelledby="deployModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="POST" action="/inventory/<%= item.ItemID %>/deploy">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
        <div class="modal-header">
          <h5 class="modal-title" id="deployModalLabel">
            <i class="bi bi-box-arrow-right me-2"></i>Deploy to Site
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <p class="text-muted small mb-3">
            Deploying: <strong><%= item.CommonName || item.ModelNumber || item.SerialNumber %></strong>
          </p>

          <!-- Site -->
          <div class="mb-3">
            <label for="deploySiteID" class="form-label">Site <span class="text-danger">*</span></label>
            <select name="siteID" id="deploySiteID" class="form-select" required>
              <option value="">— Select Site —</option>
              <%
                let lastParent = null;
                (sites || []).forEach(s => {
                  const group = s.ParentSiteName || null;
                  if (group !== lastParent) {
                    if (lastParent !== null) { %></optgroup><% }
                    lastParent = group;
                    if (group) { %><optgroup label="<%= group %>"><% }
                  }
              %>
                <option value="<%= s.SiteID %>"><%= s.SiteName %></option>
              <% }); if (lastParent) { %></optgroup><% } %>
            </select>
          </div>

          <!-- Quantity (bulk only) -->
          <% if (item.TrackingType === 'bulk') { %>
          <div class="mb-3">
            <label for="deployQuantity" class="form-label">Quantity <span class="text-danger">*</span></label>
            <input type="number" name="quantity" id="deployQuantity"
                   class="form-control" min="1" max="<%= item.QuantityAvailable %>" value="1" required />
            <div class="form-text"><%= item.QuantityAvailable %> available.</div>
          </div>
          <% } %>

          <!-- Pulled From -->
          <div class="mb-3">
            <label for="deployPulledFrom" class="form-label">Pulled From</label>
            <select name="pulledFrom" id="deployPulledFrom" class="form-select">
              <option value="">— General Stock / Unallocated —</option>
              <% if (item.TrackingType === 'bulk') { %>
                <%
                  const deployLocRows  = (stockDistribution || []).filter(r => r.LocationName);
                  const deployUserRows = (stockDistribution || []).filter(r => r.UserDisplayName);
                %>
                <% if (deployLocRows.length) { %>
                  <optgroup label="Stock Locations">
                    <% deployLocRows.forEach(r => { %>
                      <option value="location:<%= r.LocationID %>">
                        <%= r.LocationName %> (<%= r.Quantity %> available)
                      </option>
                    <% }) %>
                  </optgroup>
                <% } %>
                <% if (deployUserRows.length) { %>
                  <optgroup label="Person">
                    <% deployUserRows.forEach(r => { %>
                      <option value="user:<%= r.UserID %>">
                        <%= r.UserDisplayName %> (<%= r.Quantity %> available)
                      </option>
                    <% }) %>
                  </optgroup>
                <% } %>
              <% } else { %>
                <% if (item.StockLocationID && item.StockLocationName) { %>
                  <option value="location:<%= item.StockLocationID %>" selected>
                    <%= item.StockLocationName %>
                  </option>
                <% } else if (item.AssignedToUserID && item.AssignedToUserName) { %>
                  <option value="user:<%= item.AssignedToUserID %>" selected>
                    <%= item.AssignedToUserName %>
                  </option>
                <% } %>
              <% } %>
            </select>
          </div>

          <!-- Notes -->
          <div class="mb-1">
            <label for="deployNotes" class="form-label">Install Notes</label>
            <input type="text" name="installNotes" id="deployNotes"
                   class="form-control" maxlength="500" />
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-box-arrow-right me-1"></i>Deploy
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
<% } %>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var holderType   = document.getElementById('holderType');
  var locGroup     = document.getElementById('stockLocGroup');
  var userGroup    = document.getElementById('stockUserGroup');

  function toggleHolder() {
    if (!holderType) return;
    var val = holderType.value;
    if (locGroup)  locGroup.style.display  = val === 'location' ? '' : 'none';
    if (userGroup) userGroup.style.display = val === 'user'     ? '' : 'none';
  }

  if (holderType) {
    holderType.addEventListener('change', toggleHolder);
    toggleHolder();
  }

  // ── Stock row click → populate form ────────────────────────────────────────
  var saveBtn   = document.getElementById('stockSaveBtn');
  var cancelBtn = document.getElementById('stockCancelBtn');
  var locSel    = document.getElementById('stockLocationID');
  var userSel   = document.getElementById('stockUserID');
  var qtyInput  = document.getElementById('stockQuantity');
  var notesInput= document.getElementById('stockNotes');

  function resetStockForm() {
    if (holderType)  holderType.value = 'location';
    if (locSel)      locSel.value     = '';
    if (userSel)     userSel.value    = '';
    if (qtyInput)    qtyInput.value   = '1';
    if (notesInput)  notesInput.value = '';
    if (saveBtn)     saveBtn.textContent = 'Save';
    if (saveBtn)     saveBtn.classList.replace('btn-success', 'btn-primary');
    if (cancelBtn)   cancelBtn.style.display = 'none';
    document.querySelectorAll('.stock-row.table-active').forEach(function(r) {
      r.classList.remove('table-active');
    });
    toggleHolder();
  }

  document.querySelectorAll('.stock-row').forEach(function (row) {
    row.addEventListener('click', function () {
      var holderTypeVal = row.dataset.holderType;
      var locationID    = row.dataset.locationId;
      var userID        = row.dataset.userId;
      var quantity      = row.dataset.quantity;
      var notes         = row.dataset.notes;

      if (holderType)  holderType.value = holderTypeVal;
      toggleHolder();
      if (locSel)      locSel.value     = locationID || '';
      if (userSel)     userSel.value    = userID     || '';
      if (qtyInput)    qtyInput.value   = quantity;
      if (notesInput)  notesInput.value = notes;

      if (saveBtn) {
        saveBtn.textContent = 'Update';
        saveBtn.classList.replace('btn-primary', 'btn-success');
      }
      if (cancelBtn) cancelBtn.style.display = '';

      document.querySelectorAll('.stock-row.table-active').forEach(function(r) {
        r.classList.remove('table-active');
      });
      row.classList.add('table-active');

      document.getElementById('stockForm').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  });

  if (cancelBtn) {
    cancelBtn.addEventListener('click', resetStockForm);
  }

  // ── Unallocated row edit button ─────────────────────────────────────────────
  var editUnallocatedBtn = document.getElementById('editUnallocatedBtn');
  if (editUnallocatedBtn) {
    var unallocatedQtyCell = document.getElementById('unallocatedQtyCell');
    function activateUnallocated(e) {
      e.stopPropagation();
      if (holderType)  holderType.value = 'unallocated';
      toggleHolder();
      if (qtyInput) qtyInput.value = unallocatedQtyCell ? unallocatedQtyCell.textContent.trim() : '0';
      if (notesInput) notesInput.value = '';
      if (saveBtn) {
        saveBtn.textContent = 'Update';
        saveBtn.classList.replace('btn-primary', 'btn-success');
      }
      if (cancelBtn) cancelBtn.style.display = '';
      document.querySelectorAll('.stock-row.table-active').forEach(function(r) { r.classList.remove('table-active'); });
      document.getElementById('unallocatedRow').classList.add('table-active');
      document.getElementById('stockForm').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    editUnallocatedBtn.addEventListener('click', activateUnallocated);
    document.getElementById('unallocatedRow').addEventListener('click', activateUnallocated);
  }

});
</script>
